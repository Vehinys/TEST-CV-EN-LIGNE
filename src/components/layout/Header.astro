---
import type { Lang } from '../../i18n/utils';
import { useTranslations, getAlternateLangPath } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const alternatePath = getAlternateLangPath(Astro.url);

const navLinks = [
  { href: '#about', label: t('nav.about') },
  { href: '#skills', label: t('nav.skills') },
  { href: '#projects', label: t('nav.projects') },
  { href: '#experience', label: t('nav.experience') },
  { href: '#volunteer', label: t('nav.volunteer') },
  { href: '#hobbies', label: t('nav.hobbies') },
  { href: '#contact', label: t('nav.contact') },
] as const;
---

<header id="site-header" class="site-header" role="banner">
  <nav class="nav-container" aria-label={t('nav.home')}>
    <a href={lang === 'en' ? '/en' : '/'} class="nav-logo" aria-label="Albert Lecomte — Accueil">
      <span class="gradient-text" aria-hidden="true">AL</span>
    </a>

    <!-- Desktop nav -->
    <ul class="nav-links" role="list">
      {navLinks.map(({ href, label }) => (
        <li>
          <a href={href} class="nav-link">{label}</a>
        </li>
      ))}
    </ul>

    <div class="nav-actions">
      <!-- Mode OS toggle -->
      <button
        id="mode-toggle-btn"
        class="nav-btn nav-btn--mode"
        type="button"
        aria-label={lang === 'fr' ? 'Passer en mode bureau interactif' : 'Switch to interactive desktop mode'}
        title={lang === 'fr' ? 'Mode bureau' : 'Desktop mode'}
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
        </svg>
      </button>

      <!-- Language toggle -->
      <a href={alternatePath} class="nav-btn" aria-label={t('nav.lang.switch')} lang={lang === 'fr' ? 'en' : 'fr'}>
        {lang === 'fr' ? 'EN' : 'FR'}
      </a>

      <!-- Theme toggle -->
      <button id="theme-toggle" class="nav-btn" aria-label={t('nav.theme.dark')} aria-pressed="false">
        <svg id="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <svg id="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="display:none">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </button>

      <!-- Mobile menu toggle -->
      <button id="mobile-menu-toggle" class="nav-btn nav-btn--mobile" aria-label={t('nav.menu.open')} aria-expanded="false" aria-controls="mobile-menu">
        <svg id="icon-menu" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="display:none">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
    <ul role="list">
      {navLinks.map(({ href, label }) => (
        <li>
          <a href={href} class="mobile-nav-link">{label}</a>
        </li>
      ))}
      <li>
        <a href={alternatePath} class="mobile-nav-link" lang={lang === 'fr' ? 'en' : 'fr'}>
          {t('nav.lang.switch')}
        </a>
      </li>
    </ul>
  </div>
</header>

<style>
.site-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  transition: background 0.3s ease, backdrop-filter 0.3s ease, box-shadow 0.3s ease;
}

.site-header.scrolled {
  background: var(--glass-bg);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--glass-border);
  box-shadow: 0 4px 24px rgba(0,0,0,0.2);
}

.nav-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 1rem 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
}

.nav-logo {
  font-family: var(--font-family-display, 'Space Grotesk', sans-serif);
  font-size: 1.5rem;
  font-weight: 800;
  text-decoration: none;
  letter-spacing: -0.02em;
}

.nav-links {
  display: flex;
  gap: 0.25rem;
  list-style: none;
  padding: 0;
  margin: 0;
}

@media (max-width: 768px) {
  .nav-links { display: none; }
}

.nav-link {
  padding: 0.5rem 0.75rem;
  border-radius: 0.5rem;
  color: var(--color-text-subtle);
  text-decoration: none;
  font-size: 0.9rem;
  font-weight: 500;
  transition: color 0.2s ease, background 0.2s ease;
}

.nav-link:hover,
.nav-link:focus-visible {
  color: var(--color-text);
  background: var(--glass-bg);
}

.nav-actions {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.nav-btn {
  width: 2.25rem;
  height: 2.25rem;
  border-radius: 0.5rem;
  border: 1px solid var(--glass-border);
  background: var(--glass-bg);
  color: var(--color-text-subtle);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem;
  font-weight: 600;
  cursor: pointer;
  text-decoration: none;
  transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease;
}

.nav-btn:hover,
.nav-btn:focus-visible {
  color: var(--color-text);
  background: var(--glass-bg-hover);
  border-color: var(--glass-border-hover);
}

.nav-btn:focus-visible {
  outline: 3px solid var(--color-focus);
  outline-offset: 2px;
}

.nav-btn--mobile {
  display: none;
}

@media (max-width: 768px) {
  .nav-btn--mobile { display: flex; }
}

/* Mobile menu */
.mobile-menu {
  background: var(--glass-bg);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-top: 1px solid var(--glass-border);
  overflow: hidden;
  max-height: 0;
  transition: max-height 0.3s ease;
  display: none;
}

@media (max-width: 768px) {
  .mobile-menu { display: block; }
}

.mobile-menu[aria-hidden="false"] {
  max-height: 400px;
}

.mobile-menu ul {
  list-style: none;
  padding: 1rem 1.5rem;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.mobile-nav-link {
  display: block;
  padding: 0.75rem 1rem;
  border-radius: 0.5rem;
  color: var(--color-text-subtle);
  text-decoration: none;
  font-size: 1rem;
  font-weight: 500;
  transition: color 0.2s ease, background 0.2s ease;
}

.mobile-nav-link:hover,
.mobile-nav-link:focus-visible {
  color: var(--color-text);
  background: var(--glass-bg-hover);
}

.mobile-nav-link:focus-visible {
  outline: 3px solid var(--color-focus);
  outline-offset: 2px;
}
</style>

<script>
(function () {
  const header = document.getElementById('site-header');
  const themeToggle = document.getElementById('theme-toggle') as HTMLButtonElement | null;
  const mobileToggle = document.getElementById('mobile-menu-toggle') as HTMLButtonElement | null;
  const mobileMenu = document.getElementById('mobile-menu');
  const iconMoon = document.getElementById('icon-moon');
  const iconSun = document.getElementById('icon-sun');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  // Mode toggle
  const modeBtnHeader = document.getElementById('mode-toggle-btn');
  modeBtnHeader?.addEventListener('click', () => {
    const html = document.documentElement;
    const next = html.getAttribute('data-portfolio-mode') === 'os' ? 'classic' : 'os';
    html.setAttribute('data-portfolio-mode', next);
    localStorage.setItem('portfolio-mode', next);
  });

  // Scroll header
  window.addEventListener('scroll', () => {
    if (header) {
      header.classList.toggle('scrolled', window.scrollY > 20);
    }
  }, { passive: true });

  // Theme toggle
  const savedTheme = localStorage.getItem('theme') ?? (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
  document.documentElement.setAttribute('data-theme', savedTheme);
  updateThemeIcons(savedTheme);

  themeToggle?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    updateThemeIcons(next);
  });

  function updateThemeIcons(theme: string) {
    if (!iconMoon || !iconSun || !themeToggle) return;
    if (theme === 'dark') {
      iconMoon.style.display = '';
      iconSun.style.display = 'none';
    } else {
      iconMoon.style.display = 'none';
      iconSun.style.display = '';
    }
  }

  // Mobile menu
  mobileToggle?.addEventListener('click', () => {
    const isOpen = mobileMenu?.getAttribute('aria-hidden') === 'false';
    mobileMenu?.setAttribute('aria-hidden', isOpen ? 'true' : 'false');
    mobileToggle.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
    if (iconMenu && iconClose) {
      iconMenu.style.display = isOpen ? '' : 'none';
      iconClose.style.display = isOpen ? 'none' : '';
    }
  });

  // Close mobile menu on link click
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.setAttribute('aria-hidden', 'true');
      mobileToggle?.setAttribute('aria-expanded', 'false');
      if (iconMenu && iconClose) {
        iconMenu.style.display = '';
        iconClose.style.display = 'none';
      }
    });
  });

  // Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileMenu?.getAttribute('aria-hidden') === 'false') {
      mobileMenu.setAttribute('aria-hidden', 'true');
      mobileToggle?.setAttribute('aria-expanded', 'false');
      if (iconMenu && iconClose) {
        iconMenu.style.display = '';
        iconClose.style.display = 'none';
      }
      mobileToggle?.focus();
    }
  });
})();
</script>

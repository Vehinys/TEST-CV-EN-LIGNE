---
import { getCollection } from 'astro:content';
import type { Lang } from '../../i18n/utils';
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const allVolunteer = await getCollection('volunteer');
const volunteerItems = allVolunteer
  .map(v => ({ ...v.data, id: v.id }))
  .sort((a, b) => a.order - b.order);
---

<div class="vol-win">
  <div class="vol-win__header">
    <span class="win-label">{t('volunteer.title')}</span>
    <h2 class="win-title">{t('volunteer.subtitle')}</h2>
  </div>

  <ul class="vol-win__list" role="list">
    {volunteerItems.map(item => (
      <li class="vol-card" role="listitem">
        <div class="vol-card__icon" aria-hidden="true">
          {item.icon}
        </div>
        <div class="vol-card__content">
          <div class="vol-card__header">
            <h3 class="vol-card__org">{item.organization}</h3>
            <span class="vol-card__period">{item.period}</span>
          </div>
          <p class="vol-card__role">
            {lang === 'en' ? item.titleEn : item.title}
          </p>
          <p class="vol-card__desc">
            {lang === 'en' ? item.descriptionEn : item.description}
          </p>
        </div>
      </li>
    ))}
  </ul>
</div>

<style>
.vol-win {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.win-label {
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #F59E0B;
  display: block;
  margin-bottom: 0.25rem;
}

.win-title {
  font-size: clamp(1.25rem, 3vw, 1.75rem);
  font-weight: 700;
  color: #FAF5FF;
  margin: 0;
}

.vol-win__list {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  list-style: none;
  padding: 0;
  margin: 0;
}

.vol-card {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 1.25rem;
  padding: 1.25rem;
  background: rgba(139, 92, 246, 0.06);
  border: 1px solid rgba(139, 92, 246, 0.18);
  border-radius: 0.75rem;
  align-items: start;
  transition: border-color 0.2s ease;
}

.vol-card:hover {
  border-color: rgba(139, 92, 246, 0.35);
}

.vol-card__icon {
  font-size: 1.75rem;
  width: 3rem;
  height: 3rem;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(139, 92, 246, 0.1);
  border: 1px solid rgba(139, 92, 246, 0.2);
  border-radius: 0.625rem;
  flex-shrink: 0;
}

.vol-card__content {
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
}

.vol-card__header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.vol-card__org {
  font-size: 1rem;
  font-weight: 700;
  color: #FAF5FF;
  margin: 0;
}

.vol-card__period {
  font-size: 0.75rem;
  font-weight: 600;
  color: #8B5CF6;
}

.vol-card__role {
  font-size: 0.875rem;
  font-weight: 600;
  color: #A78BFA;
  margin: 0;
}

.vol-card__desc {
  font-size: 0.8125rem;
  color: #C4B5FD;
  line-height: 1.65;
  margin: 0;
}

@media (max-width: 500px) {
  .vol-card {
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
}
</style>

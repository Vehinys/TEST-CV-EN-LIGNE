---
import { getCollection } from 'astro:content';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const allVolunteer = await getCollection('volunteer');
const volunteerItems = allVolunteer
  .map(v => ({ ...v.data, id: v.id }))
  .sort((a, b) => a.order - b.order);

const labels = {
  fr: {
    windowTitle: 'Bénévolat — Carnet d\'adresses',
    searchPlaceholder: 'Rechercher une organisation...',
    contacts: 'Contacts',
    noSelection: 'Sélectionnez un contact pour afficher les détails',
  },
  en: {
    windowTitle: 'Volunteer — Contacts',
    searchPlaceholder: 'Search an organization...',
    contacts: 'Contacts',
    noSelection: 'Select a contact to view details',
  },
} as const;

const l = labels[lang];
---

<div class="contacts-win" role="region" aria-label={l.windowTitle}>

  <!-- Left panel: contact list -->
  <div class="contacts-list-panel" role="navigation" aria-label={l.contacts}>

    <!-- Search bar (cosmetic) -->
    <div class="contacts-search" aria-hidden="true">
      <span class="contacts-search__icon">🔍</span>
      <span class="contacts-search__text">{l.searchPlaceholder}</span>
    </div>

    <!-- Contact list -->
    <ul class="contacts-list" role="list" id="contacts-list">
      {volunteerItems.map((item, i) => (
        <li>
          <button
            class={`contacts-contact ${i === 0 ? 'contacts-contact--active' : ''}`}
            type="button"
            data-index={i}
            aria-pressed={i === 0 ? 'true' : 'false'}
            aria-label={`${item.organization} — ${lang === 'fr' ? item.title : item.titleEn}`}
          >
            <span class="contacts-contact__avatar">
              {item.icon}
            </span>
            <div class="contacts-contact__info">
              <span class="contacts-contact__org">{item.organization}</span>
              <span class="contacts-contact__role">
                {lang === 'fr' ? item.title : item.titleEn}
              </span>
              <span class="contacts-contact__period">{item.period}</span>
            </div>
          </button>
        </li>
      ))}
    </ul>
  </div>

  <!-- Right panel: contact detail -->
  <div
    class="contacts-detail-panel"
    id="contacts-detail"
    aria-live="polite"
    aria-atomic="true"
    role="main"
  >
    {volunteerItems.map((item, i) => (
      <div
        class={`contacts-card ${i === 0 ? '' : 'contacts-card--hidden'}`}
        data-contact-index={i}
        aria-hidden={i === 0 ? 'false' : 'true'}
      >
        <!-- Avatar -->
        <div class="contacts-card__avatar-wrap">
          <div class="contacts-card__avatar">
            <span class="contacts-card__avatar-emoji">{item.icon}</span>
          </div>
        </div>

        <!-- Identity -->
        <div class="contacts-card__identity">
          <h2 class="contacts-card__org">{item.organization}</h2>
          <p class="contacts-card__role">{lang === 'fr' ? item.title : item.titleEn}</p>
          <span class="contacts-card__period-badge">{item.period}</span>
        </div>

        <hr class="contacts-card__divider" aria-hidden="true" />

        <!-- Description -->
        <div class="contacts-card__body">
          <p class="contacts-card__desc">
            {lang === 'fr' ? item.description : item.descriptionEn}
          </p>
        </div>
      </div>
    ))}

    <!-- Placeholder if no items -->
    {volunteerItems.length === 0 && (
      <div class="contacts-placeholder">
        <span aria-hidden="true">👤</span>
        <p>{l.noSelection}</p>
      </div>
    )}
  </div>

</div>

<style>
/* ── Root ──────────────────────────────────────────────────────── */
.contacts-win {
  display: grid;
  grid-template-columns: 40% 60%;
  background: #080613;
  border: 1px solid rgba(139, 92, 246, 0.25);
  border-radius: 0.5rem;
  overflow: hidden;
  font-size: 0.8125rem;
  min-height: 360px;
}

@media (max-width: 500px) {
  .contacts-win {
    grid-template-columns: 1fr;
    grid-template-rows: auto 1fr;
  }
}

/* ── Left panel ────────────────────────────────────────────────── */
.contacts-list-panel {
  border-right: 1px solid rgba(139, 92, 246, 0.18);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* Search bar */
.contacts-search {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 0.75rem;
  background: rgba(0, 0, 0, 0.25);
  border-bottom: 1px solid rgba(139, 92, 246, 0.15);
  flex-shrink: 0;
}

.contacts-search__icon {
  font-size: 0.75rem;
  opacity: 0.5;
}

.contacts-search__text {
  font-size: 0.75rem;
  color: #475569;
  font-style: italic;
}

/* Contact list */
.contacts-list {
  list-style: none;
  padding: 0.375rem 0;
  margin: 0;
  overflow-y: auto;
  flex: 1;
}

.contacts-contact {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  width: 100%;
  padding: 0.5rem 0.75rem;
  background: transparent;
  border: none;
  cursor: pointer;
  font-family: inherit;
  text-align: left;
  transition: background 0.15s ease;
  border-left: 2px solid transparent;
}

.contacts-contact:hover {
  background: rgba(139, 92, 246, 0.07);
}

.contacts-contact--active {
  background: rgba(139, 92, 246, 0.14);
  border-left-color: #8B5CF6;
}

.contacts-contact--active .contacts-contact__org {
  color: #FAF5FF;
}

.contacts-contact:focus-visible {
  outline: 2px solid #F59E0B;
  outline-offset: -2px;
}

.contacts-contact__avatar {
  width: 2.5rem;
  height: 2.5rem;
  border-radius: 50%;
  background: rgba(139, 92, 246, 0.12);
  border: 1px solid rgba(139, 92, 246, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.25rem;
  flex-shrink: 0;
}

.contacts-contact--active .contacts-contact__avatar {
  background: rgba(139, 92, 246, 0.25);
  border-color: rgba(139, 92, 246, 0.5);
}

.contacts-contact__info {
  display: flex;
  flex-direction: column;
  gap: 0.1rem;
  min-width: 0;
}

.contacts-contact__org {
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--color-text-subtle);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  transition: color 0.15s ease;
}

.contacts-contact__role {
  font-size: 0.7rem;
  color: var(--color-text-dim);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.contacts-contact__period {
  font-size: 0.65rem;
  color: #8B5CF6;
  font-weight: 600;
}

/* ── Right panel ───────────────────────────────────────────────── */
.contacts-detail-panel {
  overflow-y: auto;
  padding: 1.5rem 1.25rem;
  position: relative;
}

/* Contact card */
.contacts-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 0.875rem;
  animation: contacts-fadein 0.2s ease;
}

@media (prefers-reduced-motion: reduce) {
  .contacts-card { animation: none; }
}

.contacts-card--hidden {
  display: none;
}

@keyframes contacts-fadein {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

.contacts-card__avatar-wrap {
  margin-top: 0.5rem;
}

.contacts-card__avatar {
  width: 5rem;
  height: 5rem;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(139, 92, 246, 0.25) 0%, rgba(139, 92, 246, 0.05) 70%);
  border: 2px solid rgba(139, 92, 246, 0.4);
  box-shadow: 0 0 24px rgba(139, 92, 246, 0.25), 0 0 48px rgba(139, 92, 246, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
}

.contacts-card__avatar-emoji {
  font-size: 2.5rem;
  line-height: 1;
}

.contacts-card__identity {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.25rem;
}

.contacts-card__org {
  font-size: 1.1rem;
  font-weight: 800;
  color: #FAF5FF;
  margin: 0;
  line-height: 1.2;
}

.contacts-card__role {
  font-size: 0.875rem;
  color: #F59E0B;
  font-weight: 600;
  margin: 0;
}

.contacts-card__period-badge {
  display: inline-block;
  padding: 0.2rem 0.625rem;
  background: rgba(139, 92, 246, 0.1);
  border: 1px solid rgba(139, 92, 246, 0.25);
  border-radius: 999px;
  font-size: 0.7rem;
  color: #A78BFA;
  font-weight: 600;
  margin-top: 0.125rem;
}

.contacts-card__divider {
  width: 100%;
  border: none;
  border-top: 1px solid rgba(139, 92, 246, 0.15);
  margin: 0.125rem 0;
}

.contacts-card__body {
  width: 100%;
  text-align: left;
}

.contacts-card__desc {
  font-size: 0.8125rem;
  color: var(--color-text-subtle);
  line-height: 1.7;
  margin: 0;
}

/* Placeholder */
.contacts-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  height: 100%;
  min-height: 200px;
  color: #475569;
  font-size: 0.875rem;
  text-align: center;
}

.contacts-placeholder span {
  font-size: 2.5rem;
  opacity: 0.3;
}
</style>

<script>
(function () {
  const win = document.querySelector<HTMLElement>('.contacts-win');
  if (!win) return;

  const contactBtns = win.querySelectorAll<HTMLButtonElement>('.contacts-contact');
  const cards       = win.querySelectorAll<HTMLElement>('.contacts-card');

  contactBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = btn.dataset['index'];
      if (idx === undefined) return;

      // Update list selection
      contactBtns.forEach(b => {
        b.classList.remove('contacts-contact--active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('contacts-contact--active');
      btn.setAttribute('aria-pressed', 'true');

      // Update detail panel
      cards.forEach(card => {
        const cardIdx = card.dataset['contactIndex'];
        if (cardIdx === idx) {
          card.classList.remove('contacts-card--hidden');
          card.setAttribute('aria-hidden', 'false');
        } else {
          card.classList.add('contacts-card--hidden');
          card.setAttribute('aria-hidden', 'true');
        }
      });
    });
  });
})();
</script>

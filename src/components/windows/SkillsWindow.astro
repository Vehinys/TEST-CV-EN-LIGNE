---
import { getCollection } from 'astro:content';
import type { Lang } from '../../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;

// ── Processus : Design uniquement ───────────────────────────────
const allSkillEntries = await getCollection('skills');
const designSkills = (allSkillEntries[0]?.data ?? [])
  .filter(s => s.category === 'design')
  .sort((a, b) => a.order - b.order);

const versionLabels: Record<number, string> = {
  1: 'v0.1 alpha', 2: 'v1.0 beta', 3: 'v2.0 stable', 4: 'v3.0 LTS', 5: 'v5.0 PROD',
};
const processStates: Record<number, { text: string; cls: string }> = {
  1: { text: 'SUSPENDED', cls: 'grey'   },
  2: { text: 'IDLE',      cls: 'grey'   },
  3: { text: 'SLEEPING',  cls: 'yellow' },
  4: { text: 'RUNNING',   cls: 'green'  },
  5: { text: 'RUNNING',   cls: 'green'  },
};
function getStatus(level: number) {
  if (level >= 4) return { dot: 'green',  label: lang === 'fr' ? 'Actif' : 'Active' };
  if (level === 3) return { dot: 'yellow', label: 'Stable' };
  return { dot: 'grey', label: lang === 'fr' ? 'Inactif' : 'Inactive' };
}

// ── Environnement : Code ─────────────────────────────────────────
const codeItems = [
  { name: 'Windows 11',      catFr: 'Système',      catEn: 'System'      },
  { name: 'VS Code',         catFr: 'Éditeur',      catEn: 'Editor'      },
  { name: 'Antigravity',     catFr: 'Éditeur',      catEn: 'Editor'      },
  { name: 'JetBrains Mono',  catFr: 'Police code',  catEn: 'Code font'   },
  { name: 'Chrome',          catFr: 'Navigateur',   catEn: 'Browser'     },
  { name: 'HTML5 / CSS3',    catFr: 'Frontend',     catEn: 'Frontend'    },
  { name: 'JavaScript',      catFr: 'Frontend',     catEn: 'Frontend'    },
  { name: 'Tailwind CSS',    catFr: 'Frontend',     catEn: 'Frontend'    },
  { name: 'PHP / Symfony',   catFr: 'Backend',      catEn: 'Backend'     },
  { name: 'MySQL',           catFr: 'Base de données', catEn: 'Database' },
  { name: 'Git / GitHub',    catFr: 'Dépôts',       catEn: 'Repos'       },
  { name: 'Vercel',          catFr: 'Déploiement',  catEn: 'Deploy'      },
  { name: 'SEO / SEA',       catFr: 'SEO',          catEn: 'SEO'         },
] as const;

// ── WordPress ────────────────────────────────────────────────────
const wpItems = [
  { name: 'WordPress',      catFr: 'CMS',          catEn: 'CMS'          },
  { name: 'Elementor',      catFr: 'Page builder', catEn: 'Page builder' },
  { name: 'Divi',           catFr: 'Page builder', catEn: 'Page builder' },
  { name: 'Gutenberg',      catFr: 'Éditeur WP',   catEn: 'WP Editor'    },
  { name: 'Rank Math SEO',  catFr: 'SEO',          catEn: 'SEO'          },
] as const;

const labels = {
  fr: {
    tabProcesses: 'Design',
    tabCode:      'Code',
    tabWp:        'WordPress',
    colProcess:   'Processus',
    colUsage:     'Utilisation',
    colLevel:     'Version',
    colStatus:    'Statut',
    footer:       `CPU Albert.exe\u00a0: Actif\u00a0| Design\u00a0: ${designSkills.length} proc.\u00a0| Démarré\u00a0: 2021`,
    codeTitle:    'Environnement code',
    wpTitle:      'Environnement WordPress',
  },
  en: {
    tabProcesses: 'Design',
    tabCode:      'Code',
    tabWp:        'WordPress',
    colProcess:   'Process',
    colUsage:     'Usage',
    colLevel:     'Version',
    colStatus:    'Status',
    footer:       `CPU Albert.exe: Active | Design: ${designSkills.length} proc. | Started: 2021`,
    codeTitle:    'Code environment',
    wpTitle:      'WordPress environment',
  },
} as const;

const l = labels[lang];
---

<div class="taskmgr-win" role="region" aria-label={lang === 'fr' ? 'Gestionnaire des tâches — Compétences' : 'Task Manager — Skills'}>

  <!-- Tab bar -->
  <div class="taskmgr-tabs" role="tablist" aria-label={lang === 'fr' ? 'Onglets' : 'Tabs'}>
    <button
      class="taskmgr-tab taskmgr-tab--active"
      role="tab"
      id="tab-processes"
      aria-selected="true"
      aria-controls="panel-processes"
      type="button"
    >
      <span aria-hidden="true">📋</span>
      {l.tabProcesses}
    </button>
    <button
      class="taskmgr-tab"
      role="tab"
      id="tab-code"
      aria-selected="false"
      aria-controls="panel-code"
      type="button"
    >
      <span aria-hidden="true">🖥️</span>
      {l.tabCode}
    </button>
    <button
      class="taskmgr-tab"
      role="tab"
      id="tab-wp"
      aria-selected="false"
      aria-controls="panel-wp"
      type="button"
    >
      <span aria-hidden="true">🌐</span>
      {l.tabWp}
    </button>
  </div>

  <!-- Panel: Design -->
  <div
    class="taskmgr-panel"
    id="panel-processes"
    role="tabpanel"
    aria-labelledby="tab-processes"
  >
    <div class="taskmgr-table-wrap">
      <table class="taskmgr-table" aria-label={lang === 'fr' ? 'Compétences Design' : 'Design Skills'}>
        <thead>
          <tr class="taskmgr-thead__row">
            <th scope="col" class="taskmgr-th taskmgr-th--name">{l.colProcess}</th>
            <th scope="col" class="taskmgr-th taskmgr-th--bar">{l.colUsage}</th>
            <th scope="col" class="taskmgr-th taskmgr-th--level">{l.colLevel}</th>
            <th scope="col" class="taskmgr-th taskmgr-th--status">{l.colStatus}</th>
          </tr>
        </thead>
        <tbody>
          {designSkills.map((skill, idx) => {
            const status = getStatus(skill.level);
            const verLabel = versionLabels[skill.level] ?? 'v?';
            return (
              <tr class={`taskmgr-row ${idx % 2 === 0 ? '' : 'taskmgr-row--alt'}`}>
                <td class="taskmgr-td taskmgr-td--name">{skill.name}</td>
                <td class="taskmgr-td taskmgr-td--bar">
                  <span
                    class={`taskmgr-state taskmgr-state--${processStates[skill.level]?.cls ?? 'grey'}`}
                    aria-label={`${skill.name}: ${processStates[skill.level]?.text ?? ''}`}
                  >
                    {processStates[skill.level]?.text ?? 'UNKNOWN'}
                  </span>
                </td>
                <td class="taskmgr-td taskmgr-td--level">{verLabel}</td>
                <td class="taskmgr-td taskmgr-td--status">
                  <span class={`taskmgr-dot taskmgr-dot--${status.dot}`} aria-label={status.label}></span>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Panel: Code -->
  <div
    class="taskmgr-panel taskmgr-panel--hidden"
    id="panel-code"
    role="tabpanel"
    aria-labelledby="tab-code"
    tabindex="0"
  >
    <div class="taskmgr-cmd" aria-label={l.codeTitle}>
      <div class="taskmgr-cmd__line taskmgr-cmd__line--prompt">
        <span class="taskmgr-cmd__prompt">C:\albert-exe&gt;</span>
        <span class="taskmgr-cmd__input">list-env --code</span>
      </div>
      <div class="taskmgr-cmd__line taskmgr-cmd__line--info">
        {lang === 'fr' ? '// Environnement code — albert-exe v2026' : '// Code environment — albert-exe v2026'}
      </div>
      <div class="taskmgr-cmd__sep" aria-hidden="true"></div>
      <ul class="taskmgr-cmd__entries" aria-label={l.codeTitle}>
        {codeItems.map((item, i) => (
          <li class="taskmgr-cmd__entry">
            <span class="taskmgr-cmd__index" aria-hidden="true">[{String(i + 1).padStart(2, '0')}]</span>
            <span class="taskmgr-cmd__name">{item.name}</span>
            <span class="taskmgr-cmd__arrow" aria-hidden="true">→</span>
            <span class="taskmgr-cmd__tag">{lang === 'fr' ? item.catFr : item.catEn}</span>
          </li>
        ))}
      </ul>
      <div class="taskmgr-cmd__sep" aria-hidden="true"></div>
      <div class="taskmgr-cmd__line taskmgr-cmd__line--ok">
        {lang === 'fr' ? `✓  ${codeItems.length} entrées chargées` : `✓  ${codeItems.length} entries loaded`}
      </div>
    </div>
  </div>

  <!-- Panel: WordPress -->
  <div
    class="taskmgr-panel taskmgr-panel--hidden"
    id="panel-wp"
    role="tabpanel"
    aria-labelledby="tab-wp"
    tabindex="0"
  >
    <div class="taskmgr-cmd" aria-label={l.wpTitle}>
      <div class="taskmgr-cmd__line taskmgr-cmd__line--prompt">
        <span class="taskmgr-cmd__prompt">C:\albert-exe&gt;</span>
        <span class="taskmgr-cmd__input">list-env --wordpress</span>
      </div>
      <div class="taskmgr-cmd__line taskmgr-cmd__line--info">
        {lang === 'fr' ? '// Environnement WordPress — albert-exe v2026' : '// WordPress environment — albert-exe v2026'}
      </div>
      <div class="taskmgr-cmd__sep" aria-hidden="true"></div>
      <ul class="taskmgr-cmd__entries" aria-label={l.wpTitle}>
        {wpItems.map((item, i) => (
          <li class="taskmgr-cmd__entry">
            <span class="taskmgr-cmd__index" aria-hidden="true">[{String(i + 1).padStart(2, '0')}]</span>
            <span class="taskmgr-cmd__name">{item.name}</span>
            <span class="taskmgr-cmd__arrow" aria-hidden="true">→</span>
            <span class="taskmgr-cmd__tag">{lang === 'fr' ? item.catFr : item.catEn}</span>
          </li>
        ))}
      </ul>
      <div class="taskmgr-cmd__sep" aria-hidden="true"></div>
      <div class="taskmgr-cmd__line taskmgr-cmd__line--ok">
        {lang === 'fr' ? `✓  ${wpItems.length} entrées chargées` : `✓  ${wpItems.length} entries loaded`}
      </div>
    </div>
  </div>

  <!-- Footer -->
  <div class="taskmgr-footer" aria-label={lang === 'fr' ? 'Informations système' : 'System info'}>
    <span class="taskmgr-footer__text">{l.footer}</span>
  </div>

</div>

<style>
/* ── Root ──────────────────────────────────────────────────────── */
.taskmgr-win {
  display: flex;
  flex-direction: column;
  background: #080613;
  border: 1px solid rgba(139, 92, 246, 0.25);
  border-radius: 0.5rem;
  overflow: hidden;
  font-size: 0.8125rem;
}

/* ── Tabs ──────────────────────────────────────────────────────── */
.taskmgr-tabs {
  display: flex;
  background: rgba(139, 92, 246, 0.06);
  border-bottom: 1px solid rgba(139, 92, 246, 0.2);
  flex-shrink: 0;
}

.taskmgr-tab {
  display: flex;
  align-items: center;
  gap: 0.375rem;
  padding: 0.5rem 1rem;
  background: transparent;
  border: none;
  border-bottom: 2px solid transparent;
  color: #94A3B8;
  font-size: 0.75rem;
  font-weight: 600;
  cursor: pointer;
  font-family: inherit;
  transition: color 0.15s ease, border-color 0.15s ease;
  letter-spacing: 0.01em;
}

.taskmgr-tab:hover {
  color: #C4B5FD;
}

.taskmgr-tab--active {
  color: #A78BFA;
  border-bottom-color: #8B5CF6;
}

.taskmgr-tab:focus-visible {
  outline: 2px solid #F59E0B;
  outline-offset: -2px;
}

/* ── Panels ────────────────────────────────────────────────────── */
.taskmgr-panel {
  flex: 1;
  overflow: auto;
}

.taskmgr-panel--hidden {
  display: none;
}

/* ── Table ─────────────────────────────────────────────────────── */
.taskmgr-table-wrap {
  overflow-x: auto;
}

.taskmgr-table {
  width: 100%;
  border-collapse: collapse;
}

.taskmgr-thead__row {
  background: rgba(139, 92, 246, 0.1);
  position: sticky;
  top: 0;
  z-index: 1;
}

.taskmgr-th {
  padding: 0.4rem 0.75rem;
  text-align: left;
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: #8B5CF6;
  border-bottom: 1px solid rgba(139, 92, 246, 0.2);
  white-space: nowrap;
}

.taskmgr-th--bar    { width: 35%; }
.taskmgr-th--level  { width: 18%; }
.taskmgr-th--status { width: 12%; text-align: center; }

/* Group headers */
.taskmgr-group-header {
  background: rgba(139, 92, 246, 0.08);
}

.taskmgr-group-header__cell {
  padding: 0.375rem 0.75rem;
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: #A78BFA;
  display: flex;
  align-items: center;
  gap: 0.4rem;
}

/* Rows */
.taskmgr-row {
  border-bottom: 1px solid rgba(139, 92, 246, 0.06);
  transition: background 0.1s ease;
}

.taskmgr-row:hover {
  background: rgba(139, 92, 246, 0.06);
}

.taskmgr-row--alt {
  background: rgba(255, 255, 255, 0.015);
}

.taskmgr-row--alt:hover {
  background: rgba(139, 92, 246, 0.06);
}

.taskmgr-td {
  padding: 0.35rem 0.75rem;
  vertical-align: middle;
}

.taskmgr-td--name {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  color: #FAF5FF;
  font-size: 0.8rem;
  white-space: nowrap;
}

.taskmgr-td__icon {
  font-size: 0.875rem;
}

/* Process state */
.taskmgr-td--bar {
  display: flex;
  align-items: center;
}

.taskmgr-state {
  font-family: 'Consolas', 'Courier New', monospace;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  white-space: nowrap;
}

.taskmgr-state--green  { color: #4ade80; }
.taskmgr-state--yellow { color: #F59E0B; }
.taskmgr-state--grey   { color: #475569; }

.taskmgr-td--level {
  font-size: 0.7rem;
  color: #C4B5FD;
  white-space: nowrap;
}

.taskmgr-td--status {
  text-align: center;
}

/* Status dots */
.taskmgr-dot {
  display: inline-block;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

.taskmgr-dot--green  { background: #4ade80; box-shadow: 0 0 4px #4ade80; }
.taskmgr-dot--yellow { background: #F59E0B; box-shadow: 0 0 4px rgba(245, 158, 11, 0.6); }
.taskmgr-dot--grey   { background: #475569; }

/* ── CMD panel ─────────────────────────────────────────────────── */
.taskmgr-cmd {
  padding: 0.75rem 0.875rem;
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
  font-family: 'Consolas', 'Courier New', monospace;
  font-size: 0.75rem;
  overflow-y: auto;
}

.taskmgr-cmd__line {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.1rem 0;
}

.taskmgr-cmd__line--prompt {
  margin-bottom: 0.1rem;
}

.taskmgr-cmd__prompt {
  color: #4ade80;
  font-weight: 700;
  flex-shrink: 0;
}

.taskmgr-cmd__input {
  color: #FAF5FF;
}

.taskmgr-cmd__line--info {
  color: #475569;
  font-size: 0.7rem;
  padding-left: 0.25rem;
}

.taskmgr-cmd__line--ok {
  color: #4ade80;
  font-size: 0.7rem;
  margin-top: 0.1rem;
}

.taskmgr-cmd__sep {
  height: 1px;
  background: rgba(139, 92, 246, 0.12);
  margin: 0.35rem 0;
}

.taskmgr-cmd__entries {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.05rem;
}

.taskmgr-cmd__entry {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.18rem 0.25rem;
  border-radius: 0.2rem;
  transition: background 0.1s ease;
}

.taskmgr-cmd__entry:hover {
  background: rgba(139, 92, 246, 0.07);
}

.taskmgr-cmd__index {
  color: #475569;
  font-size: 0.65rem;
  flex-shrink: 0;
  min-width: 2rem;
}

.taskmgr-cmd__name {
  color: #FAF5FF;
  flex: 1;
}

.taskmgr-cmd__arrow {
  color: #8B5CF6;
  flex-shrink: 0;
}

.taskmgr-cmd__tag {
  color: #A78BFA;
  font-size: 0.65rem;
  min-width: 7rem;
  text-align: right;
}

/* ── Footer ────────────────────────────────────────────────────── */
.taskmgr-footer {
  padding: 0.3rem 0.75rem;
  background: rgba(139, 92, 246, 0.05);
  border-top: 1px solid rgba(139, 92, 246, 0.15);
  flex-shrink: 0;
}

.taskmgr-footer__text {
  font-size: 0.65rem;
  color: #475569;
  font-family: 'Consolas', 'Courier New', monospace;
}
</style>

<script>
(function () {
  const win = document.querySelector<HTMLElement>('.taskmgr-win');
  if (!win) return;

  const tabs   = win.querySelectorAll<HTMLButtonElement>('.taskmgr-tab');
  const panels = win.querySelectorAll<HTMLElement>('.taskmgr-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const targetId = tab.getAttribute('aria-controls');
      if (!targetId) return;

      tabs.forEach(t => {
        t.classList.remove('taskmgr-tab--active');
        t.setAttribute('aria-selected', 'false');
      });
      panels.forEach(p => p.classList.add('taskmgr-panel--hidden'));

      tab.classList.add('taskmgr-tab--active');
      tab.setAttribute('aria-selected', 'true');

      const targetPanel = win.querySelector<HTMLElement>(`#${targetId}`);
      targetPanel?.classList.remove('taskmgr-panel--hidden');
    });
  });
})();
</script>

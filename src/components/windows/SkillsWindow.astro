---
import { getCollection } from 'astro:content';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const allSkillEntries = await getCollection('skills');
const skills = (allSkillEntries[0]?.data ?? []).sort((a, b) => a.order - b.order);

const categories = ['design', 'frontend', 'backend', 'tools'] as const;

type Category = typeof categories[number];

const catMeta: Record<Category, { icon: string; labelFr: string; labelEn: string }> = {
  design:   { icon: '🎨', labelFr: 'Design',    labelEn: 'Design' },
  frontend: { icon: '🖥️', labelFr: 'Front-end', labelEn: 'Front-end' },
  backend:  { icon: '⚙️', labelFr: 'Back-end',  labelEn: 'Back-end' },
  tools:    { icon: '🔧', labelFr: 'Outils',    labelEn: 'Tools' },
};

const versionLabels: Record<number, string> = {
  1: 'v0.1 alpha 🚧',
  2: 'v1.0 beta  🧪',
  3: 'v2.0 stable',
  4: 'v3.0 LTS ⚡',
  5: 'v5.0 PROD 🔥',
};

const processStates: Record<number, { text: string; cls: string }> = {
  1: { text: 'SUSPENDED', cls: 'grey'   },
  2: { text: 'IDLE',      cls: 'grey'   },
  3: { text: 'SLEEPING',  cls: 'yellow' },
  4: { text: 'RUNNING',   cls: 'green'  },
  5: { text: 'RUNNING',   cls: 'green'  },
};

function getStatus(level: number): { dot: string; label: string } {
  if (level >= 4) return { dot: 'green',  label: lang === 'fr' ? 'Actif' : 'Active' };
  if (level === 3) return { dot: 'yellow', label: lang === 'fr' ? 'Stable' : 'Stable' };
  return { dot: 'grey', label: lang === 'fr' ? 'Inactif' : 'Inactive' };
}

// Compute avg for each category (for Performances tab)
function avg(cat: Category): number {
  const catSkills = skills.filter(s => s.category === cat);
  if (catSkills.length === 0) return 0;
  return Math.round(catSkills.reduce((sum, s) => sum + s.level, 0) / catSkills.length * 20);
}

const processCount = skills.length;

const labels = {
  fr: {
    tabProcesses:    'Processus',
    tabPerformances: 'Performances',
    colProcess:      'Processus',
    colUsage:        'Utilisation',
    colLevel:        'Version',
    colStatus:       'Statut',
    footer:          `CPU Albert.exe\u00a0: Actif\u00a0| Processus\u00a0: ${processCount}\u00a0| Démarré\u00a0: 2021`,
    perfTitle:       (cat: string) => `Catégorie\u00a0: ${cat}`,
    perfScore:       (n: number) => `BENCHMARK\u00a0: ${n} pts`,
  },
  en: {
    tabProcesses:    'Processes',
    tabPerformances: 'Performance',
    colProcess:      'Process',
    colUsage:        'Usage',
    colLevel:        'Version',
    colStatus:       'Status',
    footer:          `CPU Albert.exe: Active | Processes: ${processCount} | Started: 2021`,
    perfTitle:       (cat: string) => `Category: ${cat}`,
    perfScore:       (n: number) => `BENCHMARK: ${n} pts`,
  },
} as const;

const l = labels[lang];
---

<div class="taskmgr-win" role="region" aria-label={lang === 'fr' ? 'Gestionnaire des tâches — Compétences' : 'Task Manager — Skills'}>

  <!-- Tab bar -->
  <div class="taskmgr-tabs" role="tablist" aria-label={lang === 'fr' ? 'Onglets' : 'Tabs'}>
    <button
      class="taskmgr-tab taskmgr-tab--active"
      role="tab"
      id="tab-processes"
      aria-selected="true"
      aria-controls="panel-processes"
      type="button"
    >
      <span aria-hidden="true">📋</span>
      {l.tabProcesses}
    </button>
    <button
      class="taskmgr-tab"
      role="tab"
      id="tab-perf"
      aria-selected="false"
      aria-controls="panel-perf"
      type="button"
    >
      <span aria-hidden="true">📈</span>
      {l.tabPerformances}
    </button>
  </div>

  <!-- Panel: Processus -->
  <div
    class="taskmgr-panel"
    id="panel-processes"
    role="tabpanel"
    aria-labelledby="tab-processes"
  >
    <div class="taskmgr-table-wrap">
      <table class="taskmgr-table" aria-label={lang === 'fr' ? 'Liste des compétences' : 'Skills list'}>
        <thead>
          <tr class="taskmgr-thead__row">
            <th scope="col" class="taskmgr-th taskmgr-th--name">{l.colProcess}</th>
            <th scope="col" class="taskmgr-th taskmgr-th--bar">{l.colUsage}</th>
            <th scope="col" class="taskmgr-th taskmgr-th--level">{l.colLevel}</th>
            <th scope="col" class="taskmgr-th taskmgr-th--status">{l.colStatus}</th>
          </tr>
        </thead>
        <tbody>
          {categories.map(cat => {
            const catSkills = skills.filter(s => s.category === cat);
            if (catSkills.length === 0) return null;
            const meta = catMeta[cat];
            return (
              <>
                <tr class="taskmgr-group-header">
                  <td colspan="4" class="taskmgr-group-header__cell">
                    <span aria-hidden="true">{meta.icon}</span>
                    {lang === 'fr' ? meta.labelFr : meta.labelEn}
                  </td>
                </tr>
                {catSkills.map((skill, idx) => {
                  const status = getStatus(skill.level);
                  const verLabel = versionLabels[skill.level] ?? 'v?';
                  return (
                    <tr class={`taskmgr-row ${idx % 2 === 0 ? '' : 'taskmgr-row--alt'}`}>
                      <td class="taskmgr-td taskmgr-td--name">
                        <span class="taskmgr-td__icon" aria-hidden="true">{skill.icon}</span>
                        {skill.name}
                      </td>
                      <td class="taskmgr-td taskmgr-td--bar">
                        <span class={`taskmgr-state taskmgr-state--${processStates[skill.level]?.cls ?? 'grey'}`}
                          aria-label={`${skill.name}: ${processStates[skill.level]?.text ?? ''}`}>
                          {processStates[skill.level]?.text ?? 'UNKNOWN'}
                        </span>
                      </td>
                      <td class="taskmgr-td taskmgr-td--level">{verLabel}</td>
                      <td class="taskmgr-td taskmgr-td--status">
                        <span class={`taskmgr-dot taskmgr-dot--${status.dot}`} aria-label={status.label}></span>
                      </td>
                    </tr>
                  );
                })}
              </>
            );
          })}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Panel: Performances -->
  <div
    class="taskmgr-panel taskmgr-panel--hidden"
    id="panel-perf"
    role="tabpanel"
    aria-labelledby="tab-perf"
    tabindex="0"
  >
    <div class="taskmgr-perf-grid">
      {categories.map(cat => {
        const meta = catMeta[cat];
        const score = avg(cat);
        const catLabel = lang === 'fr' ? meta.labelFr : meta.labelEn;
        return (
          <div class="taskmgr-perf-card">
            <div class="taskmgr-perf-card__header">
              <span class="taskmgr-perf-card__icon" aria-hidden="true">{meta.icon}</span>
              <span class="taskmgr-perf-card__title">{catLabel}</span>
            </div>
            <div
              class="taskmgr-perf-ring"
              role="progressbar"
              aria-valuenow={score}
              aria-valuemin={0}
              aria-valuemax={100}
              aria-label={`${catLabel}: ${score}/100`}
              style={`--score: ${score}`}
            >
              <svg viewBox="0 0 36 36" class="taskmgr-perf-svg" aria-hidden="true">
                <circle
                  class="taskmgr-perf-svg__track"
                  cx="18" cy="18" r="15.915"
                  fill="none"
                  stroke-width="3"
                />
                <circle
                  class="taskmgr-perf-svg__fill"
                  cx="18" cy="18" r="15.915"
                  fill="none"
                  stroke-width="3"
                  stroke-dasharray={`${score}, 100`}
                  stroke-linecap="round"
                />
              </svg>
              <span class="taskmgr-perf-ring__label">{score}</span>
            </div>
            <p class="taskmgr-perf-card__score">{l.perfScore(score)}</p>
          </div>
        );
      })}
    </div>
  </div>

  <!-- Footer -->
  <div class="taskmgr-footer" aria-label={lang === 'fr' ? 'Informations système' : 'System info'}>
    <span class="taskmgr-footer__text">{l.footer}</span>
  </div>

</div>

<style>
/* ── Root ──────────────────────────────────────────────────────── */
.taskmgr-win {
  display: flex;
  flex-direction: column;
  background: #080613;
  border: 1px solid rgba(139, 92, 246, 0.25);
  border-radius: 0.5rem;
  overflow: hidden;
  font-size: 0.8125rem;
}

/* ── Tabs ──────────────────────────────────────────────────────── */
.taskmgr-tabs {
  display: flex;
  background: rgba(139, 92, 246, 0.06);
  border-bottom: 1px solid rgba(139, 92, 246, 0.2);
  flex-shrink: 0;
}

.taskmgr-tab {
  display: flex;
  align-items: center;
  gap: 0.375rem;
  padding: 0.5rem 1rem;
  background: transparent;
  border: none;
  border-bottom: 2px solid transparent;
  color: #94A3B8;
  font-size: 0.75rem;
  font-weight: 600;
  cursor: pointer;
  font-family: inherit;
  transition: color 0.15s ease, border-color 0.15s ease;
  letter-spacing: 0.01em;
}

.taskmgr-tab:hover {
  color: #C4B5FD;
}

.taskmgr-tab--active {
  color: #A78BFA;
  border-bottom-color: #8B5CF6;
}

.taskmgr-tab:focus-visible {
  outline: 2px solid #F59E0B;
  outline-offset: -2px;
}

/* ── Panels ────────────────────────────────────────────────────── */
.taskmgr-panel {
  flex: 1;
  overflow: auto;
}

.taskmgr-panel--hidden {
  display: none;
}

/* ── Table ─────────────────────────────────────────────────────── */
.taskmgr-table-wrap {
  overflow-x: auto;
}

.taskmgr-table {
  width: 100%;
  border-collapse: collapse;
}

.taskmgr-thead__row {
  background: rgba(139, 92, 246, 0.1);
  position: sticky;
  top: 0;
  z-index: 1;
}

.taskmgr-th {
  padding: 0.4rem 0.75rem;
  text-align: left;
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: #8B5CF6;
  border-bottom: 1px solid rgba(139, 92, 246, 0.2);
  white-space: nowrap;
}

.taskmgr-th--bar    { width: 35%; }
.taskmgr-th--level  { width: 18%; }
.taskmgr-th--status { width: 12%; text-align: center; }

/* Group headers */
.taskmgr-group-header {
  background: rgba(139, 92, 246, 0.08);
}

.taskmgr-group-header__cell {
  padding: 0.375rem 0.75rem;
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: #A78BFA;
  display: flex;
  align-items: center;
  gap: 0.4rem;
}

/* Rows */
.taskmgr-row {
  border-bottom: 1px solid rgba(139, 92, 246, 0.06);
  transition: background 0.1s ease;
}

.taskmgr-row:hover {
  background: rgba(139, 92, 246, 0.06);
}

.taskmgr-row--alt {
  background: rgba(255, 255, 255, 0.015);
}

.taskmgr-row--alt:hover {
  background: rgba(139, 92, 246, 0.06);
}

.taskmgr-td {
  padding: 0.35rem 0.75rem;
  vertical-align: middle;
}

.taskmgr-td--name {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  color: #FAF5FF;
  font-size: 0.8rem;
  white-space: nowrap;
}

.taskmgr-td__icon {
  font-size: 0.875rem;
}

/* Process state */
.taskmgr-td--bar {
  display: flex;
  align-items: center;
}

.taskmgr-state {
  font-family: 'Consolas', 'Courier New', monospace;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  white-space: nowrap;
}

.taskmgr-state--green  { color: #4ade80; }
.taskmgr-state--yellow { color: #F59E0B; }
.taskmgr-state--grey   { color: #475569; }

.taskmgr-td--level {
  font-size: 0.7rem;
  color: #C4B5FD;
  white-space: nowrap;
}

.taskmgr-td--status {
  text-align: center;
}

/* Status dots */
.taskmgr-dot {
  display: inline-block;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

.taskmgr-dot--green  { background: #4ade80; box-shadow: 0 0 4px #4ade80; }
.taskmgr-dot--yellow { background: #F59E0B; box-shadow: 0 0 4px rgba(245, 158, 11, 0.6); }
.taskmgr-dot--grey   { background: #475569; }

/* ── Perf panel ────────────────────────────────────────────────── */
.taskmgr-perf-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
  padding: 1rem;
}

@media (max-width: 400px) {
  .taskmgr-perf-grid {
    grid-template-columns: 1fr;
  }
}

.taskmgr-perf-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.75rem;
  padding: 1rem;
  background: rgba(139, 92, 246, 0.06);
  border: 1px solid rgba(139, 92, 246, 0.18);
  border-radius: 0.5rem;
}

.taskmgr-perf-card__header {
  display: flex;
  align-items: center;
  gap: 0.375rem;
}

.taskmgr-perf-card__icon {
  font-size: 1rem;
}

.taskmgr-perf-card__title {
  font-size: 0.8rem;
  font-weight: 700;
  color: #C4B5FD;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.taskmgr-perf-ring {
  position: relative;
  width: 80px;
  height: 80px;
}

.taskmgr-perf-svg {
  width: 100%;
  height: 100%;
  transform: rotate(-90deg);
}

.taskmgr-perf-svg__track {
  stroke: rgba(139, 92, 246, 0.12);
}

.taskmgr-perf-svg__fill {
  stroke: #8B5CF6;
  transition: stroke-dasharray 1s ease;
}

@media (prefers-reduced-motion: reduce) {
  .taskmgr-perf-svg__fill { transition: none; }
}

.taskmgr-perf-ring__label {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.25rem;
  font-weight: 800;
  color: #FAF5FF;
}

.taskmgr-perf-card__score {
  font-size: 0.7rem;
  color: #94A3B8;
  margin: 0;
}

/* ── Footer ────────────────────────────────────────────────────── */
.taskmgr-footer {
  padding: 0.3rem 0.75rem;
  background: rgba(139, 92, 246, 0.05);
  border-top: 1px solid rgba(139, 92, 246, 0.15);
  flex-shrink: 0;
}

.taskmgr-footer__text {
  font-size: 0.65rem;
  color: #475569;
  font-family: 'Consolas', 'Courier New', monospace;
}
</style>

<script>
(function () {
  const win = document.querySelector<HTMLElement>('.taskmgr-win');
  if (!win) return;

  const tabs   = win.querySelectorAll<HTMLButtonElement>('.taskmgr-tab');
  const panels = win.querySelectorAll<HTMLElement>('.taskmgr-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const targetId = tab.getAttribute('aria-controls');
      if (!targetId) return;

      tabs.forEach(t => {
        t.classList.remove('taskmgr-tab--active');
        t.setAttribute('aria-selected', 'false');
      });
      panels.forEach(p => p.classList.add('taskmgr-panel--hidden'));

      tab.classList.add('taskmgr-tab--active');
      tab.setAttribute('aria-selected', 'true');

      const targetPanel = win.querySelector<HTMLElement>(`#${targetId}`);
      targetPanel?.classList.remove('taskmgr-panel--hidden');
    });
  });
})();
</script>

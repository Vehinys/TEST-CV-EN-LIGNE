---
import { getCollection } from 'astro:content';
import type { Lang } from '../../i18n/utils';
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const allProjects = await getCollection('projects');
const projects = allProjects
  .map(p => ({ ...p.data, id: p.id }))
  .sort((a, b) => a.order - b.order);

const categories = ['design', 'development', 'wordpress', 'branding'] as const;
---

<div class="proj-win">
  <div class="proj-win__header">
    <span class="win-label">{t('projects.title')}</span>
    <h2 class="win-title">{t('projects.subtitle')}</h2>
  </div>

  <!-- Filters -->
  <div class="proj-win__filters" role="group" aria-label={lang === 'fr' ? 'Filtrer par catégorie' : 'Filter by category'}>
    <button class="proj-filter proj-filter--active" data-filter="all" aria-pressed="true" type="button">
      {t('projects.filter.all')}
    </button>
    {categories.map(cat => (
      <button class="proj-filter" data-filter={cat} aria-pressed="false" type="button">
        {t(`projects.filter.${cat}`)}
      </button>
    ))}
  </div>

  <!-- Grid -->
  <ul class="proj-win__grid" id="proj-win-grid" role="list">
    {projects.map(project => (
      <li class="proj-card" data-category={project.category} role="listitem">
        <div class="proj-card__image">
          <img
            src={project.image}
            alt={project.title}
            width="400"
            height="225"
            loading="lazy"
            decoding="async"
            class="proj-card__img"
          />
          {project.featured && (
            <span class="proj-card__badge">{t('projects.featured')}</span>
          )}
        </div>

        <div class="proj-card__body">
          <h3 class="proj-card__title">{project.title}</h3>
          <p class="proj-card__desc">
            {lang === 'en' ? project.descriptionEn : project.description}
          </p>

          <ul class="proj-card__tags" role="list" aria-label={lang === 'fr' ? 'Technologies' : 'Technologies'}>
            {project.tags.map(tag => (
              <li class="proj-tag">{tag}</li>
            ))}
          </ul>

          <div class="proj-card__actions">
            {project.url && (
              <a
                href={project.url}
                class="proj-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${t('projects.view.live')} — ${project.title}`}
              >
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                {t('projects.view.live')}
              </a>
            )}
            {project.github && (
              <a
                href={project.github}
                class="proj-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${t('projects.view.github')} — ${project.title}`}
              >
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
                </svg>
                {t('projects.view.github')}
              </a>
            )}
          </div>
        </div>
      </li>
    ))}
  </ul>
</div>

<style>
.proj-win {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.win-label {
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #F59E0B;
  display: block;
  margin-bottom: 0.25rem;
}

.win-title {
  font-size: clamp(1.25rem, 3vw, 1.75rem);
  font-weight: 700;
  color: #FAF5FF;
  margin: 0;
}

.proj-win__filters {
  display: flex;
  flex-wrap: wrap;
  gap: 0.375rem;
}

.proj-filter {
  padding: 0.375rem 0.875rem;
  border-radius: 999px;
  border: 1px solid rgba(139, 92, 246, 0.25);
  background: rgba(139, 92, 246, 0.06);
  color: #C4B5FD;
  font-size: 0.8125rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s ease;
  font-family: inherit;
}

.proj-filter:hover,
.proj-filter--active {
  background: rgba(139, 92, 246, 0.2);
  border-color: rgba(139, 92, 246, 0.5);
  color: #FAF5FF;
}

.proj-filter:focus-visible {
  outline: 2px solid #F59E0B;
  outline-offset: 2px;
}

.proj-win__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 1rem;
  list-style: none;
  padding: 0;
  margin: 0;
}

.proj-card {
  background: rgba(139, 92, 246, 0.06);
  border: 1px solid rgba(139, 92, 246, 0.18);
  border-radius: 0.75rem;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: border-color 0.2s ease, transform 0.2s ease;
}

.proj-card:hover {
  border-color: rgba(139, 92, 246, 0.4);
  transform: translateY(-2px);
}

.proj-card[data-hidden] {
  display: none;
}

.proj-card__image {
  position: relative;
  height: 140px;
  background: rgba(139, 92, 246, 0.08);
  overflow: hidden;
}

.proj-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.35s ease;
}

.proj-card:hover .proj-card__img {
  transform: scale(1.04);
}

.proj-card__badge {
  position: absolute;
  top: 0.5rem;
  left: 0.5rem;
  padding: 0.2rem 0.5rem;
  border-radius: 999px;
  font-size: 0.65rem;
  font-weight: 700;
  background: rgba(245, 158, 11, 0.2);
  border: 1px solid rgba(245, 158, 11, 0.4);
  color: #F59E0B;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.proj-card__body {
  padding: 0.875rem 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  flex: 1;
}

.proj-card__title {
  font-size: 0.9375rem;
  font-weight: 700;
  color: #FAF5FF;
  margin: 0;
  line-height: 1.3;
}

.proj-card__desc {
  font-size: 0.8125rem;
  color: #C4B5FD;
  line-height: 1.6;
  margin: 0;
  flex: 1;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.proj-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.25rem;
  list-style: none;
  padding: 0;
  margin: 0;
}

.proj-tag {
  padding: 0.15rem 0.5rem;
  border-radius: 999px;
  font-size: 0.65rem;
  font-weight: 600;
  background: rgba(139, 92, 246, 0.1);
  border: 1px solid rgba(139, 92, 246, 0.2);
  color: #A78BFA;
}

.proj-card__actions {
  display: flex;
  gap: 0.625rem;
  padding-top: 0.25rem;
}

.proj-link {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  font-size: 0.75rem;
  font-weight: 600;
  color: #A78BFA;
  text-decoration: none;
  transition: color 0.2s ease;
}

.proj-link:hover {
  color: #FAF5FF;
}

.proj-link:focus-visible {
  outline: 2px solid #F59E0B;
  outline-offset: 2px;
  border-radius: 2px;
}
</style>

<script>
(function () {
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('#window-projects .proj-filter');
  const cards = document.querySelectorAll<HTMLElement>('#window-projects .proj-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset['filter'] ?? 'all';

      filterBtns.forEach(b => {
        b.classList.remove('proj-filter--active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('proj-filter--active');
      btn.setAttribute('aria-pressed', 'true');

      cards.forEach(card => {
        const cat = card.dataset['category'];
        if (filter === 'all' || cat === filter) {
          card.removeAttribute('data-hidden');
        } else {
          card.setAttribute('data-hidden', 'true');
        }
      });
    });
  });
})();
</script>

---
import { getCollection } from 'astro:content';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const allProjects = await getCollection('projects');
const projects = allProjects
  .map(p => ({ ...p.data, id: p.id }))
  .sort((a, b) => a.order - b.order);

const totalCount = projects.length;

const labels = {
  fr: {
    addressBarBase: 'Albert.exe > Projets',
    categories: 'Catégories',
    all: 'Tous les projets',
    design: 'Design',
    development: 'Développement',
    wordpress: 'WordPress',
    gridView: 'Grille',
    listView: 'Liste',
    viewLive: 'Voir ↗',
    viewCode: 'Code </>',
    selected: '1 sélectionné',
    items: (n: number) => `${n} élément${n > 1 ? 's' : ''}`,
    filterLabel: 'Filtrer par catégorie',
    gridLabel: 'Vue en grille',
    listLabel: 'Vue en liste',
    previewTitle: 'Aperçu',
    previewCat: 'Catégorie',
    previewDesc: 'Description',
    previewTags: 'Technologies',
    previewClose: 'Fermer le panneau',
    previewNone: 'Cliquez sur un projet pour voir ses détails',
    previewLive: 'Voir le site ↗',
    previewCode: 'Voir le code </>',
  },
  en: {
    addressBarBase: 'Albert.exe > Projects',
    categories: 'Categories',
    all: 'All projects',
    design: 'Design',
    development: 'Development',
    wordpress: 'WordPress',
    gridView: 'Grid',
    listView: 'List',
    viewLive: 'View ↗',
    viewCode: 'Code </>',
    selected: '1 selected',
    items: (n: number) => `${n} item${n > 1 ? 's' : ''}`,
    filterLabel: 'Filter by category',
    gridLabel: 'Grid view',
    listLabel: 'List view',
    previewTitle: 'Preview',
    previewCat: 'Category',
    previewDesc: 'Description',
    previewTags: 'Technologies',
    previewClose: 'Close panel',
    previewNone: 'Click a project to see its details',
    previewLive: 'View site ↗',
    previewCode: 'View code </>',
  },
} as const;

const l = labels[lang];

const folders = [
  { key: 'all',         icon: '📁', label: l.all },
  { key: 'design',      icon: '🎨', label: l.design },
  { key: 'development', icon: '⚙️', label: l.development },
  { key: 'wordpress',   icon: '🔧', label: l.wordpress },
] as const;
---

<div class="xplr-win" role="region" aria-label={lang === 'fr' ? 'Explorateur de projets' : 'Project Explorer'}>

  <!-- Toolbar -->
  <div class="xplr-toolbar" role="toolbar" aria-label={lang === 'fr' ? 'Barre d\'outils' : 'Toolbar'}>
    <div class="xplr-addressbar" aria-label={lang === 'fr' ? 'Chemin de navigation' : 'Navigation path'}>
      <span class="xplr-addressbar__icon" aria-hidden="true">📂</span>
      <span class="xplr-addressbar__path" id="xplr-address-text">{l.addressBarBase} &gt; {l.all}</span>
    </div>
    <div class="xplr-viewtoggle" role="group" aria-label={lang === 'fr' ? 'Mode d\'affichage' : 'View mode'}>
      <button
        class="xplr-viewbtn xplr-viewbtn--active"
        id="xplr-btn-grid"
        type="button"
        title={l.gridLabel}
        aria-label={l.gridLabel}
        aria-pressed="true"
      >
        <span aria-hidden="true">⊞</span>
        <span class="xplr-viewbtn__label">{l.gridView}</span>
      </button>
      <button
        class="xplr-viewbtn"
        id="xplr-btn-list"
        type="button"
        title={l.listLabel}
        aria-label={l.listLabel}
        aria-pressed="false"
      >
        <span aria-hidden="true">☰</span>
        <span class="xplr-viewbtn__label">{l.listView}</span>
      </button>
    </div>
    <span class="xplr-itemcount" id="xplr-count" aria-live="polite" aria-atomic="true">
      {l.items(totalCount)}
    </span>
  </div>

  <!-- Main area -->
  <div class="xplr-main">

    <!-- Sidebar -->
    <nav class="xplr-sidebar" aria-label={l.categories}>
      <p class="xplr-sidebar__title" aria-hidden="true">
        <span>📂</span> {l.categories}
      </p>
      <ul class="xplr-sidebar__list" role="list">
        {folders.map((f, i) => (
          <li>
            <button
              class={`xplr-folder ${i === 0 ? 'xplr-folder--active' : ''}`}
              data-filter={f.key}
              data-label={f.label}
              type="button"
              aria-pressed={i === 0 ? 'true' : 'false'}
            >
              <span class="xplr-folder__icon" aria-hidden="true">{f.icon}</span>
              <span class="xplr-folder__name">{f.label}</span>
            </button>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Content area -->
    <div class="xplr-content" role="main" id="xplr-content">
      <ul class="xplr-grid" id="xplr-grid" role="list" aria-label={lang === 'fr' ? 'Projets' : 'Projects'}>
        {projects.map(project => (
          <li
            class="xplr-file"
            data-category={project.category}
            data-title={project.title}
            data-description={lang === 'en' ? project.descriptionEn : project.description}
            data-cat-label={labels[lang][project.category] ?? project.category}
            data-tags={project.tags.join('|')}
            data-url={project.url ?? ''}
            data-github={project.github ?? ''}
            data-image={project.image}
            role="listitem"
            tabindex="0"
          >
            <div class="xplr-file__thumb">
              <img
                src={project.image}
                alt={project.title}
                width="200"
                height="140"
                loading="lazy"
                decoding="async"
                class="xplr-file__img"
              />
              {project.featured && (
                <span class="xplr-file__star" aria-label={lang === 'fr' ? 'En vedette' : 'Featured'}>⭐</span>
              )}
              <!-- Hover overlay -->
              <div class="xplr-file__overlay" aria-hidden="true">
                <p class="xplr-file__desc">
                  {lang === 'en' ? project.descriptionEn : project.description}
                </p>
                <div class="xplr-file__actions">
                  {project.url && (
                    <a
                      href={project.url}
                      class="xplr-file__action"
                      target="_blank"
                      rel="noopener noreferrer"
                      tabindex="-1"
                    >
                      {labels[lang].viewLive}
                    </a>
                  )}
                  {project.github && (
                    <a
                      href={project.github}
                      class="xplr-file__action"
                      target="_blank"
                      rel="noopener noreferrer"
                      tabindex="-1"
                    >
                      {labels[lang].viewCode}
                    </a>
                  )}
                </div>
              </div>
            </div>
            <div class="xplr-file__meta">
              <span class="xplr-file__name">{project.title}</span>
              <span class="xplr-file__type">{labels[lang][project.category] ?? project.category}</span>
            </div>
            <!-- Accessible links outside overlay -->
            <div class="xplr-file__a11y-links">
              {project.url && (
                <a
                  href={project.url}
                  class="sr-only-focusable"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${lang === 'fr' ? 'Voir le site' : 'View site'} — ${project.title}`}
                >
                  {labels[lang].viewLive}
                </a>
              )}
              {project.github && (
                <a
                  href={project.github}
                  class="sr-only-focusable"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${lang === 'fr' ? 'Voir le code' : 'View code'} — ${project.title}`}
                >
                  {labels[lang].viewCode}
                </a>
              )}
            </div>
          </li>
        ))}
      </ul>
    </div>

    <!-- Preview panel -->
    <aside
      class="xplr-preview"
      id="xplr-preview"
      aria-label={l.previewTitle}
      data-hidden
    >
      <div class="xplr-preview__header">
        <span class="xplr-preview__label" aria-hidden="true">📄</span>
        <span class="xplr-preview__name" id="xplr-preview-name">—</span>
        <button
          class="xplr-preview__close"
          id="xplr-preview-close"
          type="button"
          aria-label={l.previewClose}
        >×</button>
      </div>
      <div class="xplr-preview__body" hidden>
        <div class="xplr-preview__img-wrap">
          <img class="xplr-preview__img" id="xplr-preview-img" src="" alt="" loading="lazy" />
        </div>
        <dl class="xplr-preview__props">
          <dt>{l.previewCat}</dt>
          <dd id="xplr-preview-cat">—</dd>
          <dt>{l.previewDesc}</dt>
          <dd id="xplr-preview-desc">—</dd>
          <dt>{l.previewTags}</dt>
          <dd id="xplr-preview-tags" class="xplr-preview__tags"></dd>
        </dl>
        <div class="xplr-preview__actions" id="xplr-preview-actions"></div>
      </div>
      <p class="xplr-preview__empty" id="xplr-preview-empty">{l.previewNone}</p>
    </aside>

  </div>

  <!-- Status bar -->
  <div class="xplr-statusbar" role="status" aria-live="polite" aria-atomic="true">
    <span id="xplr-status-left">{l.items(totalCount)}</span>
    <span class="xplr-statusbar__sep" aria-hidden="true">|</span>
    <span id="xplr-status-right">{l.selected}</span>
  </div>

</div>

<style>
/* ── Root ──────────────────────────────────────────────────────── */
.xplr-win {
  display: flex;
  flex-direction: column;
  background: #0A0812;
  border: 1px solid rgba(139, 92, 246, 0.25);
  border-radius: 0.5rem;
  overflow: hidden;
  font-size: 0.8125rem;
  height: 100%;
  min-height: 400px;
}

.sr-only-focusable {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0,0,0,0);
  white-space: nowrap;
  border: 0;
}

.sr-only-focusable:focus-visible {
  position: static;
  width: auto;
  height: auto;
  clip: auto;
  white-space: normal;
  margin: 0;
  padding: 0.25rem 0.5rem;
  background: #8B5CF6;
  color: #fff;
  font-size: 0.75rem;
  border-radius: 0.25rem;
  outline: 2px solid #F59E0B;
}

/* ── Toolbar ───────────────────────────────────────────────────── */
.xplr-toolbar {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  padding: 0.375rem 0.75rem;
  background: rgba(139, 92, 246, 0.08);
  border-bottom: 1px solid rgba(139, 92, 246, 0.2);
  flex-shrink: 0;
}

.xplr-addressbar {
  display: flex;
  align-items: center;
  gap: 0.375rem;
  flex: 1;
  background: rgba(0, 0, 0, 0.3);
  border: 1px solid rgba(139, 92, 246, 0.2);
  border-radius: 0.25rem;
  padding: 0.25rem 0.625rem;
  min-width: 0;
}

.xplr-addressbar__icon {
  font-size: 0.75rem;
  flex-shrink: 0;
}

.xplr-addressbar__path {
  font-size: 0.75rem;
  color: var(--color-text-subtle);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.xplr-viewtoggle {
  display: flex;
  gap: 2px;
  flex-shrink: 0;
}

.xplr-viewbtn {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  padding: 0.25rem 0.5rem;
  background: transparent;
  border: 1px solid rgba(139, 92, 246, 0.2);
  border-radius: 0.25rem;
  color: var(--color-text-dim);
  font-size: 0.7rem;
  cursor: pointer;
  font-family: inherit;
  transition: all 0.15s ease;
}

.xplr-viewbtn:hover,
.xplr-viewbtn--active {
  background: rgba(139, 92, 246, 0.2);
  border-color: rgba(139, 92, 246, 0.45);
  color: var(--color-text-subtle);
}

.xplr-viewbtn:focus-visible {
  outline: 2px solid #F59E0B;
  outline-offset: 2px;
}

.xplr-viewbtn__label {
  display: none;
}

@media (min-width: 400px) {
  .xplr-viewbtn__label { display: inline; }
}

.xplr-itemcount {
  font-size: 0.7rem;
  color: var(--color-text-dim);
  flex-shrink: 0;
  white-space: nowrap;
}

/* ── Main layout ───────────────────────────────────────────────── */
.xplr-main {
  display: grid;
  grid-template-columns: 160px 1fr;
  flex: 1;
  min-height: 0;
  overflow: hidden;
  transition: grid-template-columns 0.2s ease;
}

.xplr-main--preview {
  grid-template-columns: 160px 1fr 220px;
}

@media (max-width: 480px) {
  .xplr-main,
  .xplr-main--preview {
    grid-template-columns: 1fr;
    grid-template-rows: auto 1fr auto;
  }
}

@media (prefers-reduced-motion: reduce) {
  .xplr-main { transition: none; }
}

/* ── Sidebar ───────────────────────────────────────────────────── */
.xplr-sidebar {
  border-right: 1px solid rgba(139, 92, 246, 0.15);
  background: rgba(0, 0, 0, 0.2);
  padding: 0.5rem 0;
  overflow-y: auto;
}

.xplr-sidebar__title {
  display: flex;
  align-items: center;
  gap: 0.3rem;
  padding: 0.375rem 0.75rem;
  font-size: 0.6875rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: #8B5CF6;
  margin: 0 0 0.25rem;
}

.xplr-sidebar__list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.xplr-folder {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  width: 100%;
  padding: 0.375rem 0.75rem;
  background: transparent;
  border: none;
  border-left: 2px solid transparent;
  color: var(--color-text-dim);
  font-size: 0.75rem;
  cursor: pointer;
  font-family: inherit;
  text-align: left;
  transition: all 0.15s ease;
}

.xplr-folder:hover {
  background: rgba(139, 92, 246, 0.08);
  color: var(--color-text-subtle);
}

.xplr-folder--active {
  background: rgba(139, 92, 246, 0.12);
  border-left-color: #8B5CF6;
  color: #FAF5FF;
}

.xplr-folder:focus-visible {
  outline: 2px solid #F59E0B;
  outline-offset: -2px;
}

.xplr-folder__icon {
  font-size: 0.875rem;
  flex-shrink: 0;
}

.xplr-folder__name {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ── Content area ──────────────────────────────────────────────── */
.xplr-content {
  overflow-y: auto;
  padding: 0.75rem;
}

/* ── Grid view (default) ───────────────────────────────────────── */
.xplr-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
  gap: 0.75rem;
  list-style: none;
  padding: 0;
  margin: 0;
}

.xplr-file {
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
  cursor: default;
}

.xplr-file[data-hidden] {
  display: none;
}

.xplr-file__thumb {
  position: relative;
  aspect-ratio: 16 / 9;
  background: rgba(10, 8, 20, 0.6);
  border: 1px solid rgba(139, 92, 246, 0.18);
  border-radius: 0.375rem;
  overflow: hidden;
}

.xplr-file__img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  transition: transform 0.3s ease;
}

@media (prefers-reduced-motion: reduce) {
  .xplr-file__img { transition: none; }
}

.xplr-file:hover .xplr-file__img {
  transform: scale(1.05);
}

.xplr-file__star {
  position: absolute;
  top: 0.3rem;
  right: 0.3rem;
  font-size: 0.75rem;
}

.xplr-file__overlay {
  position: absolute;
  inset: 0;
  background: rgba(8, 6, 15, 0.88);
  backdrop-filter: blur(4px);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  gap: 0.5rem;
  padding: 0.625rem;
  opacity: 0;
  transition: opacity 0.2s ease;
}

@media (prefers-reduced-motion: reduce) {
  .xplr-file__overlay { transition: none; }
}

.xplr-file:hover .xplr-file__overlay {
  opacity: 1;
}

.xplr-file__desc {
  font-size: 0.6875rem;
  color: var(--color-text-subtle);
  line-height: 1.5;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.xplr-file__actions {
  display: flex;
  gap: 0.375rem;
  flex-wrap: wrap;
}

.xplr-file__action {
  display: inline-block;
  padding: 0.2rem 0.5rem;
  background: rgba(139, 92, 246, 0.25);
  border: 1px solid rgba(139, 92, 246, 0.5);
  border-radius: 0.25rem;
  color: var(--color-text-subtle);
  font-size: 0.65rem;
  font-weight: 600;
  text-decoration: none;
  transition: background 0.15s ease;
}

.xplr-file__action:hover {
  background: rgba(139, 92, 246, 0.45);
  color: #FAF5FF;
}

.xplr-file__meta {
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
  padding: 0 0.125rem;
}

.xplr-file__name {
  font-size: 0.7rem;
  color: #FAF5FF;
  font-weight: 500;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.xplr-file__type {
  font-size: 0.6rem;
  color: #8B5CF6;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

/* ── List view (toggled via JS) ────────────────────────────────── */
.xplr-grid--list {
  grid-template-columns: 1fr;
  gap: 0.25rem;
}

.xplr-grid--list .xplr-file {
  flex-direction: row;
  align-items: center;
  gap: 0.75rem;
  padding: 0.375rem 0.5rem;
  border-radius: 0.25rem;
  transition: background 0.15s ease;
}

.xplr-grid--list .xplr-file:hover {
  background: rgba(139, 92, 246, 0.08);
}

.xplr-grid--list .xplr-file__thumb {
  width: 2.5rem;
  height: 2.5rem;
  aspect-ratio: unset;
  flex-shrink: 0;
  border-radius: 0.25rem;
}

.xplr-grid--list .xplr-file__overlay {
  display: none;
}

.xplr-grid--list .xplr-file__meta {
  flex: 1;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0;
}

.xplr-grid--list .xplr-file__name {
  font-size: 0.8125rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 60%;
}

/* ── Selected state ────────────────────────────────────────────── */
.xplr-file--selected .xplr-file__thumb {
  border-color: #8B5CF6;
  box-shadow: 0 0 0 2px rgba(139, 92, 246, 0.35);
}

.xplr-file--selected .xplr-file__name {
  color: var(--color-text-subtle);
}

/* ── Preview panel ─────────────────────────────────────────────── */
.xplr-preview {
  border-left: 1px solid rgba(139, 92, 246, 0.2);
  background: rgba(0, 0, 0, 0.25);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  min-width: 0;
}

.xplr-preview[data-hidden] {
  display: none;
}

.xplr-preview__header {
  display: flex;
  align-items: center;
  gap: 0.375rem;
  padding: 0.5rem 0.625rem;
  background: rgba(139, 92, 246, 0.08);
  border-bottom: 1px solid rgba(139, 92, 246, 0.15);
  flex-shrink: 0;
  min-width: 0;
}

.xplr-preview__label {
  font-size: 0.875rem;
  flex-shrink: 0;
}

.xplr-preview__name {
  flex: 1;
  font-size: 0.7rem;
  font-weight: 600;
  color: #FAF5FF;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  min-width: 0;
}

.xplr-preview__close {
  background: transparent;
  border: none;
  color: var(--color-text-dim);
  font-size: 1rem;
  line-height: 1;
  cursor: pointer;
  padding: 0.1rem 0.3rem;
  border-radius: 0.2rem;
  flex-shrink: 0;
  transition: color 0.15s ease, background 0.15s ease;
}

.xplr-preview__close:hover {
  color: #FAF5FF;
  background: rgba(139, 92, 246, 0.2);
}

.xplr-preview__close:focus-visible {
  outline: 2px solid #F59E0B;
  outline-offset: 2px;
}

.xplr-preview__body {
  flex: 1;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.xplr-preview__empty {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 0.7rem;
  color: #475569;
  padding: 1rem;
  margin: 0;
  line-height: 1.6;
}

.xplr-preview__img-wrap {
  width: 100%;
  aspect-ratio: 16 / 9;
  background: rgba(10, 8, 20, 0.6);
  border-bottom: 1px solid rgba(139, 92, 246, 0.12);
  overflow: hidden;
  flex-shrink: 0;
}

.xplr-preview__img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.xplr-preview__props {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 0;
  margin: 0;
  padding: 0;
  font-size: 0.7rem;
}

.xplr-preview__props dt {
  padding: 0.45rem 0.625rem;
  color: #8B5CF6;
  font-weight: 700;
  font-size: 0.65rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  border-bottom: 1px solid rgba(139, 92, 246, 0.07);
  white-space: nowrap;
}

.xplr-preview__props dd {
  padding: 0.45rem 0.625rem;
  color: var(--color-text-subtle);
  line-height: 1.5;
  margin: 0;
  border-bottom: 1px solid rgba(139, 92, 246, 0.07);
  min-width: 0;
  word-break: break-word;
}

.xplr-preview__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.25rem;
  padding-top: 0.4rem !important;
  padding-bottom: 0.4rem !important;
}

.xplr-preview__tag {
  display: inline-block;
  padding: 0.1rem 0.35rem;
  background: rgba(139, 92, 246, 0.12);
  border: 1px solid rgba(139, 92, 246, 0.25);
  border-radius: 0.2rem;
  color: #A78BFA;
  font-size: 0.6rem;
  font-weight: 600;
  font-family: 'Consolas', 'Courier New', monospace;
}

.xplr-preview__actions {
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
  padding: 0.625rem;
  border-top: 1px solid rgba(139, 92, 246, 0.12);
  flex-shrink: 0;
}

.xplr-preview__action {
  display: block;
  padding: 0.35rem 0.5rem;
  background: rgba(139, 92, 246, 0.1);
  border: 1px solid rgba(139, 92, 246, 0.3);
  border-radius: 0.25rem;
  color: var(--color-text-subtle);
  font-size: 0.7rem;
  font-weight: 600;
  text-decoration: none;
  text-align: center;
  transition: background 0.15s ease, color 0.15s ease;
}

.xplr-preview__action:hover {
  background: rgba(139, 92, 246, 0.3);
  color: #FAF5FF;
}

.xplr-preview__action:focus-visible {
  outline: 2px solid #F59E0B;
  outline-offset: 2px;
}

/* ── Status bar ────────────────────────────────────────────────── */
.xplr-statusbar {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.25rem 0.875rem;
  background: rgba(139, 92, 246, 0.05);
  border-top: 1px solid rgba(139, 92, 246, 0.15);
  font-size: 0.6875rem;
  color: var(--color-text-dim);
  flex-shrink: 0;
}

.xplr-statusbar__sep {
  color: rgba(139, 92, 246, 0.3);
}
</style>

<script>
(function () {
  const win = document.querySelector<HTMLElement>('.xplr-win');
  if (!win) return;

  const folderBtns = win.querySelectorAll<HTMLButtonElement>('.xplr-folder');
  const cards      = win.querySelectorAll<HTMLElement>('.xplr-file');
  const gridEl     = win.querySelector<HTMLElement>('#xplr-grid');
  const btnGrid    = win.querySelector<HTMLButtonElement>('#xplr-btn-grid');
  const btnList    = win.querySelector<HTMLButtonElement>('#xplr-btn-list');
  const addrText   = win.querySelector<HTMLElement>('#xplr-address-text');
  const countEl    = win.querySelector<HTMLElement>('#xplr-count');
  const statusLeft = win.querySelector<HTMLElement>('#xplr-status-left');
  const isEn       = document.documentElement.lang === 'en' || win.closest('[lang="en"]') !== null;

  function updateCount(n: number): void {
    const txt = isEn
      ? `${n} item${n !== 1 ? 's' : ''}`
      : `${n} élément${n !== 1 ? 's' : ''}`;
    if (countEl) countEl.textContent = txt;
    if (statusLeft) statusLeft.textContent = txt;
  }

  folderBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset['filter'] ?? 'all';
      const label  = btn.dataset['label'] ?? '';

      folderBtns.forEach(b => {
        b.classList.remove('xplr-folder--active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('xplr-folder--active');
      btn.setAttribute('aria-pressed', 'true');

      const base = isEn ? 'Albert.exe > Projects' : 'Albert.exe > Projets';
      if (addrText) addrText.textContent = `${base} > ${label}`;

      let visible = 0;
      cards.forEach(card => {
        const cat = card.dataset['category'];
        if (filter === 'all' || cat === filter) {
          card.removeAttribute('data-hidden');
          visible++;
        } else {
          card.setAttribute('data-hidden', 'true');
        }
      });

      updateCount(visible);
    });
  });

  // View toggle
  function setView(mode: 'grid' | 'list'): void {
    if (!gridEl || !btnGrid || !btnList) return;
    if (mode === 'list') {
      gridEl.classList.add('xplr-grid--list');
      btnList.classList.add('xplr-viewbtn--active');
      btnGrid.classList.remove('xplr-viewbtn--active');
      btnList.setAttribute('aria-pressed', 'true');
      btnGrid.setAttribute('aria-pressed', 'false');
    } else {
      gridEl.classList.remove('xplr-grid--list');
      btnGrid.classList.add('xplr-viewbtn--active');
      btnList.classList.remove('xplr-viewbtn--active');
      btnGrid.setAttribute('aria-pressed', 'true');
      btnList.setAttribute('aria-pressed', 'false');
    }
  }

  btnGrid?.addEventListener('click', () => setView('grid'));
  btnList?.addEventListener('click', () => setView('list'));

  // ── Preview panel ──────────────────────────────────────────────
  const mainEl       = win.querySelector<HTMLElement>('.xplr-main');
  const previewPanel = win.querySelector<HTMLElement>('#xplr-preview');
  const previewClose = win.querySelector<HTMLButtonElement>('#xplr-preview-close');
  const previewName  = win.querySelector<HTMLElement>('#xplr-preview-name');
  const previewImg   = win.querySelector<HTMLImageElement>('#xplr-preview-img');
  const previewCat   = win.querySelector<HTMLElement>('#xplr-preview-cat');
  const previewDesc  = win.querySelector<HTMLElement>('#xplr-preview-desc');
  const previewTags  = win.querySelector<HTMLElement>('#xplr-preview-tags');
  const previewActs  = win.querySelector<HTMLElement>('#xplr-preview-actions');
  const previewEmpty = win.querySelector<HTMLElement>('#xplr-preview-empty');
  const statusRight  = win.querySelector<HTMLElement>('#xplr-status-right');

  function openPreview(card: HTMLElement): void {
    const title    = card.dataset['title'] ?? '';
    const desc     = card.dataset['description'] ?? '';
    const catLabel = card.dataset['catLabel'] ?? '';
    const tags     = (card.dataset['tags'] ?? '').split('|').filter(Boolean);
    const url      = card.dataset['url'] ?? '';
    const github   = card.dataset['github'] ?? '';
    const image    = card.dataset['image'] ?? '';

    // Highlight selected
    cards.forEach(c => c.classList.remove('xplr-file--selected'));
    card.classList.add('xplr-file--selected');

    // Populate
    if (previewName)  previewName.textContent = title;
    if (previewImg)   { previewImg.src = image; previewImg.alt = title; }
    if (previewCat)   previewCat.textContent = catLabel;
    if (previewDesc)  previewDesc.textContent = desc;

    if (previewTags) {
      previewTags.innerHTML = '';
      tags.forEach(tag => {
        const span = document.createElement('span');
        span.className = 'xplr-preview__tag';
        span.textContent = tag;
        previewTags.appendChild(span);
      });
    }

    if (previewActs) {
      previewActs.innerHTML = '';
      if (url) {
        const a = document.createElement('a');
        a.href = url;
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
        a.className = 'xplr-preview__action';
        a.textContent = isEn ? 'View site ↗' : 'Voir le site ↗';
        previewActs.appendChild(a);
      }
      if (github) {
        const a = document.createElement('a');
        a.href = github;
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
        a.className = 'xplr-preview__action';
        a.textContent = isEn ? 'View code </>' : 'Voir le code </>';
        previewActs.appendChild(a);
      }
    }

    // Show/hide body vs empty message
    const body = previewPanel?.querySelector<HTMLElement>('.xplr-preview__body');
    if (body)         body.hidden = false;
    if (previewEmpty) previewEmpty.hidden = true;

    // Show panel
    previewPanel?.removeAttribute('data-hidden');
    mainEl?.classList.add('xplr-main--preview');

    // Status bar
    if (statusRight) statusRight.textContent = title;
  }

  function closePreview(): void {
    cards.forEach(c => c.classList.remove('xplr-file--selected'));
    previewPanel?.setAttribute('data-hidden', '');
    mainEl?.classList.remove('xplr-main--preview');
    const base = isEn ? '1 selected' : '1 sélectionné';
    if (statusRight) statusRight.textContent = base;
  }

  cards.forEach(card => {
    card.addEventListener('click', () => openPreview(card));
    card.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        openPreview(card);
      }
    });
    card.style.cursor = 'pointer';
  });

  previewClose?.addEventListener('click', closePreview);
})();
</script>

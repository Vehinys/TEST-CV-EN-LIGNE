---
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const labels = {
  fr: {
    windowTitle: 'Propriétés système — Albert Lecomte',
    headerSection: 'Informations système',
    fullName: 'Nom complet',
    jobTitle: 'Titre',
    version: 'Version',
    specialization: 'Spécialisation',
    rqth: 'Certification RQTH',
    languages: 'Langues',
    hwSpecs: 'Spécifications matérielles',
    cpu: 'CPU : WordPress, UI & SEO',
    ram: 'RAM : Formations diplômantes',
    gpu: 'GPU : Stage Businet',
    perf: 'PERF : Expérience',
    downloadCv: 'Télécharger CV',
    contact: 'Contact',
    location: 'Mulhouse, Alsace',
    available: 'Disponible',
    versionValue: 'En recherche active (CDI)',
    langValue: 'Français (natif) · Anglais (compréhension écrite)',
    specCpu: 'OVERCLOCKED 🔥',
    specRam: '4 modules ✨',
    specGpu: 'Refonte + SEO 🔧',
    specPerf: 'NO LAG ⚡',
  },
  en: {
    windowTitle: 'System Properties — Albert Lecomte',
    headerSection: 'System Information',
    fullName: 'Full Name',
    jobTitle: 'Title',
    version: 'Version',
    specialization: 'Specialization',
    rqth: 'RQTH Certification',
    languages: 'Languages',
    hwSpecs: 'Hardware Specifications',
    cpu: 'CPU: WordPress, UI & SEO',
    ram: 'RAM: Degrees obtained',
    gpu: 'GPU: Businet Internship',
    perf: 'PERF: Experience',
    downloadCv: 'Download CV',
    contact: 'Contact',
    location: 'Mulhouse, Alsace',
    available: 'Available',
    versionValue: 'Actively seeking (CDI)',
    langValue: 'French (native) · English (reading comprehension)',
    specCpu: 'OVERCLOCKED 🔥',
    specRam: '4 modules ✨',
    specGpu: 'Redesign + SEO 🔧',
    specPerf: 'NO LAG ⚡',
  },
} as const;

const l = labels[lang];

const tableRows = [
  { key: l.fullName,       value: 'Albert Lecomte' },
  { key: l.jobTitle,       value: lang === 'fr' ? 'Concepteur Designer UI' : 'UI Designer Conceptor' },
  { key: l.version,        value: l.versionValue },
  { key: l.specialization, value: lang === 'fr' ? 'WordPress · UI/UX Design · SEO' : 'WordPress · UI/UX Design · SEO' },
  { key: l.rqth,           value: lang === 'fr' ? 'Reconnu' : 'Recognized' },
  { key: l.languages,      value: l.langValue },
];

interface SpecItem { label: string; value: string; id?: string; }

const ramModules = [
  {
    title: lang === 'fr' ? 'Concepteur Designer UI (Niv. 6)' : 'UI Designer Conceptor (L. 6)',
    school: 'GRETA Alsace Sud',
    period: '2025 — 2026',
    status: lang === 'fr' ? 'EN COURS' : 'IN PROGRESS',
    done: false,
  },
  {
    title: lang === 'fr' ? 'Développeur Web & Mobile (Niv. 5)' : 'Web & Mobile Developer (L. 5)',
    school: 'Elan Formation',
    period: '2024',
    status: 'ACQUIS ✓',
    done: true,
  },
  {
    title: lang === 'fr' ? 'Infographiste Metteur en Page (Niv. 4)' : 'Graphic Designer Page Setter (L. 4)',
    school: 'GRETA Sud Alsace',
    period: '2022 — 2023',
    status: 'ACQUIS ✓',
    done: true,
  },
  {
    title: lang === 'fr' ? 'Titre Pro. Vendeur Conseil (Niv. 4)' : 'Sales Advisor Certificate (L. 4)',
    school: 'CEFA Saint-Anne (Belgique)',
    period: '2006',
    status: 'ACQUIS ✓',
    done: true,
  },
];

const specs: SpecItem[] = [
  { label: l.cpu, value: l.specCpu             },
  { label: l.gpu, value: l.specGpu             },
  { label: l.ram, value: l.specRam, id: 'ram'  },
];
---

<div class="sysinfo-win" role="region" aria-label={l.windowTitle}>

  <!-- Title bar -->
  <div class="sysinfo-titlebar" aria-hidden="true">
    <span class="sysinfo-titlebar__icon">🖥️</span>
    <span class="sysinfo-titlebar__text">{l.windowTitle}</span>
  </div>

  <!-- Body -->
  <div class="sysinfo-body">

    <!-- Left column: identity -->
    <aside class="sysinfo-identity" aria-label={lang === 'fr' ? 'Identité' : 'Identity'}>
      <div class="sysinfo-avatar">
        <img src="/images/Albert.webp" alt="Albert Lecomte" class="sysinfo-avatar__photo" width="80" height="80" />
      </div>
      <p class="sysinfo-identity__name">Albert Lecomte</p>
      <p class="sysinfo-identity__title">
        {lang === 'fr' ? 'Concepteur Designer UI' : 'UI Designer Conceptor'}
      </p>
      <div class="sysinfo-badges">
        <span class="sysinfo-badge sysinfo-badge--location">
          <span aria-hidden="true">📍</span>
          {l.location}
        </span>
        <span class="sysinfo-badge sysinfo-badge--available">
          <span aria-hidden="true">🟢</span>
          {l.available}
        </span>
      </div>
    </aside>

    <!-- Right column: table + specs -->
    <div class="sysinfo-details">

      <!-- Properties table -->
      <section aria-label={l.headerSection}>
        <div class="sysinfo-section-header">
          <span class="sysinfo-section-icon" aria-hidden="true">ℹ️</span>
          <span class="sysinfo-section-title">{l.headerSection}</span>
        </div>
        <dl class="sysinfo-table">
          {tableRows.map((row, i) => (
            <div class={`sysinfo-table__row ${i % 2 === 0 ? 'sysinfo-table__row--even' : ''}`}>
              <dt class="sysinfo-table__key">{row.key}</dt>
              <dd class="sysinfo-table__value">{row.value}</dd>
            </div>
          ))}
        </dl>
      </section>

      <!-- Hardware specs -->
      <section class="sysinfo-hw" aria-label={l.hwSpecs}>
        <div class="sysinfo-section-header">
          <span class="sysinfo-section-icon" aria-hidden="true">⚡</span>
          <span class="sysinfo-section-title">{l.hwSpecs}</span>
        </div>
        <div class="sysinfo-specs">
          {specs.map(spec => (
            <div class="sysinfo-spec">
              <span class="sysinfo-spec__label">{spec.label}</span>
              {spec.id === 'ram' ? (
                <button
                  class="sysinfo-spec__value sysinfo-ram-btn"
                  type="button"
                  aria-expanded="false"
                  aria-haspopup="listbox"
                >
                  {spec.value}<span class="sysinfo-ram-arrow" aria-hidden="true"> ▾</span>
                </button>
              ) : (
                <span class="sysinfo-spec__value">{spec.value}</span>
              )}
            </div>
          ))}

          <!-- RAM modules popup -->
          <ul
            class="sysinfo-ram-popup"
            hidden
            role="listbox"
            aria-label={lang === 'fr' ? 'Formations diplômantes' : 'Degrees'}
          >
            {ramModules.map(m => (
              <li class="sysinfo-ram-item" role="option" aria-selected="false">
                <span class="sysinfo-ram-item__icon" aria-hidden="true">{m.done ? '✅' : '⏳'}</span>
                <div class="sysinfo-ram-item__info">
                  <p class="sysinfo-ram-item__title">{m.title}</p>
                  <p class="sysinfo-ram-item__meta">{m.school} · {m.period}</p>
                </div>
                <span class={`sysinfo-ram-item__badge ${m.done ? 'sysinfo-ram-item__badge--done' : 'sysinfo-ram-item__badge--wip'}`}>
                  {m.status}
                </span>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- Action buttons -->
      <div class="sysinfo-actions">
        <a
          href="/cv/albert-lecomte-cv.pdf"
          download
          class="sysinfo-btn sysinfo-btn--primary"
          aria-label={`${l.downloadCv} (PDF)`}
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" style="flex-shrink:0">
            <rect width="24" height="24" rx="3" fill="#E02020"/>
            <rect x="2" y="10" width="20" height="9" rx="1.5" fill="#B91C1C"/>
            <text x="12" y="17.5" text-anchor="middle" font-family="Arial,sans-serif" font-size="6.5" font-weight="900" fill="white" letter-spacing="0.3">PDF</text>
          </svg>
          {l.downloadCv}
        </a>
        <button
          type="button"
          class="sysinfo-btn"
          data-open-window="contact"
          aria-label={l.contact}
        >
          <span aria-hidden="true">📧</span>
          {l.contact}
        </button>
      </div>

    </div>
  </div>
</div>

<style>
/* ── Container ─────────────────────────────────────────────────── */
.sysinfo-win {
  display: flex;
  flex-direction: column;
  background: #0D0D1A;
  border: 1px solid rgba(139, 92, 246, 0.3);
  border-radius: 0.5rem;
  overflow: hidden;
  font-size: 0.8125rem;
}

/* ── Title bar ─────────────────────────────────────────────────── */
.sysinfo-titlebar {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 0.875rem;
  background: linear-gradient(90deg, rgba(139, 92, 246, 0.25) 0%, rgba(139, 92, 246, 0.08) 100%);
  border-bottom: 1px solid rgba(139, 92, 246, 0.35);
  user-select: none;
}

.sysinfo-titlebar__icon {
  font-size: 0.875rem;
}

.sysinfo-titlebar__text {
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--color-text-subtle);
  letter-spacing: 0.02em;
}

/* ── Body layout ───────────────────────────────────────────────── */
.sysinfo-body {
  display: grid;
  grid-template-columns: 35% 65%;
  min-height: 0;
}

@media (max-width: 520px) {
  .sysinfo-body {
    grid-template-columns: 1fr;
  }
}

/* ── Left: identity ────────────────────────────────────────────── */
.sysinfo-identity {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.625rem;
  padding: 1.5rem 1rem;
  border-right: 1px solid rgba(139, 92, 246, 0.2);
  text-align: center;
}

.sysinfo-avatar {
  width: 5rem;
  height: 5rem;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(139, 92, 246, 0.3) 0%, rgba(139, 92, 246, 0.05) 70%);
  border: 2px solid rgba(139, 92, 246, 0.5);
  box-shadow: 0 0 20px rgba(139, 92, 246, 0.3), 0 0 40px rgba(139, 92, 246, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.sysinfo-avatar__emoji {
  font-size: 2.5rem;
  line-height: 1;
}

.sysinfo-identity__name {
  font-size: 0.9375rem;
  font-weight: 700;
  color: #FAF5FF;
  margin: 0;
  margin-top: 0.25rem;
}

.sysinfo-identity__title {
  font-size: 0.75rem;
  color: #F59E0B;
  margin: 0;
  font-weight: 600;
}

.sysinfo-badges {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  width: 100%;
}

.sysinfo-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.3rem;
  padding: 0.3rem 0.5rem;
  border-radius: 0.375rem;
  font-size: 0.7rem;
  font-weight: 600;
}

.sysinfo-badge--location {
  background: rgba(139, 92, 246, 0.1);
  border: 1px solid rgba(139, 92, 246, 0.25);
  color: var(--color-text-subtle);
}

.sysinfo-badge--available {
  background: rgba(74, 222, 128, 0.08);
  border: 1px solid rgba(74, 222, 128, 0.25);
  color: #4ade80;
}

/* ── Right: details ────────────────────────────────────────────── */
.sysinfo-details {
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* ── Section header ────────────────────────────────────────────── */
.sysinfo-section-header {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.5rem 0.875rem;
  background: rgba(139, 92, 246, 0.08);
  border-bottom: 1px solid rgba(139, 92, 246, 0.15);
}

.sysinfo-section-icon {
  font-size: 0.75rem;
}

.sysinfo-section-title {
  font-size: 0.6875rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: #8B5CF6;
}

/* ── Properties table ──────────────────────────────────────────── */
.sysinfo-table {
  display: flex;
  flex-direction: column;
  margin: 0;
}

.sysinfo-table__row {
  display: grid;
  grid-template-columns: 40% 60%;
  padding: 0.4rem 0.875rem;
  border-bottom: 1px solid rgba(139, 92, 246, 0.08);
}

.sysinfo-table__row--even {
  background: rgba(139, 92, 246, 0.04);
}

.sysinfo-table__key {
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--color-text-dim);
  padding-right: 0.5rem;
}

.sysinfo-table__value {
  font-size: 0.75rem;
  color: #FAF5FF;
  margin: 0;
}

/* ── Hardware specs ────────────────────────────────────────────── */
.sysinfo-hw {
  border-top: 1px solid rgba(139, 92, 246, 0.15);
}

.sysinfo-specs {
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
  padding: 0.875rem;
}


.sysinfo-spec__label {
  font-size: 0.7rem;
  color: var(--color-text-dim);
  font-weight: 500;
}

.sysinfo-spec__value {
  font-size: 0.7rem;
  color: #F59E0B;
  font-weight: 700;
}

.sysinfo-spec {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* RAM expandable button */
.sysinfo-ram-btn {
  background: none;
  border: none;
  font-family: inherit;
  font-size: 0.7rem;
  font-weight: 700;
  color: #F59E0B;
  cursor: pointer;
  padding: 0;
  display: flex;
  align-items: center;
  transition: color 0.15s ease;
}

.sysinfo-ram-btn:hover { color: #FCD34D; }

.sysinfo-ram-btn:focus-visible {
  outline: 2px solid #F59E0B;
  outline-offset: 2px;
  border-radius: 2px;
}

.sysinfo-ram-arrow {
  display: inline-block;
  transition: transform 0.2s ease;
}

.sysinfo-ram-btn[aria-expanded="true"] .sysinfo-ram-arrow {
  transform: rotate(180deg);
}

/* RAM popup list */
.sysinfo-ram-popup {
  list-style: none;
  margin: 0.25rem 0 0;
  padding: 0.375rem;
  background: rgba(4, 2, 14, 0.97);
  border: 1px solid rgba(139, 92, 246, 0.35);
  border-radius: 0.375rem;
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
}

.sysinfo-ram-popup[hidden] { display: none; }

.sysinfo-ram-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.375rem 0.5rem;
  border-radius: 0.25rem;
  background: rgba(139, 92, 246, 0.05);
  border: 1px solid rgba(139, 92, 246, 0.12);
}

.sysinfo-ram-item__icon { font-size: 0.875rem; flex-shrink: 0; }

.sysinfo-ram-item__info { flex: 1; min-width: 0; }

.sysinfo-ram-item__title {
  margin: 0;
  font-size: 0.7rem;
  font-weight: 600;
  color: #FAF5FF;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.sysinfo-ram-item__meta {
  margin: 0.1rem 0 0;
  font-size: 0.6rem;
  color: var(--color-text-dim);
  font-family: 'Consolas', 'Courier New', monospace;
}

.sysinfo-ram-item__badge {
  flex-shrink: 0;
  font-size: 0.55rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  padding: 0.15rem 0.4rem;
  border-radius: 9999px;
  white-space: nowrap;
}

.sysinfo-ram-item__badge--done {
  background: rgba(74, 222, 128, 0.1);
  border: 1px solid rgba(74, 222, 128, 0.3);
  color: #4ade80;
}

.sysinfo-ram-item__badge--wip {
  background: rgba(245, 158, 11, 0.1);
  border: 1px solid rgba(245, 158, 11, 0.3);
  color: #F59E0B;
}

/* ── Action buttons ────────────────────────────────────────────── */
.sysinfo-actions {
  display: flex;
  gap: 0.625rem;
  padding: 0.875rem;
  border-top: 1px solid rgba(139, 92, 246, 0.15);
  background: rgba(139, 92, 246, 0.03);
}

.sysinfo-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  padding: 0.4rem 0.875rem;
  border: 1px solid rgba(139, 92, 246, 0.3);
  background: rgba(139, 92, 246, 0.08);
  color: var(--color-text-subtle);
  font-size: 0.75rem;
  font-weight: 600;
  border-radius: 0.25rem;
  cursor: pointer;
  text-decoration: none;
  font-family: inherit;
  transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  letter-spacing: 0.01em;
}

.sysinfo-btn:hover {
  background: rgba(139, 92, 246, 0.22);
  border-color: rgba(139, 92, 246, 0.6);
  color: #FAF5FF;
}

.sysinfo-btn--primary {
  background: rgba(245, 158, 11, 0.1);
  border-color: rgba(245, 158, 11, 0.35);
  color: #F59E0B;
}

.sysinfo-btn--primary:hover {
  background: rgba(245, 158, 11, 0.22);
  border-color: #F59E0B;
  color: #FCD34D;
}

.sysinfo-btn:focus-visible {
  outline: 2px solid #F59E0B;
  outline-offset: 2px;
}
</style>

<script>
(function () {
  // ── Contact button ───────────────────────────────────────────────────────
  const contactBtn = document.querySelector<HTMLButtonElement>('[data-open-window="contact"]');
  contactBtn?.addEventListener('click', async () => {
    const { open } = await import('../../utils/window-manager');
    open('contact');
  });

  // ── RAM modules popup ────────────────────────────────────────────────────
  const ramBtn  = document.querySelector<HTMLButtonElement>('.sysinfo-ram-btn');
  const ramList = document.querySelector<HTMLElement>('.sysinfo-ram-popup');
  if (!ramBtn || !ramList) return;

  ramBtn.addEventListener('click', () => {
    const isOpen = ramBtn.getAttribute('aria-expanded') === 'true';
    ramBtn.setAttribute('aria-expanded', String(!isOpen));
    ramList.hidden = isOpen;
  });

  // Close on Escape or outside click
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !ramList.hidden) {
      ramList.hidden = true;
      ramBtn.setAttribute('aria-expanded', 'false');
      ramBtn.focus();
    }
  });

  document.addEventListener('click', (e) => {
    if (!ramList.hidden && !ramBtn.contains(e.target as Node) && !ramList.contains(e.target as Node)) {
      ramList.hidden = true;
      ramBtn.setAttribute('aria-expanded', 'false');
    }
  });
})();
</script>

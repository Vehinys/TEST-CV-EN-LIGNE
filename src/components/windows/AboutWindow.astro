---
import type { Lang } from '../../i18n/utils';
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const stats = [
  { value: '5+',   key: 'about.years' },
  { value: '40+',  key: 'about.projects' },
  { value: '30+',  key: 'about.clients' },
  { value: '100%', key: 'about.satisfaction' },
] as const;
---

<div class="about-win">
  <div class="about-win__header">
    <span class="win-label">{t('about.title')}</span>
    <h2 class="win-title">{t('about.subtitle')}</h2>
  </div>

  <div class="about-win__grid">
    <div class="about-win__content">
      <p class="about-win__text">{t('about.p1')}</p>
      <p class="about-win__text">{t('about.p2')}</p>
      <p class="about-win__text">{t('about.p3')}</p>

      <a
        href="/cv/albert-lecomte-cv.pdf"
        class="about-win__cv-btn"
        download
        aria-label={`${t('about.cv.download')} (PDF)`}
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        {t('about.cv.download')}
      </a>
    </div>

    <div class="about-win__stats" aria-label={lang === 'fr' ? 'Statistiques' : 'Statistics'}>
      {stats.map(({ value, key }) => (
        <div class="stat-card">
          <span class="stat-card__value">{value}</span>
          <span class="stat-card__label">{t(key)}</span>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
.about-win {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.about-win__header {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.win-label {
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #F59E0B;
  display: block;
}

.win-title {
  font-size: clamp(1.25rem, 3vw, 1.75rem);
  font-weight: 700;
  color: #FAF5FF;
  margin: 0;
  line-height: 1.2;
}

.about-win__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
}

@media (min-width: 500px) {
  .about-win__grid {
    grid-template-columns: 3fr 2fr;
    align-items: start;
  }
}

.about-win__content {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.about-win__text {
  font-size: 0.9375rem;
  color: #C4B5FD;
  line-height: 1.8;
  margin: 0;
}

.about-win__cv-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: rgba(245, 158, 11, 0.15);
  border: 1px solid rgba(245, 158, 11, 0.35);
  color: #F59E0B;
  text-decoration: none;
  padding: 0.625rem 1.25rem;
  border-radius: 0.5rem;
  font-size: 0.875rem;
  font-weight: 600;
  transition: all 0.2s ease;
  align-self: flex-start;
  margin-top: 0.25rem;
}

.about-win__cv-btn:hover {
  background: rgba(245, 158, 11, 0.25);
  border-color: #F59E0B;
  color: #FCD34D;
}

.about-win__cv-btn:focus-visible {
  outline: 2px solid #F59E0B;
  outline-offset: 2px;
}

.about-win__stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem;
}

.stat-card {
  padding: 1.125rem 0.875rem;
  background: rgba(139, 92, 246, 0.08);
  border: 1px solid rgba(139, 92, 246, 0.2);
  border-radius: 0.75rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 0.25rem;
}

.stat-card__value {
  font-size: 1.75rem;
  font-weight: 800;
  background: linear-gradient(135deg, #A78BFA, #F59E0B);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: -0.03em;
  line-height: 1;
}

.stat-card__label {
  font-size: 0.75rem;
  color: #C4B5FD;
  font-weight: 500;
  line-height: 1.3;
}
</style>

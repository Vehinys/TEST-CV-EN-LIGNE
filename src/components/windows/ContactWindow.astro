---
import type { Lang } from '../../i18n/utils';
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const formId = 'contact-win-form';
---

<div class="con-win">
  <div class="con-win__header">
    <span class="win-label">{t('contact.title')}</span>
    <h2 class="win-title">{t('contact.subtitle')}</h2>
    <p class="con-win__intro">{t('contact.intro')}</p>
  </div>

  <div class="con-win__layout">
    <!-- Info cards -->
    <div class="con-win__info">
      <div class="con-info-item">
        <div class="con-info-item__icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#8B5CF6" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
        </div>
        <div>
          <p class="con-info-item__label">{lang === 'fr' ? 'Localisation' : 'Location'}</p>
          <p class="con-info-item__value">{t('contact.location')}</p>
        </div>
      </div>

      <div class="con-info-item">
        <div class="con-info-item__icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#8B5CF6" stroke-width="2">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
        </div>
        <div>
          <p class="con-info-item__label">Email</p>
          <a href="mailto:contact@albert-lecomte.fr" class="con-info-item__link">
            contact@albert-lecomte.fr
          </a>
        </div>
      </div>

      <div class="con-info-item">
        <div class="con-info-item__icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#8B5CF6" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <div>
          <p class="con-info-item__label">{lang === 'fr' ? 'Disponibilité' : 'Availability'}</p>
          <p class="con-info-item__value">{t('contact.availability')}</p>
          <p class="con-info-item__sub">{t('contact.response.time')}</p>
        </div>
      </div>
    </div>

    <!-- Form -->
    <form
      id={formId}
      class="con-form"
      novalidate
      aria-label={lang === 'fr' ? 'Formulaire de contact' : 'Contact form'}
    >
      <div id="con-status" role="status" aria-live="polite" class="sr-only"></div>

      <div class="form-group">
        <label for="con-name" class="form-label">
          {t('contact.name')}
          <span class="form-req" aria-hidden="true">*</span>
        </label>
        <input
          type="text"
          id="con-name"
          name="name"
          class="form-input"
          required
          aria-required="true"
          autocomplete="name"
          aria-describedby="con-name-error"
        />
        <p id="con-name-error" class="form-error" role="alert" aria-live="polite"></p>
      </div>

      <div class="form-group">
        <label for="con-email" class="form-label">
          {t('contact.email')}
          <span class="form-req" aria-hidden="true">*</span>
        </label>
        <input
          type="email"
          id="con-email"
          name="email"
          class="form-input"
          required
          aria-required="true"
          autocomplete="email"
          aria-describedby="con-email-error"
        />
        <p id="con-email-error" class="form-error" role="alert" aria-live="polite"></p>
      </div>

      <div class="form-group">
        <label for="con-subject" class="form-label">{t('contact.subject')}</label>
        <input
          type="text"
          id="con-subject"
          name="subject"
          class="form-input"
          placeholder={t('contact.subject.placeholder')}
          autocomplete="off"
        />
      </div>

      <div class="form-group">
        <label for="con-message" class="form-label">
          {t('contact.message')}
          <span class="form-req" aria-hidden="true">*</span>
        </label>
        <textarea
          id="con-message"
          name="message"
          class="form-input form-textarea"
          rows={4}
          required
          aria-required="true"
          placeholder={t('contact.message.placeholder')}
          aria-describedby="con-message-error"
        ></textarea>
        <p id="con-message-error" class="form-error" role="alert" aria-live="polite"></p>
      </div>

      <button type="submit" id="con-submit" class="con-submit-btn">
        <span id="con-btn-text">{t('contact.send')}</span>
        <span id="con-btn-loading" style="display:none" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="spin"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
          {t('contact.sending')}
        </span>
      </button>

      <div id="con-success" class="con-success" style="display:none" role="alert" aria-live="polite">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="2" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        {t('contact.success')}
      </div>
    </form>
  </div>
</div>

<style>
.con-win {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

.win-label {
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #F59E0B;
  display: block;
  margin-bottom: 0.25rem;
}

.win-title {
  font-size: clamp(1.25rem, 3vw, 1.75rem);
  font-weight: 700;
  color: #FAF5FF;
  margin: 0;
}

.con-win__intro {
  font-size: 0.875rem;
  color: #C4B5FD;
  margin: 0;
}

.con-win__layout {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.25rem;
}

@media (min-width: 520px) {
  .con-win__layout {
    grid-template-columns: 1fr 2fr;
    align-items: start;
  }
}

.con-win__info {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.con-info-item {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  padding: 0.875rem;
  background: rgba(139, 92, 246, 0.06);
  border: 1px solid rgba(139, 92, 246, 0.15);
  border-radius: 0.625rem;
}

.con-info-item__icon {
  width: 2rem;
  height: 2rem;
  background: rgba(139, 92, 246, 0.1);
  border-radius: 0.375rem;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.con-info-item__label {
  font-size: 0.6875rem;
  font-weight: 600;
  color: #A78BFA;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin: 0 0 0.15rem;
}

.con-info-item__value {
  font-size: 0.8125rem;
  color: #FAF5FF;
  font-weight: 500;
  margin: 0;
}

.con-info-item__sub {
  font-size: 0.75rem;
  color: #C4B5FD;
  margin: 0.1rem 0 0;
}

.con-info-item__link {
  font-size: 0.8125rem;
  color: #8B5CF6;
  text-decoration: none;
  font-weight: 500;
  transition: color 0.2s ease;
}

.con-info-item__link:hover {
  color: #A78BFA;
}

.con-info-item__link:focus-visible {
  outline: 2px solid #F59E0B;
  outline-offset: 2px;
  border-radius: 2px;
}

/* Form */
.con-form {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}

.form-label {
  font-size: 0.8125rem;
  font-weight: 600;
  color: #FAF5FF;
  display: flex;
  align-items: center;
  gap: 0.15rem;
}

.form-req {
  color: #ef4444;
}

.form-input {
  padding: 0.625rem 0.875rem;
  border-radius: 0.5rem;
  border: 1px solid rgba(139, 92, 246, 0.25);
  background: rgba(139, 92, 246, 0.06);
  color: #FAF5FF;
  font-size: 0.875rem;
  font-family: inherit;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
  width: 100%;
}

.form-input::placeholder {
  color: rgba(196, 181, 253, 0.4);
}

.form-input:focus {
  outline: none;
  border-color: #8B5CF6;
  box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.15);
}

.form-input:focus-visible {
  outline: 2px solid #F59E0B;
  outline-offset: 2px;
}

.form-input[aria-invalid="true"] {
  border-color: #ef4444;
  box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.12);
}

.form-textarea {
  resize: vertical;
  min-height: 100px;
}

.form-error {
  font-size: 0.75rem;
  color: #ef4444;
  margin: 0;
  min-height: 1.1em;
}

.con-submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.75rem 1.5rem;
  background: rgba(139, 92, 246, 0.2);
  border: 1px solid rgba(139, 92, 246, 0.4);
  color: #FAF5FF;
  font-size: 0.875rem;
  font-weight: 700;
  border-radius: 0.5rem;
  cursor: pointer;
  font-family: inherit;
  transition: all 0.2s ease;
  letter-spacing: 0.03em;
}

.con-submit-btn:hover:not(:disabled) {
  background: rgba(139, 92, 246, 0.35);
  border-color: #8B5CF6;
}

.con-submit-btn:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

.con-submit-btn:focus-visible {
  outline: 2px solid #F59E0B;
  outline-offset: 2px;
}

.con-success {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.625rem 0.875rem;
  border-radius: 0.5rem;
  background: rgba(74, 222, 128, 0.08);
  border: 1px solid rgba(74, 222, 128, 0.2);
  color: #4ade80;
  font-size: 0.8125rem;
  font-weight: 500;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.spin {
  animation: spin 0.8s linear infinite;
}
</style>

<script>
import { sendContactEmail } from '../../utils/emailjs';

(function () {
  const form = document.getElementById('contact-win-form') as HTMLFormElement | null;
  if (!form) return;

  const nameInput    = document.getElementById('con-name')    as HTMLInputElement | null;
  const emailInput   = document.getElementById('con-email')   as HTMLInputElement | null;
  const messageInput = document.getElementById('con-message') as HTMLTextAreaElement | null;
  const subjectInput = document.getElementById('con-subject') as HTMLInputElement | null;
  const submitBtn    = document.getElementById('con-submit')  as HTMLButtonElement | null;
  const btnText      = document.getElementById('con-btn-text');
  const btnLoading   = document.getElementById('con-btn-loading');
  const successMsg   = document.getElementById('con-success');
  const statusEl     = document.getElementById('con-status');

  function showError(inputId: string, message: string): void {
    const input = document.getElementById(inputId);
    const error = document.getElementById(`${inputId}-error`);
    if (input) input.setAttribute('aria-invalid', 'true');
    if (error) error.textContent = message;
  }

  function clearError(inputId: string): void {
    const input = document.getElementById(inputId);
    const error = document.getElementById(`${inputId}-error`);
    if (input) input.removeAttribute('aria-invalid');
    if (error) error.textContent = '';
  }

  function validateEmail(email: string): boolean {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const name    = nameInput?.value.trim() ?? '';
    const email   = emailInput?.value.trim() ?? '';
    const message = messageInput?.value.trim() ?? '';
    const subject = subjectInput?.value.trim() ?? '';

    let isValid = true;

    clearError('con-name');
    clearError('con-email');
    clearError('con-message');

    if (!name) {
      showError('con-name', 'Ce champ est obligatoire');
      isValid = false;
    }

    if (!email) {
      showError('con-email', 'Ce champ est obligatoire');
      isValid = false;
    } else if (!validateEmail(email)) {
      showError('con-email', 'Email invalide');
      isValid = false;
    }

    if (!message) {
      showError('con-message', 'Ce champ est obligatoire');
      isValid = false;
    }

    if (!isValid) return;

    if (submitBtn && btnText && btnLoading) {
      submitBtn.disabled = true;
      btnText.style.display = 'none';
      btnLoading.style.display = '';
    }

    try {
      await sendContactEmail({ name, email, subject, message });

      if (successMsg) successMsg.style.display = 'flex';
      if (statusEl) statusEl.textContent = 'Message envoyé avec succès';
      form.reset();
    } catch {
      if (statusEl) statusEl.textContent = "Erreur lors de l'envoi. Veuillez réessayer.";
      alert("Erreur lors de l'envoi. Veuillez réessayer ou me contacter directement.");
    } finally {
      if (submitBtn && btnText && btnLoading) {
        submitBtn.disabled = false;
        btnText.style.display = '';
        btnLoading.style.display = 'none';
      }
    }
  });
})();
</script>

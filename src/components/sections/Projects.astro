---
import { getCollection } from 'astro:content';
import type { Lang } from '../../i18n/utils';
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const allProjects = await getCollection('projects');
const projects = allProjects
  .map(p => ({ ...p.data, id: p.id }))
  .sort((a, b) => a.order - b.order);

const filters = ['all', 'design', 'development', 'wordpress'] as const;
type Filter = (typeof filters)[number];

const filterLabel: Record<Filter, string> = {
  all:         t('projects.filter.all'),
  design:      t('projects.filter.design'),
  development: t('projects.filter.development'),
  wordpress:   t('projects.filter.wordpress'),
};
---

<section id="projects" class="projects section-padding" aria-labelledby="projects-title">
  <div class="proj__container">

    <!-- Section header -->
    <div class="proj__header">
      <p class="proj__label"><span aria-hidden="true">// </span>{t('projects.title')}</p>
      <h2 id="projects-title" class="proj__title">{t('projects.subtitle')}</h2>
    </div>

    <!-- Terminal panel -->
    <div class="proj-panel" role="region" aria-label={lang === 'fr' ? 'Liste des projets' : 'Project list'}>

      <!-- Window bar -->
      <div class="proj-panel__bar" aria-hidden="true">
        <div class="proj-panel__dots">
          <span class="proj-panel__dot" style="background:#FF5F57"></span>
          <span class="proj-panel__dot" style="background:#FEBC2E"></span>
          <span class="proj-panel__dot" style="background:#28C840"></span>
        </div>
        <span class="proj-panel__barlabel">bash — ls projects/</span>
      </div>

      <!-- Panel body -->
      <div class="proj-panel__body">

        <!-- Prompt + filter row -->
        <div class="proj-controls">
          <p class="proj-prompt" aria-hidden="true">
            <span class="proj-prompt__caret">❯</span>
            <span class="proj-prompt__cmd">$ ls -la projects/</span>
          </p>
          <div
            class="proj-filters"
            role="group"
            aria-label={lang === 'fr' ? 'Filtrer par catégorie' : 'Filter by category'}
          >
            {filters.map(f => (
              <button
                class={`proj-filter${f === 'all' ? ' proj-filter--active' : ''}`}
                data-filter={f}
                aria-pressed={f === 'all' ? 'true' : 'false'}
                type="button"
              >
                {filterLabel[f]}
              </button>
            ))}
          </div>
        </div>

        <!-- Project grid -->
        <ul
          class="proj-grid"
          role="list"
          id="projects-grid"
          aria-label={lang === 'fr' ? 'Projets' : 'Projects'}
        >
          {projects.map(project => (
            <li class="proj-card" data-category={project.category} role="listitem">

              <!-- Image + overlay -->
              <div class="proj-card__img-wrap">
                <img
                  src={project.image}
                  alt={project.title}
                  width="800"
                  height="450"
                  loading="lazy"
                  decoding="async"
                  class="proj-card__img"
                />
                <div class="proj-card__overlay" aria-hidden="true">
                  <span class={`proj-card__cat proj-card__cat--${project.category}`}>
                    {project.category}
                  </span>
                  {project.featured && (
                    <span class="proj-card__feat">
                      {t('projects.featured')}
                    </span>
                  )}
                </div>
              </div>

              <!-- Body -->
              <div class="proj-card__body">
                <h3 class="proj-card__title">{project.title}</h3>
                <p class="proj-card__desc">
                  {lang === 'en' ? project.descriptionEn : project.description}
                </p>

                <ul
                  class="proj-card__tags"
                  role="list"
                  aria-label={lang === 'fr' ? 'Technologies utilisées' : 'Technologies used'}
                >
                  {project.tags.map(tag => <li class="proj-tag">{tag}</li>)}
                </ul>

                <div class="proj-card__links">
                  {project.github && (
                    <a
                      href={project.github}
                      class="proj-link"
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`${t('projects.view.github')} — ${project.title}`}
                    >
                      <span aria-hidden="true">↗</span>
                      {t('projects.view.github')}
                    </a>
                  )}
                  {project.url && (
                    <a
                      href={project.url}
                      class="proj-link proj-link--live"
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`${t('projects.view.live')} — ${project.title}`}
                    >
                      <span aria-hidden="true">↗</span>
                      {t('projects.view.live')}
                    </a>
                  )}
                </div>
              </div>

            </li>
          ))}
        </ul>

      </div><!-- /.proj-panel__body -->
    </div><!-- /.proj-panel -->

  </div>
</section>

<style>
/* ── Section ────────────────────────────────────────────────────── */
.projects {
  padding-top: var(--section-padding);
}

/* ── Container ─────────────────────────────────────────────────── */
.proj__container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 2.5rem;
}

/* ── Header ────────────────────────────────────────────────────── */
.proj__header {
  text-align: center;
}

.proj__label {
  font-size: 0.8125rem;
  font-weight: 700;
  color: var(--color-acid-green);
  text-transform: uppercase;
  letter-spacing: 0.12em;
  font-family: var(--font-family-mono);
  margin-bottom: 0.625rem;
}

.proj__title {
  font-size: clamp(1.5rem, 3vw, 2.25rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--color-text);
}

/* ── Terminal panel ────────────────────────────────────────────── */
.proj-panel {
  background: #0D0D1A;
  border: 1px solid rgba(139, 92, 246, 0.3);
  border-radius: 0.75rem;
  overflow: hidden;
}

/* ── Window bar ────────────────────────────────────────────────── */
.proj-panel__bar {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.625rem 1rem;
  background: rgba(139, 92, 246, 0.08);
  border-bottom: 1px solid rgba(139, 92, 246, 0.15);
}

.proj-panel__dots {
  display: flex;
  gap: 0.375rem;
}

.proj-panel__dot {
  width: 0.6875rem;
  height: 0.6875rem;
  border-radius: 50%;
  display: block;
}

.proj-panel__barlabel {
  font-size: 0.6875rem;
  color: #94A3B8;
  font-family: var(--font-family-mono);
  flex: 1;
  text-align: center;
}

/* ── Panel body ────────────────────────────────────────────────── */
.proj-panel__body {
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

/* ── Controls row ──────────────────────────────────────────────── */
.proj-controls {
  display: flex;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
}

.proj-prompt {
  font-family: var(--font-family-mono);
  font-size: 0.8125rem;
  margin: 0;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  white-space: nowrap;
}

.proj-prompt__caret {
  color: var(--color-acid-green);
}

.proj-prompt__cmd {
  color: #C4B5FD;
}

/* ── Filter buttons ────────────────────────────────────────────── */
.proj-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 0.375rem;
}

.proj-filter {
  padding: 0.3rem 0.75rem;
  border: 1px solid rgba(139, 92, 246, 0.25);
  background: rgba(139, 92, 246, 0.05);
  color: #64748B;
  font-size: 0.6875rem;
  font-weight: 700;
  font-family: var(--font-family-mono);
  border-radius: 0.25rem;
  cursor: pointer;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
}

.proj-filter:hover {
  background: rgba(204, 255, 0, 0.06);
  border-color: rgba(204, 255, 0, 0.3);
  color: var(--color-acid-green);
}

.proj-filter--active {
  background: rgba(204, 255, 0, 0.08);
  border-color: rgba(204, 255, 0, 0.4);
  color: var(--color-acid-green);
}

.proj-filter:focus-visible {
  outline: 2px solid var(--color-acid-green);
  outline-offset: 2px;
}

/* ── Grid ──────────────────────────────────────────────────────── */
.proj-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.25rem;
  list-style: none;
  padding: 0;
  margin: 0;
}

@media (min-width: 640px) {
  .proj-grid { grid-template-columns: 1fr 1fr; }
}

@media (min-width: 1024px) {
  .proj-grid { grid-template-columns: repeat(3, 1fr); }
}

/* ── Card ──────────────────────────────────────────────────────── */
.proj-card {
  display: flex;
  flex-direction: column;
  background: rgba(9, 9, 20, 0.9);
  border: 1px solid rgba(139, 92, 246, 0.2);
  border-radius: 0.5rem;
  overflow: hidden;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.proj-card:hover {
  border-color: rgba(139, 92, 246, 0.5);
  box-shadow: 0 0 24px rgba(139, 92, 246, 0.1);
}

.proj-card[data-hidden] {
  display: none;
}

/* ── Card image ────────────────────────────────────────────────── */
.proj-card__img-wrap {
  position: relative;
  height: 165px;
  overflow: hidden;
  border-bottom: 1px solid rgba(139, 92, 246, 0.15);
}

.proj-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}

.proj-card:hover .proj-card__img {
  transform: scale(1.04);
}

.proj-card__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(9, 9, 20, 0.85) 0%, transparent 55%);
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 0.5rem 0.625rem;
  pointer-events: none;
}

/* ── Category badge ────────────────────────────────────────────── */
.proj-card__cat {
  font-family: var(--font-family-mono);
  font-size: 0.5625rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  padding: 0.15rem 0.4rem;
  border-radius: 0.2rem;
}

.proj-card__cat--development {
  background: rgba(204, 255, 0, 0.1);
  border: 1px solid rgba(204, 255, 0, 0.3);
  color: var(--color-acid-green);
}

.proj-card__cat--design {
  background: rgba(139, 92, 246, 0.12);
  border: 1px solid rgba(139, 92, 246, 0.35);
  color: #A78BFA;
}

.proj-card__cat--wordpress {
  background: rgba(245, 158, 11, 0.1);
  border: 1px solid rgba(245, 158, 11, 0.3);
  color: #F59E0B;
}

/* ── Featured badge ────────────────────────────────────────────── */
.proj-card__feat {
  font-family: var(--font-family-mono);
  font-size: 0.5625rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding: 0.15rem 0.4rem;
  border-radius: 0.2rem;
  background: rgba(245, 158, 11, 0.12);
  border: 1px solid rgba(245, 158, 11, 0.35);
  color: #F59E0B;
}

/* ── Card body ─────────────────────────────────────────────────── */
.proj-card__body {
  padding: 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
  flex: 1;
}

.proj-card__title {
  font-size: 0.9375rem;
  font-weight: 700;
  color: #FAF5FF;
  margin: 0;
  font-family: var(--font-family-mono);
  line-height: 1.3;
}

.proj-card__desc {
  font-size: 0.8125rem;
  color: rgba(196, 181, 253, 0.7);
  line-height: 1.65;
  margin: 0;
  flex: 1;
}

/* ── Tags ──────────────────────────────────────────────────────── */
.proj-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.3rem;
  list-style: none;
  padding: 0;
  margin: 0;
}

.proj-tag {
  font-family: var(--font-family-mono);
  font-size: 0.5625rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  padding: 0.15rem 0.4rem;
  border-radius: 0.2rem;
  background: rgba(139, 92, 246, 0.07);
  border: 1px solid rgba(139, 92, 246, 0.22);
  color: #A78BFA;
}

/* ── Links ─────────────────────────────────────────────────────── */
.proj-card__links {
  display: flex;
  gap: 0.875rem;
  padding-top: 0.5rem;
  border-top: 1px solid rgba(139, 92, 246, 0.1);
  margin-top: auto;
}

.proj-link {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  font-family: var(--font-family-mono);
  font-size: 0.6875rem;
  font-weight: 700;
  color: #64748B;
  text-decoration: none;
  letter-spacing: 0.03em;
  transition: color 0.15s ease;
}

.proj-link:hover {
  color: var(--color-acid-green);
}

.proj-link--live:hover {
  color: #F59E0B;
}

.proj-link:focus-visible {
  outline: 2px solid var(--color-acid-green);
  outline-offset: 2px;
  border-radius: 2px;
}
</style>

<script>
(function () {
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.proj-filter');
  const cards = document.querySelectorAll<HTMLElement>('.proj-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset['filter'] ?? 'all';

      filterBtns.forEach(b => {
        b.classList.remove('proj-filter--active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('proj-filter--active');
      btn.setAttribute('aria-pressed', 'true');

      cards.forEach(card => {
        const cat = card.dataset['category'];
        if (filter === 'all' || cat === filter) {
          card.removeAttribute('data-hidden');
        } else {
          card.setAttribute('data-hidden', 'true');
        }
      });
    });
  });
})();
</script>

---
import { getCollection } from 'astro:content';
import type { Lang } from '../../i18n/utils';
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const allSkillEntries = await getCollection('skills');
// skills.json is a single entry with an array as data
const skills = (allSkillEntries[0]?.data ?? []).sort((a, b) => a.order - b.order);

const categories = ['design', 'frontend', 'backend', 'tools'] as const;
---

<section id="skills" class="skills section-padding" aria-labelledby="skills-title">
  <div class="skills__container">
    <div class="skills__header">
      <p class="section-label">{t('skills.title')}</p>
      <h2 id="skills-title" class="section-title">{t('skills.subtitle')}</h2>
    </div>

    <div class="skills__grid">
      {categories.map(cat => {
        const catSkills = skills.filter(s => s.category === cat);
        if (catSkills.length === 0) return null;
        return (
          <div class="skills__category glass-card">
            <h3 class="skills__cat-title">{t(`skills.${cat}`)}</h3>
            <ul class="skills__list" role="list">
              {catSkills.map(skill => (
                <li class="skill-item">
                  <div class="skill-item__header">
                    <span class="skill-item__name">{skill.name}</span>
                    <span class="skill-item__level sr-only">{t(`skills.level.${skill.level}`)}</span>
                    <span class="skill-item__dots" aria-hidden="true">
                      {Array.from({ length: 5 }, (_, i) => (
                        <span class={`skill-dot ${i < skill.level ? 'skill-dot--active' : ''}`}></span>
                      ))}
                    </span>
                  </div>
                  <div
                    class="skill-bar"
                    role="progressbar"
                    aria-valuenow={skill.level * 20}
                    aria-valuemin={0}
                    aria-valuemax={100}
                    aria-label={`${skill.name}: ${t(`skills.level.${skill.level}`)}`}
                  >
                    <div class="skill-bar__fill" style={`width: ${skill.level * 20}%`}></div>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
.skills__container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 3rem;
}

.skills__header {
  text-align: center;
}

.section-label {
  font-size: 0.875rem;
  font-weight: 600;
  color: #3b82f6;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 0.75rem;
}

.section-title {
  font-size: clamp(1.75rem, 4vw, 2.75rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--color-text);
}

.skills__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
}

@media (min-width: 640px) {
  .skills__grid { grid-template-columns: 1fr 1fr; }
}

@media (min-width: 1024px) {
  .skills__grid { grid-template-columns: repeat(4, 1fr); }
}

.skills__category {
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.skills__cat-title {
  font-size: 0.8rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #3b82f6;
  margin: 0;
}

.skills__list {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  list-style: none;
  padding: 0;
  margin: 0;
}

.skill-item {
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
}

.skill-item__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.skill-item__name {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-text);
}

.skill-item__dots {
  display: flex;
  gap: 3px;
}

.skill-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--glass-border);
  transition: background 0.3s ease;
}

.skill-dot--active {
  background: #3b82f6;
}

.skill-bar {
  height: 4px;
  border-radius: 999px;
  background: var(--glass-border);
  overflow: hidden;
}

.skill-bar__fill {
  height: 100%;
  border-radius: 999px;
  background: linear-gradient(90deg, #3b82f6, #0ea5e9);
  transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
}
</style>

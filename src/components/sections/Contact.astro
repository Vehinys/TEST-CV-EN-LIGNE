---
import type { Lang } from '../../i18n/utils';
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="contact" class="contact section-padding" aria-labelledby="contact-title">
  <div class="contact__container">
    <div class="contact__header">
      <p class="section-label">{t('contact.title')}</p>
      <h2 id="contact-title" class="section-title">{t('contact.subtitle')}</h2>
      <p class="contact__intro">{t('contact.intro')}</p>
    </div>

    <div class="contact__grid">
      <!-- Infos -->
      <div class="contact__info">
        <div class="contact__info-item glass-card">
          <div class="contact__info-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <p class="contact__info-label">{lang === 'fr' ? 'Localisation' : 'Location'}</p>
            <p class="contact__info-value">{t('contact.location')}</p>
          </div>
        </div>

        <div class="contact__info-item glass-card">
          <div class="contact__info-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </div>
          <div>
            <p class="contact__info-label">Email</p>
            <a href="mailto:contact@albert-lecomte.fr" class="contact__info-value contact__info-link">
              contact@albert-lecomte.fr
            </a>
          </div>
        </div>

        <div class="contact__info-item glass-card">
          <div class="contact__info-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div>
            <p class="contact__info-label">{lang === 'fr' ? 'Disponibilité' : 'Availability'}</p>
            <p class="contact__info-value">{t('contact.availability')}</p>
            <p class="contact__info-subvalue">{t('contact.response.time')}</p>
          </div>
        </div>
      </div>

      <!-- Formulaire -->
      <form id="contact-form" class="contact__form glass-card" novalidate aria-label={lang === 'fr' ? 'Formulaire de contact' : 'Contact form'}>
        <div id="contact-status" role="status" aria-live="polite" class="sr-only"></div>

        <div class="form-group">
          <label for="contact-name" class="form-label">
            {t('contact.name')}
            <span class="form-required" aria-hidden="true">*</span>
          </label>
          <input
            type="text"
            id="contact-name"
            name="name"
            class="form-input"
            required
            aria-required="true"
            autocomplete="name"
            aria-describedby="contact-name-error"
          />
          <p id="contact-name-error" class="form-error" role="alert" aria-live="polite"></p>
        </div>

        <div class="form-group">
          <label for="contact-email" class="form-label">
            {t('contact.email')}
            <span class="form-required" aria-hidden="true">*</span>
          </label>
          <input
            type="email"
            id="contact-email"
            name="email"
            class="form-input"
            required
            aria-required="true"
            autocomplete="email"
            aria-describedby="contact-email-error"
          />
          <p id="contact-email-error" class="form-error" role="alert" aria-live="polite"></p>
        </div>

        <div class="form-group">
          <label for="contact-subject" class="form-label">{t('contact.subject')}</label>
          <input
            type="text"
            id="contact-subject"
            name="subject"
            class="form-input"
            placeholder={t('contact.subject.placeholder')}
            autocomplete="off"
          />
        </div>

        <div class="form-group">
          <label for="contact-message" class="form-label">
            {t('contact.message')}
            <span class="form-required" aria-hidden="true">*</span>
          </label>
          <textarea
            id="contact-message"
            name="message"
            class="form-input form-textarea"
            rows={5}
            required
            aria-required="true"
            placeholder={t('contact.message.placeholder')}
            aria-describedby="contact-message-error"
          ></textarea>
          <p id="contact-message-error" class="form-error" role="alert" aria-live="polite"></p>
        </div>

        <button type="submit" id="contact-submit" class="btn btn--primary btn--full">
          <span id="btn-text">{t('contact.send')}</span>
          <span id="btn-loading" style="display:none" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="spin"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
            {t('contact.sending')}
          </span>
        </button>

        <div id="contact-success" class="contact__success" style="display:none" role="alert" aria-live="polite">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          {t('contact.success')}
        </div>
      </form>
    </div>
  </div>
</section>

<style>
.contact__container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 3rem;
}

.contact__header {
  text-align: center;
}

.section-label {
  font-size: 0.875rem;
  font-weight: 600;
  color: #3b82f6;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 0.75rem;
}

.section-title {
  font-size: clamp(1.75rem, 4vw, 2.75rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--color-text);
}

.contact__intro {
  margin-top: 1rem;
  font-size: 1rem;
  color: var(--color-text-subtle);
  max-width: 50ch;
  margin-inline: auto;
}

.contact__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2rem;
}

@media (min-width: 768px) {
  .contact__grid { grid-template-columns: 1fr 2fr; }
}

.contact__info {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.contact__info-item {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  padding: 1.25rem;
}

.contact__info-icon {
  width: 2.5rem;
  height: 2.5rem;
  border-radius: 0.625rem;
  background: rgba(59,130,246,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.contact__info-label {
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--color-text-subtle);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin: 0 0 0.2rem;
}

.contact__info-value {
  font-size: 0.9rem;
  color: var(--color-text);
  font-weight: 500;
  margin: 0;
}

.contact__info-subvalue {
  font-size: 0.8rem;
  color: var(--color-text-subtle);
  margin: 0.15rem 0 0;
}

.contact__info-link {
  text-decoration: none;
  color: #60a5fa;
  transition: color 0.2s ease;
}

.contact__info-link:hover { color: #93c5fd; }

.contact__info-link:focus-visible {
  outline: 3px solid var(--color-focus);
  outline-offset: 2px;
  border-radius: 2px;
}

/* Form */
.contact__form {
  padding: 2rem;
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
}

.form-label {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--color-text);
  display: flex;
  align-items: center;
  gap: 0.2rem;
}

.form-required {
  color: #ef4444;
}

.form-input {
  padding: 0.75rem 1rem;
  border-radius: 0.5rem;
  border: 1px solid var(--glass-border);
  background: var(--glass-bg);
  color: var(--color-text);
  font-size: 0.95rem;
  font-family: inherit;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
  width: 100%;
}

.form-input::placeholder {
  color: var(--color-text-muted);
}

.form-input:focus {
  outline: none;
  border-color: #3b82f6;
  box-shadow: 0 0 0 3px rgba(59,130,246,0.15);
}

.form-input:focus-visible {
  outline: 3px solid var(--color-focus);
  outline-offset: 2px;
}

.form-input[aria-invalid="true"] {
  border-color: #ef4444;
  box-shadow: 0 0 0 3px rgba(239,68,68,0.15);
}

.form-textarea {
  resize: vertical;
  min-height: 120px;
}

.form-error {
  font-size: 0.8rem;
  color: #ef4444;
  margin: 0;
  min-height: 1.2em;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.875rem 1.5rem;
  border-radius: 0.625rem;
  font-size: 0.95rem;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.25s ease;
  cursor: pointer;
  border: none;
}

.btn--primary {
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  color: white;
  box-shadow: 0 4px 16px rgba(59,130,246,0.35);
}

.btn--primary:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(59,130,246,0.5);
}

.btn--primary:disabled {
  opacity: 0.7;
  cursor: not-allowed;
}

.btn--full { width: 100%; }

.btn:focus-visible {
  outline: 3px solid var(--color-focus);
  outline-offset: 3px;
}

.contact__success {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.75rem 1rem;
  border-radius: 0.5rem;
  background: rgba(34,197,94,0.1);
  border: 1px solid rgba(34,197,94,0.25);
  color: #4ade80;
  font-size: 0.875rem;
  font-weight: 500;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.spin {
  animation: spin 0.8s linear infinite;
}
</style>

<script>
import { sendContactEmail } from '../../utils/emailjs';

(function () {
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  if (!form) return;

  const nameInput = document.getElementById('contact-name') as HTMLInputElement | null;
  const emailInput = document.getElementById('contact-email') as HTMLInputElement | null;
  const messageInput = document.getElementById('contact-message') as HTMLTextAreaElement | null;
  const subjectInput = document.getElementById('contact-subject') as HTMLInputElement | null;
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;
  const btnText = document.getElementById('btn-text');
  const btnLoading = document.getElementById('btn-loading');
  const successMsg = document.getElementById('contact-success');
  const statusEl = document.getElementById('contact-status');

  function showError(inputId: string, message: string) {
    const input = document.getElementById(inputId);
    const error = document.getElementById(`${inputId}-error`);
    if (input) input.setAttribute('aria-invalid', 'true');
    if (error) error.textContent = message;
  }

  function clearError(inputId: string) {
    const input = document.getElementById(inputId);
    const error = document.getElementById(`${inputId}-error`);
    if (input) input.removeAttribute('aria-invalid');
    if (error) error.textContent = '';
  }

  function validateEmail(email: string): boolean {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const name = nameInput?.value.trim() ?? '';
    const email = emailInput?.value.trim() ?? '';
    const message = messageInput?.value.trim() ?? '';
    const subject = subjectInput?.value.trim() ?? '';

    let isValid = true;

    clearError('contact-name');
    clearError('contact-email');
    clearError('contact-message');

    if (!name) {
      showError('contact-name', 'Ce champ est obligatoire');
      isValid = false;
    }

    if (!email) {
      showError('contact-email', 'Ce champ est obligatoire');
      isValid = false;
    } else if (!validateEmail(email)) {
      showError('contact-email', 'Email invalide');
      isValid = false;
    }

    if (!message) {
      showError('contact-message', 'Ce champ est obligatoire');
      isValid = false;
    }

    if (!isValid) return;

    if (submitBtn && btnText && btnLoading) {
      submitBtn.disabled = true;
      btnText.style.display = 'none';
      btnLoading.style.display = '';
    }

    try {
      await sendContactEmail({ name, email, subject, message });

      if (successMsg) successMsg.style.display = 'flex';
      if (statusEl) statusEl.textContent = 'Message envoyé avec succès';
      form.reset();
    } catch {
      if (statusEl) statusEl.textContent = 'Erreur lors de l\'envoi. Veuillez réessayer.';
      alert('Erreur lors de l\'envoi. Veuillez réessayer ou me contacter directement.');
    } finally {
      if (submitBtn && btnText && btnLoading) {
        submitBtn.disabled = false;
        btnText.style.display = '';
        btnLoading.style.display = 'none';
      }
    }
  });
})();
</script>

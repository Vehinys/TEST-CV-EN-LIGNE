---
import { getCollection } from 'astro:content';
import type { Lang } from '../../i18n/utils';
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const allVolunteer = await getCollection('volunteer');
const volunteerItems = allVolunteer
  .map(v => ({ ...v.data, id: v.id }))
  .sort((a, b) => a.order - b.order);
---

<section id="volunteer" class="volunteer section-padding" aria-labelledby="volunteer-title">
  <div class="volunteer__container">
    <div class="volunteer__header">
      <p class="section-label">{t('volunteer.title')}</p>
      <h2 id="volunteer-title" class="section-title">{t('volunteer.subtitle')}</h2>
    </div>

    <div class="volunteer__grid" role="list">
      {volunteerItems.map((item) => (
        <article class="volunteer-card glass-card" role="listitem">
          <div class="volunteer-card__icon" aria-hidden="true">
            {item.icon}
          </div>
          <div class="volunteer-card__content">
            <div class="volunteer-card__header">
              <h3 class="volunteer-card__title">{item.organization}</h3>
              <span class="volunteer-card__period">{item.period}</span>
            </div>
            <p class="volunteer-card__role">{lang === 'en' ? item.titleEn : item.title}</p>
            <p class="volunteer-card__desc">
              {lang === 'en' ? item.descriptionEn : item.description}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.volunteer__container {
  max-width: 900px;
  margin: 0 auto;
  padding: 0 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 2.5rem;
}

.volunteer__header {
  text-align: center;
}

.section-label {
  font-size: 0.875rem;
  font-weight: 600;
  color: #3b82f6;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 0.75rem;
}

.section-title {
  font-size: clamp(1.75rem, 4vw, 2.75rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--color-text);
}

.volunteer__grid {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.volunteer-card {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 1.5rem;
  padding: 1.5rem;
  align-items: start;
}

.volunteer-card__icon {
  font-size: 2rem;
  width: 3.5rem;
  height: 3.5rem;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--glass-bg);
  border: 1px solid var(--glass-border);
  border-radius: 12px;
}

.volunteer-card__content {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.volunteer-card__header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.volunteer-card__title {
  font-size: 1.15rem;
  font-weight: 700;
  color: var(--color-text);
  margin: 0;
}

.volunteer-card__period {
  font-size: 0.8rem;
  font-weight: 600;
  color: #3b82f6;
}

.volunteer-card__role {
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--color-text);
  margin: 0;
}

.volunteer-card__desc {
  font-size: 0.9rem;
  color: var(--color-text-subtle);
  line-height: 1.6;
  margin: 0;
}

@media (max-width: 640px) {
  .volunteer-card {
    grid-template-columns: 1fr;
    gap: 1rem;
  }
}
</style>

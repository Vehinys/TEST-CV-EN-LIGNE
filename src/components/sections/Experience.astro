---
import type { Lang } from '../../i18n/utils';
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

interface TimelineItem {
  period: string;
  title: Record<'fr' | 'en', string>;
  company: string;
  location: string;
  description: Record<'fr' | 'en', string>;
  tags: string[];
  current?: boolean;
}

const experiences: TimelineItem[] = [
  {
    period: '2022 — présent',
    title: { fr: 'Concepteur Designer UI — Freelance', en: 'UI Designer — Freelance' },
    company: 'Indépendant',
    location: 'Mulhouse, Alsace',
    description: {
      fr: 'Conception et développement de sites web pour des PME et artisans de la région Mulhousienne. Maquettes Figma, intégration WordPress sur mesure, SEO local et formation des clients.',
      en: 'Design and development of websites for SMEs and craftsmen in the Mulhouse area. Figma wireframes, custom WordPress integration, local SEO and client training.',
    },
    tags: ['Figma', 'WordPress', 'SEO', 'UI Design'],
    current: true,
  },
  {
    period: '2020 — 2022',
    title: { fr: 'Intégrateur Web', en: 'Web Integrator' },
    company: 'Agence Digit\'Al',
    location: 'Colmar, Alsace',
    description: {
      fr: 'Intégration de maquettes HTML/CSS/JS pour des clients e-commerce et institutionnels. Maintenance et évolution de sites WordPress existants. Collaboration avec l\'équipe design.',
      en: 'Integration of HTML/CSS/JS mockups for e-commerce and institutional clients. Maintenance and evolution of existing WordPress sites. Collaboration with the design team.',
    },
    tags: ['HTML', 'CSS', 'JavaScript', 'WordPress'],
  },
  {
    period: '2019 — 2020',
    title: { fr: 'Stage Développeur Web', en: 'Web Developer Intern' },
    company: 'Startup Alsace Numérique',
    location: 'Strasbourg, Alsace',
    description: {
      fr: 'Développement d\'interfaces utilisateur pour une application SaaS de gestion. Découverte des méthodes agiles et collaboration avec une équipe pluridisciplinaire.',
      en: 'Development of user interfaces for a SaaS management application. Introduction to agile methods and collaboration with a multidisciplinary team.',
    },
    tags: ['React', 'CSS', 'Agile', 'UX'],
  },
];

const education: TimelineItem[] = [
  {
    period: '2017 — 2019',
    title: { fr: 'BTS Services Informatiques aux Organisations — SIO', en: 'IT Services BTS — SIO' },
    company: 'Lycée Technique',
    location: 'Mulhouse',
    description: {
      fr: 'Spécialité Solutions Logicielles et Applications Métiers (SLAM). Développement web, bases de données, gestion de projet.',
      en: 'Software and Business Applications specialty. Web development, databases, project management.',
    },
    tags: ['Web', 'SQL', 'PHP', 'Projet'],
  },
  {
    period: '2015 — 2017',
    title: { fr: 'Baccalauréat STI2D', en: 'STI2D Baccalaureate' },
    company: 'Lycée Théodore Deck',
    location: 'Guebwiller',
    description: {
      fr: 'Spécialité Innovation Technologique et Eco-conception. Bases en électronique et design industriel.',
      en: 'Technology Innovation and Eco-design specialty. Basics in electronics and industrial design.',
    },
    tags: ['Design', 'Technologie', 'Innovation'],
  },
];
---

<section id="experience" class="experience section-padding" aria-labelledby="experience-title">
  <div class="experience__container">
    <div class="experience__header">
      <p class="section-label">{t('experience.title')}</p>
      <h2 id="experience-title" class="section-title">{t('experience.subtitle')}</h2>
    </div>

    <div class="timeline" role="list" aria-label={lang === 'fr' ? 'Expériences professionnelles' : 'Work experience'}>
      {experiences.map((item, i) => (
        <article class="timeline__item" role="listitem">
          <div class="timeline__marker" aria-hidden="true">
            <div class={`timeline__dot ${item.current ? 'timeline__dot--current' : ''}`}></div>
            {i < experiences.length - 1 && <div class="timeline__line"></div>}
          </div>

          <div class="timeline__content glass-card">
            <div class="timeline__meta">
              <time class="timeline__period">{item.period}</time>
              {item.current && (
                <span class="timeline__current-badge" aria-label={lang === 'fr' ? 'Poste actuel' : 'Current position'}>
                  {lang === 'fr' ? 'Actuel' : 'Current'}
                </span>
              )}
            </div>

            <h3 class="timeline__title">{item.title[lang]}</h3>
            <p class="timeline__company">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              {item.company} — {item.location}
            </p>

            <p class="timeline__desc">{item.description[lang]}</p>

            <ul class="timeline__tags" role="list" aria-label={lang === 'fr' ? 'Technologies' : 'Technologies'}>
              {item.tags.map(tag => <li class="tag">{tag}</li>)}
            </ul>
          </div>
        </article>
      ))}
    </div>

    <!-- Formation -->
    <div class="experience__header" style="margin-top:4rem">
      <p class="section-label">{t('education.title')}</p>
      <h2 id="education-title" class="section-title">{t('education.subtitle')}</h2>
    </div>

    <div class="timeline" role="list" aria-label={lang === 'fr' ? 'Formation académique' : 'Academic background'} aria-labelledby="education-title">
      {education.map((item, i) => (
        <article class="timeline__item" role="listitem">
          <div class="timeline__marker" aria-hidden="true">
            <div class="timeline__dot timeline__dot--edu"></div>
            {i < education.length - 1 && <div class="timeline__line"></div>}
          </div>

          <div class="timeline__content glass-card">
            <time class="timeline__period">{item.period}</time>
            <h3 class="timeline__title">{item.title[lang]}</h3>
            <p class="timeline__company">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
              {item.company} — {item.location}
            </p>
            <p class="timeline__desc">{item.description[lang]}</p>
            <ul class="timeline__tags" role="list">
              {item.tags.map(tag => <li class="tag">{tag}</li>)}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.experience__container {
  max-width: 900px;
  margin: 0 auto;
  padding: 0 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 2.5rem;
}

.experience__header {
  text-align: center;
}

.section-label {
  font-size: 0.875rem;
  font-weight: 600;
  color: #3b82f6;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 0.75rem;
}

.section-title {
  font-size: clamp(1.75rem, 4vw, 2.75rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--color-text);
}

.timeline {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.timeline__item {
  display: grid;
  grid-template-columns: 2rem 1fr;
  gap: 1.25rem;
  padding-bottom: 1.5rem;
}

.timeline__marker {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 1.5rem;
}

.timeline__dot {
  width: 0.875rem;
  height: 0.875rem;
  border-radius: 50%;
  border: 2px solid #3b82f6;
  background: var(--color-bg);
  flex-shrink: 0;
  z-index: 1;
}

.timeline__dot--current {
  background: #3b82f6;
  box-shadow: 0 0 12px rgba(59,130,246,0.5);
}

.timeline__dot--edu {
  border-color: #0ea5e9;
}

.timeline__line {
  width: 2px;
  flex: 1;
  background: var(--glass-border);
  margin-top: 4px;
}

.timeline__content {
  padding: 1.25rem 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
}

.timeline__meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.timeline__period {
  font-size: 0.8rem;
  font-weight: 600;
  color: #3b82f6;
  letter-spacing: 0.02em;
}

.timeline__current-badge {
  padding: 0.15rem 0.5rem;
  border-radius: 999px;
  font-size: 0.7rem;
  font-weight: 700;
  background: rgba(34,197,94,0.15);
  border: 1px solid rgba(34,197,94,0.3);
  color: #4ade80;
  text-transform: uppercase;
}

.timeline__title {
  font-size: 1rem;
  font-weight: 700;
  color: var(--color-text);
  margin: 0;
}

.timeline__company {
  display: flex;
  align-items: center;
  gap: 0.375rem;
  font-size: 0.85rem;
  color: var(--color-text-subtle);
  margin: 0;
}

.timeline__desc {
  font-size: 0.875rem;
  color: var(--color-text-subtle);
  line-height: 1.7;
  margin: 0;
}

.timeline__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.375rem;
  list-style: none;
  padding: 0;
  margin: 0;
  margin-top: 0.25rem;
}

.tag {
  padding: 0.2rem 0.625rem;
  border-radius: 999px;
  font-size: 0.7rem;
  font-weight: 600;
  background: var(--glass-bg);
  border: 1px solid var(--glass-border);
  color: var(--color-text-subtle);
}
</style>

---
import type { Lang } from '../../i18n/utils';
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="hero" class="hero section-padding" aria-label={lang === 'fr' ? 'Présentation' : 'Introduction'}>
  <!-- Fluid Background Assets -->
  <div class="background-container" aria-hidden="true">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>

  <div class="hero__container">
    <div class="hero__content">
      <div class="hero__badges animate-fade-up" style="animation-delay:0.1s">
        <span class="hero__available">
          <span class="hero__available-dot" aria-hidden="true"></span>
          {t('hero.available')}
        </span>
        <span class="hero__rqth">
          <span class="hero__rqth-icon" aria-hidden="true">♿</span>
          {t('hero.rqth')}
        </span>
      </div>

      <p class="hero__label animate-fade-up" style="animation-delay:0.15s">{t('hero.greeting')}</p>
      
      <h1 class="hero__name animate-fade-up" style="animation-delay:0.2s">
        <span class="gradient-text-animated">{t('hero.name')}</span>
      </h1>

      <p class="hero__title animate-fade-up" style="animation-delay:0.3s">{t('hero.title')}</p>

      <p class="hero__subtitle animate-fade-up" style="animation-delay:0.4s">{t('hero.subtitle')}</p>

      <div class="hero__cta animate-fade-up" style="animation-delay:0.5s">
        <a href="#projects" class="btn btn--primary">
          {t('hero.cta.projects')}
        </a>
        <a href="#contact" class="btn btn--ghost">
          {t('hero.cta.contact')}
        </a>
      </div>
    </div>

    <!-- Avatar / visuel droit -->
    <div class="hero__visual animate-fade-up" style="animation-delay:0.35s" aria-hidden="true">
      <div class="hero__avatar-wrap">
        <div class="hero__avatar-bg"></div>
        <img 
          src="/images/Albert.webp"
          alt="Albert Lecomte" 
          class="hero__avatar-img"
          loading="eager"
        />
        
        <!-- Floating Badge -->
        <div class="hero__experience-badge glass shadow-glow">
          <span class="text-2xl">🚀</span>
          <div class="flex flex-col">
            <span class="text-[10px] text-gray-400 uppercase font-bold tracking-tight">Expérience</span>
            <span class="text-xs font-black text-white whitespace-nowrap">Junior Passionné</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <a href="#about" class="hero__scroll" aria-label={t('hero.scroll')}>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M12 5v14M5 12l7 7 7-7"/>
    </svg>
  </a>
</section>

<!-- BANDEROLE (Infinite Marquee) -->
<div class="marquee-section" aria-hidden="true">
  <div class="marquee-content animate-marquee">
    {['WORDPRESS', 'FIGMA', 'ADOBE XD', 'SYMFONY', 'PHP', 'TAILWIND', 'SEO', 'UX DESIGN'].map((skill) => (
      <span class="marquee-item">{skill}</span>
    ))}
    {['WORDPRESS', 'FIGMA', 'ADOBE XD', 'SYMFONY', 'PHP', 'TAILWIND', 'SEO', 'UX DESIGN'].map((skill) => (
      <span class="marquee-item">{skill}</span>
    ))}
  </div>
</div>

<style>
.hero {
  position: relative;
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
  padding-top: 5rem;
}

.background-container {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
  z-index: 0;
}

.blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.15;
  animation: var(--animate-float) 20s infinite alternate;
}

.blob-1 {
  width: 400px;
  height: 400px;
  background: var(--color-acid-green);
  top: -10%;
  left: -5%;
}

.blob-2 {
  width: 350px;
  height: 350px;
  background: var(--color-neon-pink);
  bottom: 0%;
  right: -5%;
  animation-delay: -5s;
}

.blob-3 {
  width: 300px;
  height: 300px;
  background: var(--color-electric-cyan);
  top: 40%;
  right: 15%;
  animation-delay: -10s;
}

.hero__container {
  position: relative;
  z-index: 1;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1.5rem;
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
  align-items: center;
}

@media (min-width: 768px) {
  .hero__container {
    grid-template-columns: 1.2fr 0.8fr;
  }
}

.hero__content {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.hero__badges {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
}

.hero__available, .hero__rqth {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.4rem 0.9rem;
  border-radius: 999px;
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.hero__available {
  background: rgba(204, 255, 0, 0.1);
  border: 1px solid rgba(204, 255, 0, 0.2);
  color: var(--color-acid-green);
}

.hero__available-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--color-acid-green);
  animation: var(--animate-glow);
}

.hero__rqth {
  background: rgba(255, 0, 255, 0.1);
  border: 1px solid rgba(255, 0, 255, 0.2);
  color: var(--color-neon-pink);
}

.hero__label {
  font-size: 1.25rem;
  color: white;
  font-weight: 500;
  margin: 0;
}

.hero__name {
  font-size: clamp(2.8rem, 8vw, 5.5rem);
  font-weight: 900;
  line-height: 0.95;
  letter-spacing: -0.04em;
  margin: 0;
}

.hero__title {
  font-size: clamp(1.2rem, 2.5vw, 1.8rem);
  font-weight: 700;
  color: white;
  margin: 0;
}

.hero__subtitle {
  font-size: clamp(1rem, 1.8vw, 1.2rem);
  color: var(--color-text-subtle);
  line-height: 1.6;
  max-width: 50ch;
  margin: 0;
}

.hero__cta {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  margin-top: 1rem;
}

.btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.9rem 2rem;
  border-radius: 999px;
  font-size: 1rem;
  font-weight: 800;
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  transition: all 0.3s ease;
  cursor: pointer;
}

.btn--primary {
  background: white;
  color: black;
}

.btn--primary:hover {
  background: var(--color-acid-green);
  transform: translateY(-3px) scale(1.02);
  box-shadow: 0 10px 30px rgba(204, 255, 0, 0.3);
}

.btn--ghost {
  background: rgba(255, 255, 255, 0.05);
  color: white;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.btn--ghost:hover {
  background: white;
  color: black;
  transform: translateY(-3px);
}

/* Hero visual */
.hero__visual {
  display: flex;
  justify-content: center;
}

.hero__avatar-wrap {
  position: relative;
  width: clamp(260px, 30vw, 380px);
  height: clamp(260px, 30vw, 380px);
}

.hero__avatar-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--color-acid-green), var(--color-neon-pink));
  border-radius: 50%;
  filter: blur(40px);
  opacity: 0.3;
  animation: var(--animate-glow) 4s infinite alternate;
}

.hero__avatar-img {
  position: relative;
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 50%;
  border: 4px solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
  transition: transform 0.5s ease;
}

.hero__avatar-wrap:hover .hero__avatar-img {
  transform: scale(1.05) rotate(2deg);
}

.hero__experience-badge {
  position: absolute;
  bottom: 0%;
  right: 5%;
  padding: 0.75rem 1.25rem;
  border-radius: 1.25rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  animation: var(--animate-float) 4s infinite alternate;
}

.shadow-glow {
  box-shadow: 0 0 20px rgba(0, 0, 0, 0.5);
}

/* Marquee */
.marquee-section {
  padding: 2.5rem 0;
  background: rgba(0, 0, 0, 0.4);
  border-top: 1px solid rgba(255, 255, 255, 0.05);
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  overflow: hidden;
  margin-top: 2rem;
}

.marquee-content {
  display: flex;
  gap: 4rem;
  white-space: nowrap;
}

.marquee-item {
  font-size: 1.5rem;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.8);
  letter-spacing: 0.2em;
  transition: color 0.3s ease;
}

.marquee-item:hover {
  color: var(--color-acid-green);
}

.animate-marquee {
  animation: var(--animate-marquee);
}

/* Scroll indicator */
.hero__scroll {
  position: absolute;
  bottom: 3.5rem;
  left: 50%;
  transform: translateX(-50%);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 3rem;
  height: 3rem;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  transition: all 0.3s ease;
  animation: var(--animate-fade-in, fade-in 1s ease 1.5s both);
}

.hero__scroll:hover {
  background: var(--color-acid-green);
  color: black;
  border-color: var(--color-acid-green);
  transform: translateX(-50%) translateY(5px);
}

/* Animation utilities */
.animate-fade-up {
  animation: var(--animate-fade-up, fade-up 0.6s ease both);
}
</style>
</style>

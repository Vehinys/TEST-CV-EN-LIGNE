---
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
  alternateLangPath: string;
}

const { lang, alternateLangPath } = Astro.props;
const alternateLangLabel = lang === 'fr' ? 'EN' : 'FR';
const alternateLangAriaLabel = lang === 'fr' ? 'Switch to English' : 'Passer en français';
const startLabel = lang === 'fr' ? 'Albert.exe — Menu principal' : 'Albert.exe — Main menu';
---

<nav class="taskbar" role="navigation" aria-label={lang === 'fr' ? 'Barre des tâches' : 'Taskbar'}>
  <!-- Left: Start button -->
  <button
    class="taskbar__start"
    id="taskbar-start"
    aria-label={startLabel}
    type="button"
  >
    <span class="taskbar__start-icon" aria-hidden="true">⚡</span>
    <span class="taskbar__start-label">Albert.exe</span>
  </button>

  <!-- Center: Open windows -->
  <div
    id="taskbar-windows"
    class="taskbar__windows"
    role="list"
    aria-label={lang === 'fr' ? 'Fenêtres ouvertes' : 'Open windows'}
  ></div>

  <!-- Right: Lang + Clock -->
  <div class="taskbar__right">
    <a
      href={alternateLangPath}
      class="taskbar__lang"
      aria-label={alternateLangAriaLabel}
      lang={alternateLangLabel.toLowerCase()}
    >
      {alternateLangLabel}
    </a>
    <time
      id="taskbar-clock"
      class="taskbar__clock"
      aria-live="polite"
      aria-label={lang === 'fr' ? 'Heure actuelle' : 'Current time'}
    ></time>
  </div>
</nav>

<style>
.taskbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 48px;
  background: rgba(8, 4, 20, 0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1px solid rgba(139, 92, 246, 0.2);
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0 0.75rem;
  z-index: 1000;
}

.taskbar__start {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  background: rgba(139, 92, 246, 0.15);
  border: 1px solid rgba(139, 92, 246, 0.3);
  color: #FAF5FF;
  padding: 0.375rem 0.875rem;
  border-radius: 0.375rem;
  cursor: pointer;
  font-size: 0.8125rem;
  font-weight: 600;
  transition: background 0.2s ease, border-color 0.2s ease;
  font-family: inherit;
  flex-shrink: 0;
}

.taskbar__start:hover {
  background: rgba(139, 92, 246, 0.3);
  border-color: rgba(139, 92, 246, 0.5);
}

.taskbar__start:focus-visible {
  outline: 2px solid #F59E0B;
  outline-offset: 2px;
}

.taskbar__start-icon {
  font-size: 1rem;
}

.taskbar__windows {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 0.375rem;
  overflow-x: auto;
  min-width: 0;
  /* hide scrollbar */
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.taskbar__windows::-webkit-scrollbar {
  display: none;
}

.taskbar__right {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-left: auto;
  flex-shrink: 0;
}

.taskbar__lang {
  font-size: 0.75rem;
  font-weight: 700;
  color: #F59E0B;
  text-decoration: none;
  padding: 0.25rem 0.5rem;
  border-radius: 0.25rem;
  border: 1px solid rgba(245, 158, 11, 0.3);
  transition: all 0.2s ease;
  letter-spacing: 0.03em;
}

.taskbar__lang:hover {
  background: rgba(245, 158, 11, 0.1);
  border-color: rgba(245, 158, 11, 0.5);
  color: #FCD34D;
}

.taskbar__lang:focus-visible {
  outline: 2px solid #F59E0B;
  outline-offset: 2px;
}

.taskbar__clock {
  font-size: 0.8125rem;
  color: #C4B5FD;
  font-variant-numeric: tabular-nums;
  min-width: 5rem;
  text-align: right;
  font-family: 'JetBrains Mono', 'Fira Code', monospace;
}
</style>

<script>
(function () {
  // ── Live clock ──────────────────────────────────────────────────────────────
  const clockEl = document.getElementById('taskbar-clock') as HTMLTimeElement | null;

  function updateClock(): void {
    if (!clockEl) return;
    const now = new Date();
    const timeStr = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    clockEl.textContent = timeStr;
    clockEl.setAttribute('datetime', now.toISOString());
  }

  updateClock();
  setInterval(updateClock, 1000);

  // ── Start button — open "about" window ──────────────────────────────────────
  const startBtn = document.getElementById('taskbar-start');
  if (startBtn) {
    startBtn.addEventListener('click', async () => {
      const { open } = await import('../../utils/window-manager');
      open('about');
    });
  }
})();
</script>

---
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
  alternateLangPath: string;
}

const { lang, alternateLangPath } = Astro.props;
const alternateLangLabel = lang === 'fr' ? 'EN' : 'FR';
const alternateLangAriaLabel = lang === 'fr' ? 'Switch to English' : 'Passer en français';
const startLabel = lang === 'fr' ? 'Albert.exe — Menu principal' : 'Albert.exe — Main menu';
---

<!-- Start Menu popup -->
<div
  id="start-menu"
  class="start-menu"
  hidden
  role="dialog"
  aria-label={lang === 'fr' ? 'Menu principal' : 'Main menu'}
  aria-modal="false"
>
  <!-- Header -->
  <div class="start-menu__header">
    <div class="start-menu__avatar" aria-hidden="true">⚡</div>
    <div class="start-menu__identity">
      <p class="start-menu__name">Albert Lecomte</p>
      <p class="start-menu__role">{lang === 'fr' ? 'Concepteur Designer UI' : 'UI Designer Conceptor'}</p>
    </div>
  </div>

  <!-- Section: navigation -->
  <ul class="start-menu__section" role="list">
    <li>
      <button class="start-menu__item" type="button" data-start-open="about">
        <span class="start-menu__item-icon" aria-hidden="true">👤</span>
        <span>{lang === 'fr' ? 'À propos' : 'About'}</span>
      </button>
    </li>
    <li>
      <button class="start-menu__item" type="button" data-start-open="projects">
        <span class="start-menu__item-icon" aria-hidden="true">📁</span>
        <span>{lang === 'fr' ? 'Projets' : 'Projects'}</span>
      </button>
    </li>
    <li>
      <button class="start-menu__item" type="button" data-start-open="contact">
        <span class="start-menu__item-icon" aria-hidden="true">📧</span>
        <span>Contact</span>
      </button>
    </li>
    <li>
      <a class="start-menu__item" href="/cv/albert-lecomte-cv.pdf" download>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" style="flex-shrink:0">
          <rect width="24" height="24" rx="3" fill="#E02020"/>
          <rect x="2" y="10" width="20" height="9" rx="1.5" fill="#B91C1C"/>
          <text x="12" y="17.5" text-anchor="middle" font-family="Arial,sans-serif" font-size="6.5" font-weight="900" fill="white" letter-spacing="0.3">PDF</text>
        </svg>
        <span>{lang === 'fr' ? 'Télécharger CV' : 'Download CV'}</span>
      </a>
    </li>
  </ul>

  <div class="start-menu__sep" role="separator"></div>

  <!-- Section: legal -->
  <ul class="start-menu__section start-menu__section--legal" role="list">
    <li class="start-menu__section-label" aria-hidden="true">
      {lang === 'fr' ? 'Informations légales' : 'Legal'}
    </li>
    <li>
      <button class="start-menu__item start-menu__item--legal" type="button" data-start-open="mentions-legales">
        <span class="start-menu__item-icon" aria-hidden="true">⚖️</span>
        <span>{lang === 'fr' ? 'Mentions légales' : 'Legal notice'}</span>
      </button>
    </li>
    <li>
      <button class="start-menu__item start-menu__item--legal" type="button" data-start-open="politique">
        <span class="start-menu__item-icon" aria-hidden="true">🔒</span>
        <span>{lang === 'fr' ? 'Politique de confidentialité' : 'Privacy policy'}</span>
      </button>
    </li>
  </ul>
</div>

<nav class="taskbar" role="navigation" aria-label={lang === 'fr' ? 'Barre des tâches' : 'Taskbar'}>
  <!-- Left: Start button -->
  <button
    class="taskbar__start"
    id="taskbar-start"
    aria-label={startLabel}
    aria-expanded="false"
    aria-haspopup="dialog"
    aria-controls="start-menu"
    type="button"
  >
    <span class="taskbar__start-icon" aria-hidden="true">⚡</span>
    <span class="taskbar__start-label">Albert.exe</span>
  </button>

  <!-- Center: Open windows -->
  <div
    id="taskbar-windows"
    class="taskbar__windows"
    role="list"
    aria-label={lang === 'fr' ? 'Fenêtres ouvertes' : 'Open windows'}
  ></div>

  <!-- Right: Mode toggle + Lang + Clock -->
  <div class="taskbar__right">
    <button
      id="mode-toggle-btn"
      class="taskbar__mode-btn"
      type="button"
      aria-label={lang === 'fr' ? 'Passer en mode portfolio classique' : 'Switch to classic portfolio mode'}
    >
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="2"/>
        <path d="M3 9h18M9 21V9"/>
      </svg>
      <span>{lang === 'fr' ? 'Mode classique' : 'Classic'}</span>
    </button>

    <a
      href={alternateLangPath}
      class="taskbar__lang"
      aria-label={alternateLangAriaLabel}
      lang={alternateLangLabel.toLowerCase()}
    >
      {alternateLangLabel}
    </a>
    <time
      id="taskbar-clock"
      class="taskbar__clock"
      aria-live="polite"
      aria-label={lang === 'fr' ? 'Heure actuelle' : 'Current time'}
    ></time>
  </div>
</nav>

<style>
/* ── Start Menu ────────────────────────────────────────────────── */
.start-menu {
  position: fixed;
  bottom: 52px;
  left: 0.5rem;
  width: 240px;
  background: rgba(8, 4, 20, 0.97);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1px solid rgba(139, 92, 246, 0.35);
  border-radius: 0.625rem;
  z-index: 1100;
  box-shadow: 0 -8px 32px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(139, 92, 246, 0.1);
  overflow: hidden;
  animation: start-menu-in 0.15s ease;
}

.start-menu[hidden] { display: none; }

@keyframes start-menu-in {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

.start-menu__header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.875rem 1rem;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.2) 0%, rgba(139, 92, 246, 0.06) 100%);
  border-bottom: 1px solid rgba(139, 92, 246, 0.2);
}

.start-menu__avatar {
  width: 2.25rem;
  height: 2.25rem;
  border-radius: 50%;
  background: rgba(139, 92, 246, 0.2);
  border: 1px solid rgba(139, 92, 246, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.1rem;
  flex-shrink: 0;
}

.start-menu__name {
  margin: 0;
  font-size: 0.8125rem;
  font-weight: 700;
  color: #FAF5FF;
  line-height: 1.2;
}

.start-menu__role {
  margin: 0.15rem 0 0;
  font-size: 0.65rem;
  color: #8B5CF6;
  font-weight: 500;
}

.start-menu__section {
  list-style: none;
  padding: 0.375rem 0;
  margin: 0;
}

.start-menu__section-label {
  font-size: 0.6rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #475569;
  padding: 0.375rem 1rem 0.125rem;
}

.start-menu__section--legal {
  padding-bottom: 0.375rem;
}

.start-menu__item {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  width: 100%;
  padding: 0.45rem 1rem;
  background: transparent;
  border: none;
  color: var(--color-text-subtle);
  font-size: 0.8rem;
  font-weight: 500;
  cursor: pointer;
  font-family: inherit;
  text-decoration: none;
  transition: background 0.12s ease, color 0.12s ease;
  text-align: left;
}

.start-menu__item:hover {
  background: rgba(139, 92, 246, 0.15);
  color: #FAF5FF;
}

.start-menu__item:focus-visible {
  outline: 2px solid #F59E0B;
  outline-offset: -2px;
}

.start-menu__item--legal {
  color: var(--color-text-dim);
  font-size: 0.75rem;
}

.start-menu__item--legal:hover {
  color: var(--color-text-subtle);
}

.start-menu__item-icon {
  font-size: 0.875rem;
  flex-shrink: 0;
}

.start-menu__sep {
  height: 1px;
  background: rgba(139, 92, 246, 0.15);
  margin: 0;
}

/* ── Taskbar ───────────────────────────────────────────────────── */
.taskbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 48px;
  background: rgba(8, 4, 20, 0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1px solid rgba(139, 92, 246, 0.2);
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0 0.75rem;
  z-index: 1000;
}

.taskbar__start {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  background: rgba(139, 92, 246, 0.15);
  border: 1px solid rgba(139, 92, 246, 0.3);
  color: #FAF5FF;
  padding: 0.375rem 0.875rem;
  border-radius: 0.375rem;
  cursor: pointer;
  font-size: 0.8125rem;
  font-weight: 600;
  transition: background 0.2s ease, border-color 0.2s ease;
  font-family: inherit;
  flex-shrink: 0;
}

.taskbar__start:hover {
  background: rgba(139, 92, 246, 0.3);
  border-color: rgba(139, 92, 246, 0.5);
}

.taskbar__start:focus-visible {
  outline: 2px solid #F59E0B;
  outline-offset: 2px;
}

.taskbar__start-icon {
  font-size: 1rem;
}

.taskbar__windows {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 0.375rem;
  overflow-x: auto;
  min-width: 0;
  /* hide scrollbar */
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.taskbar__windows::-webkit-scrollbar {
  display: none;
}

.taskbar__right {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-left: auto;
  flex-shrink: 0;
}

.taskbar__mode-btn {
  display: flex;
  align-items: center;
  gap: 0.375rem;
  background: rgba(139, 92, 246, 0.1);
  border: 1px solid rgba(139, 92, 246, 0.25);
  color: var(--color-text-subtle);
  font-size: 0.7rem;
  font-weight: 600;
  padding: 0.25rem 0.625rem;
  border-radius: 0.25rem;
  cursor: pointer;
  font-family: inherit;
  transition: all 0.2s ease;
  letter-spacing: 0.02em;
  white-space: nowrap;
}

.taskbar__mode-btn:hover {
  background: rgba(139, 92, 246, 0.25);
  border-color: rgba(139, 92, 246, 0.5);
  color: #FAF5FF;
}

.taskbar__mode-btn:focus-visible {
  outline: 2px solid #F59E0B;
  outline-offset: 2px;
}

.taskbar__lang {
  font-size: 0.75rem;
  font-weight: 700;
  color: #F59E0B;
  text-decoration: none;
  padding: 0.25rem 0.5rem;
  border-radius: 0.25rem;
  border: 1px solid rgba(245, 158, 11, 0.3);
  transition: all 0.2s ease;
  letter-spacing: 0.03em;
}

.taskbar__lang:hover {
  background: rgba(245, 158, 11, 0.1);
  border-color: rgba(245, 158, 11, 0.5);
  color: #FCD34D;
}

.taskbar__lang:focus-visible {
  outline: 2px solid #F59E0B;
  outline-offset: 2px;
}

.taskbar__clock {
  font-size: 0.8125rem;
  color: var(--color-text-subtle);
  font-variant-numeric: tabular-nums;
  min-width: 5rem;
  text-align: right;
  font-family: 'JetBrains Mono', 'Fira Code', monospace;
}
</style>

<script>
(function () {
  // ── Live clock ──────────────────────────────────────────────────────────────
  const clockEl = document.getElementById('taskbar-clock') as HTMLTimeElement | null;

  function updateClock(): void {
    if (!clockEl) return;
    const now = new Date();
    const timeStr = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    clockEl.textContent = timeStr;
    clockEl.setAttribute('datetime', now.toISOString());
  }

  updateClock();
  setInterval(updateClock, 1000);

  // ── Start Menu ───────────────────────────────────────────────────────────────
  const startBtn  = document.getElementById('taskbar-start');
  const startMenu = document.getElementById('start-menu') as HTMLElement | null;
  if (!startBtn || !startMenu) return;
  const menu = startMenu as HTMLElement;

  function openMenu(): void {
    menu.hidden = false;
    // Force animation replay on subsequent opens
    menu.style.animation = 'none';
    void menu.offsetHeight; // reflow
    menu.style.animation = '';
    startBtn!.setAttribute('aria-expanded', 'true');
    const first = menu.querySelector<HTMLElement>('.start-menu__item');
    first?.focus();
  }

  function closeMenu(): void {
    menu.hidden = true;
    startBtn!.setAttribute('aria-expanded', 'false');
  }

  startBtn.addEventListener('click', (e) => {
    e.stopPropagation(); // empêche le document listener de fermer immédiatement
    if (menu.hidden) openMenu(); else closeMenu();
  });

  // Close on outside click (ignore clicks inside menu ou sur le bouton)
  document.addEventListener('click', (e) => {
    if (!menu.hidden && !menu.contains(e.target as Node)) {
      closeMenu();
    }
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !menu.hidden) {
      closeMenu();
      startBtn.focus();
    }
  });

  // Open window items in start menu
  menu.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>('[data-start-open]');
    if (!btn) return;
    const id = btn.dataset['startOpen'];
    if (!id) return;
    closeMenu();
    const { open } = await import('../../utils/window-manager');
    open(id);
  });
})();
</script>

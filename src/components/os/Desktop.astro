---
import type { Lang } from '../../i18n/utils';
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

interface DesktopIcon {
  id: string;
  emoji: string;
  labelKey: string;
  isDownload?: boolean;
}

const icons: DesktopIcon[] = [
  { id: 'about',      emoji: '👤', labelKey: 'os.icon.about' },
  { id: 'projects',   emoji: '📁', labelKey: 'os.icon.projects' },
  { id: 'skills',     emoji: '🛠️', labelKey: 'os.icon.skills' },
  { id: 'experience', emoji: '💼', labelKey: 'os.icon.experience' },
  { id: 'volunteer',  emoji: '🤝', labelKey: 'os.icon.volunteer' },
  { id: 'hobbies',    emoji: '🎮', labelKey: 'os.icon.hobbies' },
  { id: 'contact',    emoji: '📧', labelKey: 'os.icon.contact' },
  { id: 'cv',         emoji: '📄', labelKey: 'os.icon.cv', isDownload: true },
];
---

<!-- Particle canvas — fullscreen background -->
<canvas
  id="particles-canvas"
  aria-hidden="true"
  style="position:fixed;inset:0;width:100%;height:100%;z-index:0;pointer-events:none;"
></canvas>

<!-- Desktop area (above taskbar) -->
<div class="desktop" role="main" id="main-content" tabindex="-1" aria-label={lang === 'fr' ? 'Bureau Albert.exe' : 'Albert.exe Desktop'}>
  <ul class="desktop__icons" role="list" aria-label={lang === 'fr' ? 'Icônes du bureau' : 'Desktop icons'}>
    {icons.map((icon) => (
      <li role="listitem">
        {icon.isDownload ? (
          <a
            href="/cv/albert-lecomte-cv.pdf"
            download
            class="desktop-icon"
            aria-label={`${t(icon.labelKey)} — ${lang === 'fr' ? 'Télécharger' : 'Download'}`}
          >
            <span class="desktop-icon__emoji" aria-hidden="true">{icon.emoji}</span>
            <span class="desktop-icon__label">{t(icon.labelKey)}</span>
          </a>
        ) : (
          <button
            class="desktop-icon"
            data-open={icon.id}
            aria-label={`${lang === 'fr' ? 'Ouvrir' : 'Open'} ${t(icon.labelKey)}`}
            type="button"
          >
            <span class="desktop-icon__emoji" aria-hidden="true">{icon.emoji}</span>
            <span class="desktop-icon__label">{t(icon.labelKey)}</span>
          </button>
        )}
      </li>
    ))}
  </ul>
</div>

<style>
.desktop {
  position: fixed;
  inset: 0;
  bottom: 48px;
  z-index: 1;
  pointer-events: none; /* allow clicks to pass through to canvas background */
}

.desktop__icons {
  position: absolute;
  left: 1rem;
  top: 1rem;
  display: grid;
  grid-template-columns: repeat(2, 5rem);
  gap: 0.75rem;
  list-style: none;
  padding: 0;
  margin: 0;
  pointer-events: auto;
}

.desktop-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.375rem;
  width: 5rem;
  padding: 0.5rem 0.25rem;
  border-radius: 0.5rem;
  background: transparent;
  border: none;
  cursor: pointer;
  color: #FAF5FF;
  text-decoration: none;
  transition: background 0.2s ease, transform 0.15s ease;
}

.desktop-icon:hover {
  background: rgba(139, 92, 246, 0.15);
}

.desktop-icon:hover .desktop-icon__emoji {
  filter: drop-shadow(0 0 8px rgba(139, 92, 246, 0.5));
}

.desktop-icon:active,
.desktop-icon--active {
  transform: scale(0.92);
}

.desktop-icon:focus-visible {
  outline: 2px solid #F59E0B;
  outline-offset: 2px;
}

.desktop-icon__emoji {
  font-size: 2.25rem;
  line-height: 1;
  filter: drop-shadow(0 0 8px rgba(139, 92, 246, 0));
  transition: filter 0.2s ease;
}

.desktop-icon__label {
  font-size: 0.6875rem;
  text-align: center;
  line-height: 1.2;
  color: rgba(250, 245, 255, 0.85);
  word-break: break-word;
  max-width: 4.5rem;
  text-shadow: 0 1px 4px rgba(0, 0, 0, 0.6);
}
</style>

<script>
(function () {
  // ── Particle system ─────────────────────────────────────────────────────────
  const canvasEl = document.getElementById('particles-canvas') as HTMLCanvasElement | null;
  if (!canvasEl) return;

  const ctxMaybe = canvasEl.getContext('2d');
  if (!ctxMaybe) return;

  // Non-null typed references for use inside closures
  const canvas: HTMLCanvasElement = canvasEl;
  const ctx: CanvasRenderingContext2D = ctxMaybe;

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  interface Particle {
    x: number;
    y: number;
    vx: number;
    vy: number;
    radius: number;
    color: string;
    opacity: number;
  }

  const PARTICLE_COUNT = 60;
  const CONNECTION_DISTANCE = 120;
  const COLORS = [
    'rgba(139, 92, 246,',   // violet
    'rgba(167, 139, 250,',  // violet-light
    'rgba(245, 158, 11,',   // gold
  ];

  let particles: Particle[] = [];
  let animId = 0;

  function resize(): void {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }

  function createParticles(): void {
    particles = Array.from({ length: PARTICLE_COUNT }, () => {
      const colorBase = COLORS[Math.floor(Math.random() * COLORS.length)] ?? COLORS[0]!;
      return {
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        vx: (Math.random() - 0.5) * 0.5,
        vy: (Math.random() - 0.5) * 0.5,
        radius: Math.random() * 2 + 1,
        color: colorBase,
        opacity: Math.random() * 0.4 + 0.3,
      };
    });
  }

  function drawStatic(): void {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    for (const p of particles) {
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
      ctx.fillStyle = `${p.color}${p.opacity})`;
      ctx.fill();
    }
  }

  function drawAnimated(): void {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // Move particles
    for (const p of particles) {
      p.x += p.vx;
      p.y += p.vy;

      // Wrap around edges
      if (p.x < 0) p.x = canvas.width;
      if (p.x > canvas.width) p.x = 0;
      if (p.y < 0) p.y = canvas.height;
      if (p.y > canvas.height) p.y = 0;
    }

    // Draw connections
    for (let i = 0; i < particles.length; i++) {
      const a = particles[i];
      if (!a) continue;
      for (let j = i + 1; j < particles.length; j++) {
        const b = particles[j];
        if (!b) continue;
        const dx = a.x - b.x;
        const dy = a.y - b.y;
        const dist = Math.sqrt(dx * dx + dy * dy);

        if (dist < CONNECTION_DISTANCE) {
          const alpha = (1 - dist / CONNECTION_DISTANCE) * 0.15;
          ctx.beginPath();
          ctx.moveTo(a.x, a.y);
          ctx.lineTo(b.x, b.y);
          ctx.strokeStyle = `rgba(139, 92, 246, ${alpha})`;
          ctx.lineWidth = 0.8;
          ctx.stroke();
        }
      }
    }

    // Draw dots
    for (const p of particles) {
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
      ctx.fillStyle = `${p.color}${p.opacity})`;
      ctx.fill();
    }

    animId = requestAnimationFrame(drawAnimated);
  }

  function init(): void {
    resize();
    createParticles();

    if (prefersReducedMotion) {
      drawStatic();
    } else {
      if (animId) cancelAnimationFrame(animId);
      drawAnimated();
    }
  }

  const resizeObserver = new ResizeObserver(() => {
    resize();
    if (prefersReducedMotion) {
      drawStatic();
    }
  });
  resizeObserver.observe(document.body);

  init();
  window.addEventListener('resize', () => {
    resize();
    createParticles();
    if (!prefersReducedMotion) {
      if (animId) cancelAnimationFrame(animId);
      drawAnimated();
    }
  });

  // ── Desktop icon interaction ─────────────────────────────────────────────────
  const lastClickTime: Record<string, number> = {};
  const isMobile = window.matchMedia('(pointer: coarse)').matches;

  async function openWindow(id: string): Promise<void> {
    const { open } = await import('../../utils/window-manager');
    open(id);
  }

  const desktopIcons = document.querySelectorAll<HTMLButtonElement>('.desktop-icon[data-open]');

  desktopIcons.forEach((btn) => {
    const id = btn.dataset['open'];
    if (!id) return;

    if (isMobile) {
      // Single tap on mobile
      btn.addEventListener('click', () => {
        btn.classList.add('desktop-icon--active');
        setTimeout(() => btn.classList.remove('desktop-icon--active'), 150);
        void openWindow(id);
      });
    } else {
      // Double-click on desktop
      btn.addEventListener('click', () => {
        const now = Date.now();
        const last = lastClickTime[id] ?? 0;

        if (now - last < 300) {
          // Double click
          btn.classList.add('desktop-icon--active');
          setTimeout(() => btn.classList.remove('desktop-icon--active'), 150);
          void openWindow(id);
        }
        lastClickTime[id] = now;
      });
    }
  });
})();
</script>

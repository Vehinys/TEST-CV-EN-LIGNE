---
import type { Lang } from '../../i18n/utils';
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

interface DesktopIcon {
  id: string;
  emoji: string;
  labelKey: string;
  isDownload?: boolean;
}

const icons: DesktopIcon[] = [
  { id: 'about',      emoji: '👤', labelKey: 'os.icon.about' },
  { id: 'projects',   emoji: '📁', labelKey: 'os.icon.projects' },
  { id: 'skills',     emoji: '🛠️', labelKey: 'os.icon.skills' },
  { id: 'experience', emoji: '💼', labelKey: 'os.icon.experience' },
  { id: 'volunteer',  emoji: '🤝', labelKey: 'os.icon.volunteer' },
  { id: 'hobbies',    emoji: '🎮', labelKey: 'os.icon.hobbies' },
  { id: 'contact',    emoji: '📧', labelKey: 'os.icon.contact' },
  { id: 'cv',         emoji: '📄', labelKey: 'os.icon.cv', isDownload: true },
];
---

<!-- Particle canvas — fullscreen background -->
<canvas
  id="particles-canvas"
  aria-hidden="true"
  style="position:fixed;inset:0;width:100%;height:100%;z-index:0;pointer-events:none;"
></canvas>

<!-- Desktop area (above taskbar) -->
<div class="desktop" role="main" id="main-content" tabindex="-1" aria-label={lang === 'fr' ? 'Bureau Albert.exe' : 'Albert.exe Desktop'}>
  <ul class="desktop__icons" role="list" aria-label={lang === 'fr' ? 'Icônes du bureau' : 'Desktop icons'}>
    {icons.map((icon) => (
      <li role="listitem" data-icon-id={icon.id}>
        {icon.isDownload ? (
          <a
            href="/cv/albert-lecomte-cv.pdf"
            download
            class="desktop-icon"
            aria-label={`${t(icon.labelKey)} — ${lang === 'fr' ? 'Télécharger' : 'Download'}`}
          >
            <span class="desktop-icon__emoji desktop-icon__emoji--pdf" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 36 36" width="36" height="36" role="img" aria-hidden="true">
                <rect width="36" height="36" rx="5" fill="#E02020"/>
                <path d="M6 0h18l6 6v30H6z" fill="none"/>
                <rect x="4" y="14" width="28" height="14" rx="2" fill="#B91C1C"/>
                <text x="18" y="25" text-anchor="middle" font-family="Arial,sans-serif" font-size="9" font-weight="900" fill="white" letter-spacing="0.5">PDF</text>
                <path d="M10 5h10v10h-10z" fill="none"/>
                <path d="M8 4h14l6 6v6H8z" fill="#F87171" opacity="0.25"/>
              </svg>
            </span>
            <span class="desktop-icon__label">{t(icon.labelKey)}</span>
          </a>
        ) : (
          <button
            class="desktop-icon"
            data-open={icon.id}
            aria-label={`${lang === 'fr' ? 'Ouvrir' : 'Open'} ${t(icon.labelKey)}`}
            type="button"
          >
            <span class="desktop-icon__emoji" aria-hidden="true">{icon.emoji}</span>
            <span class="desktop-icon__label">{t(icon.labelKey)}</span>
          </button>
        )}
      </li>
    ))}
  </ul>
</div>

<!-- Trash icon — desktop only (≥1024px), resets icon positions -->
<button
  id="desktop-trash"
  class="desktop-trash"
  type="button"
  aria-label="Remettre les icônes à leur position initiale"
>
  <span class="desktop-trash__emoji" aria-hidden="true">🗑️</span>
  <span class="desktop-trash__label">{lang === 'fr' ? 'Corbeille' : 'Trash'}</span>
</button>

<style>
.desktop {
  position: fixed;
  inset: 0;
  bottom: 48px;
  z-index: 1;
  pointer-events: none; /* allow clicks to pass through to canvas background */
}

.desktop__icons {
  position: absolute;
  left: 1rem;
  top: 1rem;
  display: grid;
  grid-template-columns: repeat(2, 5rem);
  gap: 0.75rem;
  list-style: none;
  padding: 0;
  margin: 0;
  pointer-events: auto;
}

.desktop-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.375rem;
  width: 5rem;
  padding: 0.5rem 0.25rem;
  border-radius: 0.5rem;
  background: transparent;
  border: none;
  cursor: pointer;
  color: #FAF5FF;
  text-decoration: none;
  transition: background 0.2s ease, transform 0.15s ease;
}

.desktop-icon:hover {
  background: rgba(139, 92, 246, 0.15);
}

.desktop-icon:hover .desktop-icon__emoji {
  filter: drop-shadow(0 0 8px rgba(139, 92, 246, 0.5));
}

.desktop-icon:hover .desktop-icon__emoji--pdf svg {
  filter: drop-shadow(0 0 8px rgba(139, 92, 246, 0.5));
}

.desktop-icon:active,
.desktop-icon--active {
  transform: scale(0.92);
}

.desktop-icon:focus-visible {
  outline: 2px solid #F59E0B;
  outline-offset: 2px;
}

.desktop-icon__emoji {
  font-size: 2.25rem;
  line-height: 1;
  filter: drop-shadow(0 0 8px rgba(139, 92, 246, 0));
  transition: filter 0.2s ease;
}

.desktop-icon__emoji--pdf {
  font-size: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.desktop-icon__emoji--pdf svg {
  filter: drop-shadow(0 0 8px rgba(139, 92, 246, 0));
  transition: filter 0.2s ease;
}

.desktop-icon__label {
  font-size: 0.6875rem;
  text-align: center;
  line-height: 1.2;
  color: rgba(250, 245, 255, 0.85);
  word-break: break-word;
  max-width: 4.5rem;
  text-shadow: 0 1px 4px rgba(0, 0, 0, 0.6);
}

/* ── Trash / reset button — desktop only ──────────────────────────────── */
.desktop-trash {
  display: none; /* hidden by default — shown only on hover-capable ≥1024px */
  position: fixed;
  right: 1rem;
  bottom: 60px;
  flex-direction: column;
  align-items: center;
  gap: 0.375rem;
  width: 5rem;
  padding: 0.5rem 0.25rem;
  border-radius: 0.5rem;
  background: transparent;
  border: none;
  cursor: pointer;
  color: #FAF5FF;
  z-index: 50;
  transition: background 0.2s ease;
}

@media (min-width: 1024px) and (hover: hover) {
  .desktop-trash {
    display: flex;
  }
}

.desktop-trash:hover {
  background: rgba(239, 68, 68, 0.15);
}

.desktop-trash:hover .desktop-trash__emoji {
  filter: drop-shadow(0 0 8px rgba(239, 68, 68, 0.5));
}

.desktop-trash:focus-visible {
  outline: 2px solid #F59E0B;
  outline-offset: 2px;
}

.desktop-trash__emoji {
  font-size: 2.25rem;
  line-height: 1;
  filter: drop-shadow(0 0 8px rgba(239, 68, 68, 0));
  transition: filter 0.2s ease;
}

.desktop-trash__label {
  font-size: 0.6875rem;
  text-align: center;
  line-height: 1.2;
  color: rgba(250, 245, 255, 0.85);
  text-shadow: 0 1px 4px rgba(0, 0, 0, 0.6);
}

/* ── Draggable icons — desktop & large tablet only ─────────────────────── */
@media (min-width: 1024px) {
  .desktop__icons {
    display: block;
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .desktop__icons li {
    position: absolute;
    width: 5rem;
  }

  .desktop-icon {
    cursor: grab;
  }
}
</style>

<script>
(function () {
  // ── Particle system ─────────────────────────────────────────────────────────
  const canvasEl = document.getElementById('particles-canvas') as HTMLCanvasElement | null;
  if (!canvasEl) return;

  const ctxMaybe = canvasEl.getContext('2d');
  if (!ctxMaybe) return;

  // Non-null typed references for use inside closures
  const canvas: HTMLCanvasElement = canvasEl;
  const ctx: CanvasRenderingContext2D = ctxMaybe;

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  interface Particle {
    x: number;
    y: number;
    vx: number;
    vy: number;
    radius: number;
    color: string;
    opacity: number;
  }

  const PARTICLE_COUNT = 60;
  const CONNECTION_DISTANCE = 120;
  const COLORS = [
    'rgba(139, 92, 246,',   // violet
    'rgba(167, 139, 250,',  // violet-light
    'rgba(245, 158, 11,',   // gold
  ];

  let particles: Particle[] = [];
  let animId = 0;

  function resize(): void {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }

  function createParticles(): void {
    particles = Array.from({ length: PARTICLE_COUNT }, () => {
      const colorBase = COLORS[Math.floor(Math.random() * COLORS.length)] ?? COLORS[0]!;
      return {
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        vx: (Math.random() - 0.5) * 0.5,
        vy: (Math.random() - 0.5) * 0.5,
        radius: Math.random() * 2 + 1,
        color: colorBase,
        opacity: Math.random() * 0.4 + 0.3,
      };
    });
  }

  function drawStatic(): void {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    for (const p of particles) {
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
      ctx.fillStyle = `${p.color}${p.opacity})`;
      ctx.fill();
    }
  }

  function drawAnimated(): void {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // Move particles
    for (const p of particles) {
      p.x += p.vx;
      p.y += p.vy;

      // Wrap around edges
      if (p.x < 0) p.x = canvas.width;
      if (p.x > canvas.width) p.x = 0;
      if (p.y < 0) p.y = canvas.height;
      if (p.y > canvas.height) p.y = 0;
    }

    // Draw connections
    for (let i = 0; i < particles.length; i++) {
      const a = particles[i];
      if (!a) continue;
      for (let j = i + 1; j < particles.length; j++) {
        const b = particles[j];
        if (!b) continue;
        const dx = a.x - b.x;
        const dy = a.y - b.y;
        const dist = Math.sqrt(dx * dx + dy * dy);

        if (dist < CONNECTION_DISTANCE) {
          const alpha = (1 - dist / CONNECTION_DISTANCE) * 0.15;
          ctx.beginPath();
          ctx.moveTo(a.x, a.y);
          ctx.lineTo(b.x, b.y);
          ctx.strokeStyle = `rgba(139, 92, 246, ${alpha})`;
          ctx.lineWidth = 0.8;
          ctx.stroke();
        }
      }
    }

    // Draw dots
    for (const p of particles) {
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
      ctx.fillStyle = `${p.color}${p.opacity})`;
      ctx.fill();
    }

    animId = requestAnimationFrame(drawAnimated);
  }

  function init(): void {
    resize();
    createParticles();

    if (prefersReducedMotion) {
      drawStatic();
    } else {
      if (animId) cancelAnimationFrame(animId);
      drawAnimated();
    }
  }

  const resizeObserver = new ResizeObserver(() => {
    resize();
    if (prefersReducedMotion) {
      drawStatic();
    }
  });
  resizeObserver.observe(document.body);

  init();
  window.addEventListener('resize', () => {
    resize();
    createParticles();
    if (!prefersReducedMotion) {
      if (animId) cancelAnimationFrame(animId);
      drawAnimated();
    }
  });

  // ── Desktop icon interaction ─────────────────────────────────────────────────
  const lastClickTime: Record<string, number> = {};
  const isMobile = window.matchMedia('(pointer: coarse)').matches;
  const recentlyDragged = new Set<string>();

  async function openWindow(id: string): Promise<void> {
    const { open } = await import('../../utils/window-manager');
    open(id);
  }

  const desktopIcons = document.querySelectorAll<HTMLButtonElement>('.desktop-icon[data-open]');

  desktopIcons.forEach((btn) => {
    const id = btn.dataset['open'];
    if (!id) return;

    if (isMobile) {
      // Single tap on mobile
      btn.addEventListener('click', () => {
        btn.classList.add('desktop-icon--active');
        setTimeout(() => btn.classList.remove('desktop-icon--active'), 150);
        void openWindow(id);
      });
    } else {
      // Double-click on desktop
      btn.addEventListener('click', () => {
        if (recentlyDragged.has(id)) return;
        const now = Date.now();
        const last = lastClickTime[id] ?? 0;

        if (now - last < 300) {
          btn.classList.add('desktop-icon--active');
          setTimeout(() => btn.classList.remove('desktop-icon--active'), 150);
          void openWindow(id);
        }
        lastClickTime[id] = now;
      });
    }
  });

  // ── Draggable icons (desktop & large tablet ≥ 1024px, non-touch) ──────────
  const isLargeScreen = window.matchMedia('(min-width: 1024px)').matches;

  if (isLargeScreen && !isMobile) {
    const DRAG_THRESHOLD = 5;
    const ICON_STORAGE_KEY = 'albert-icon-positions-v1';
    const ICON_W = 80;
    const ICON_H = 100;
    const TASKBAR_H = 48;

    interface IconPos { x: number; y: number; }

    const DEFAULT_POSITIONS: Record<string, IconPos> = {
      about:      { x: 16,  y: 16 },
      projects:   { x: 108, y: 16 },
      skills:     { x: 16,  y: 128 },
      experience: { x: 108, y: 128 },
      volunteer:  { x: 16,  y: 240 },
      hobbies:    { x: 108, y: 240 },
      contact:    { x: 16,  y: 352 },
      cv:         { x: 108, y: 352 },
    };

    let iconPositions: Record<string, IconPos> = { ...DEFAULT_POSITIONS };
    try {
      const saved = localStorage.getItem(ICON_STORAGE_KEY);
      if (saved) {
        const parsed = JSON.parse(saved) as Record<string, IconPos>;
        iconPositions = { ...DEFAULT_POSITIONS, ...parsed };
      }
    } catch { /* ignore */ }

    function saveIconPositions(): void {
      try { localStorage.setItem(ICON_STORAGE_KEY, JSON.stringify(iconPositions)); }
      catch { /* ignore */ }
    }

    function clampX(x: number): number {
      return Math.max(0, Math.min(x, window.innerWidth - ICON_W));
    }
    function clampY(y: number): number {
      return Math.max(0, Math.min(y, window.innerHeight - TASKBAR_H - ICON_H));
    }

    // Apply saved positions
    const iconItems = document.querySelectorAll<HTMLElement>('.desktop__icons li[data-icon-id]');
    iconItems.forEach((li) => {
      const iconId = li.dataset['iconId'];
      if (!iconId) return;
      const pos = iconPositions[iconId] ?? DEFAULT_POSITIONS[iconId] ?? { x: 16, y: 16 };
      li.style.left = `${pos.x}px`;
      li.style.top  = `${pos.y}px`;
    });

    // Drag state
    let drag = {
      active: false,
      li: null as HTMLElement | null,
      iconId: '',
      startMouseX: 0, startMouseY: 0,
      startIconX: 0,  startIconY: 0,
      didDrag: false,
    };

    iconItems.forEach((li) => {
      li.addEventListener('mousedown', (e: MouseEvent) => {
        if (e.button !== 0) return;
        const iconId = li.dataset['iconId'] ?? '';
        const pos = iconPositions[iconId] ?? { x: 0, y: 0 };
        drag = {
          active: true, li, iconId,
          startMouseX: e.clientX, startMouseY: e.clientY,
          startIconX: pos.x,      startIconY: pos.y,
          didDrag: false,
        };
        e.preventDefault(); // prevent text selection
      });
    });

    window.addEventListener('mousemove', (e: MouseEvent) => {
      if (!drag.active || !drag.li) return;
      const dx = e.clientX - drag.startMouseX;
      const dy = e.clientY - drag.startMouseY;

      if (!drag.didDrag && (Math.abs(dx) > DRAG_THRESHOLD || Math.abs(dy) > DRAG_THRESHOLD)) {
        drag.didDrag = true;
        document.body.style.cursor    = 'grabbing';
        document.body.style.userSelect = 'none';
      }

      if (drag.didDrag) {
        const nx = clampX(drag.startIconX + dx);
        const ny = clampY(drag.startIconY + dy);
        drag.li.style.left = `${nx}px`;
        drag.li.style.top  = `${ny}px`;
        iconPositions[drag.iconId] = { x: nx, y: ny };
      }
    });

    window.addEventListener('mouseup', () => {
      if (!drag.active) return;
      if (drag.didDrag) {
        saveIconPositions();
        recentlyDragged.add(drag.iconId);
        requestAnimationFrame(() => recentlyDragged.delete(drag.iconId));
        document.body.style.cursor    = '';
        document.body.style.userSelect = '';
      }
      drag.active = false;
      drag.li     = null;
    });

    // Suppress CV download link click after drag
    const cvLi = document.querySelector<HTMLElement>('.desktop__icons li[data-icon-id="cv"]');
    const cvLink = cvLi?.querySelector<HTMLAnchorElement>('a.desktop-icon');
    cvLink?.addEventListener('click', (e) => {
      if (recentlyDragged.has('cv')) e.preventDefault();
    });

    // Trash button — show and wire reset
    const trashBtn = document.getElementById('desktop-trash') as HTMLButtonElement | null;
    if (trashBtn) {
      trashBtn.addEventListener('click', () => {
        iconPositions = { ...DEFAULT_POSITIONS };
        iconItems.forEach((li) => {
          const iconId = li.dataset['iconId'];
          if (!iconId) return;
          const pos = DEFAULT_POSITIONS[iconId] ?? { x: 16, y: 16 };
          li.style.left = `${pos.x}px`;
          li.style.top  = `${pos.y}px`;
        });
        try { localStorage.removeItem(ICON_STORAGE_KEY); } catch { /* ignore */ }
      });
    }
  }
})();
</script>

---
interface Props {
  id: string;
  title: string;
  icon: string;
  defaultX?: number;
  defaultY?: number;
  defaultWidth?: number;
  defaultHeight?: number;
}

const {
  id,
  title,
  icon,
  defaultX = 100,
  defaultY = 80,
  defaultWidth = 680,
  defaultHeight = 520,
} = Astro.props;
---

<div
  id={`window-${id}`}
  class="window window--closed"
  role="dialog"
  aria-label={title}
  aria-hidden="true"
  style={`left:${defaultX}px; top:${defaultY}px; width:${defaultWidth}px; height:${defaultHeight}px; z-index:100`}
>
  <div class="window__titlebar" data-window-id={id}>
    <div class="window__titlebar-left">
      <span class="window__icon" aria-hidden="true">{icon}</span>
      <span class="window__title">{title}</span>
    </div>
    <div class="window__controls" role="group" aria-label="Contrôles de fenêtre">
      <button
        class="window__btn window__btn--minimize"
        data-action="minimize"
        data-window={id}
        aria-label="Réduire"
        type="button"
      >
        <span aria-hidden="true">—</span>
      </button>
      <button
        class="window__btn window__btn--maximize"
        data-action="maximize"
        data-window={id}
        aria-label="Agrandir"
        type="button"
      >
        <span aria-hidden="true">⛶</span>
      </button>
      <button
        class="window__btn window__btn--close"
        data-action="close"
        data-window={id}
        aria-label="Fermer"
        type="button"
      >
        <span aria-hidden="true">✕</span>
      </button>
    </div>
  </div>

  <div class="window__content">
    <slot />
  </div>
</div>

<style>
.window {
  position: fixed;
  background: rgba(12, 8, 24, 0.92);
  border: 1px solid rgba(139, 92, 246, 0.3);
  border-radius: 0.75rem;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: 0 0 40px rgba(139, 92, 246, 0.15);
  transition: box-shadow 0.2s ease, border-color 0.2s ease;
  min-width: 300px;
  min-height: 200px;
}

.window--closed {
  display: none;
}

.window--minimized {
  display: none;
}

.window--maximized {
  position: fixed !important;
  left: 0 !important;
  top: 0 !important;
  width: 100vw !important;
  height: calc(100vh - 48px) !important;
  border-radius: 0 !important;
}

.window--active {
  border-color: rgba(139, 92, 246, 0.6);
  box-shadow: 0 0 60px rgba(139, 92, 246, 0.25);
}

.window__titlebar {
  height: 36px;
  min-height: 36px;
  background: rgba(20, 12, 40, 0.95);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 0.75rem;
  cursor: grab;
  user-select: none;
  flex-shrink: 0;
  border-bottom: 1px solid rgba(139, 92, 246, 0.15);
}

.window__titlebar:active {
  cursor: grabbing;
}

.window__titlebar-left {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  min-width: 0;
}

.window__icon {
  font-size: 0.875rem;
  flex-shrink: 0;
}

.window__title {
  font-size: 0.8125rem;
  font-weight: 600;
  color: #FAF5FF;
  opacity: 0.9;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.window__controls {
  display: flex;
  align-items: center;
  gap: 0.375rem;
  flex-shrink: 0;
}

.window__btn {
  width: 13px;
  height: 13px;
  border-radius: 50%;
  border: none;
  cursor: pointer;
  transition: all 0.15s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0;
  padding: 0;
  flex-shrink: 0;
}

.window__btn--minimize {
  background: #8B5CF6;
}

.window__btn--maximize {
  background: #A78BFA;
}

.window__btn--close {
  background: #F59E0B;
}

.window__btn:hover {
  font-size: 0.5rem;
  color: rgba(0, 0, 0, 0.7);
  filter: brightness(1.15);
}

.window__btn:focus-visible {
  outline: 2px solid #F59E0B;
  outline-offset: 2px;
}

.window__content {
  flex: 1;
  overflow-y: auto;
  padding: 1.5rem;
  min-height: 0;
  color: #FAF5FF;
}

/* Custom scrollbar inside windows */
.window__content::-webkit-scrollbar {
  width: 4px;
}

.window__content::-webkit-scrollbar-track {
  background: transparent;
}

.window__content::-webkit-scrollbar-thumb {
  background: rgba(139, 92, 246, 0.4);
  border-radius: 2px;
}

.window__content::-webkit-scrollbar-thumb:hover {
  background: #8B5CF6;
}

/* Responsive: on small screens, windows take full width */
@media (max-width: 640px) {
  .window {
    left: 0 !important;
    top: 0 !important;
    width: 100vw !important;
    height: calc(100vh - 48px) !important;
    border-radius: 0 !important;
  }
}
</style>

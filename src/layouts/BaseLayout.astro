---
import SEO from '../components/seo/SEO.astro';
import type { Lang } from '../i18n/utils';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  image?: string;
  /** Set true on legal pages to restore normal scrolling */
  isLegal?: boolean;
}

const { title, description, lang, image, isLegal = false } = Astro.props;
---

<!doctype html>
<html lang={lang} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preconnect fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <SEO title={title} description={description} {...(image ? { image } : {})} lang={lang} />

    <!-- Plausible Analytics (sans cookie) -->
    <script
      is:inline
      defer
      data-domain="lecomte-albert-cv.vercel.app"
      src="https://plausible.io/js/script.js"
    ></script>

    <!-- Theme init (prevents flash) -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        const pref = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', saved ?? pref ?? 'dark');
      })();
    </script>

    <!-- Portfolio mode init (prevents flash) -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('portfolio-mode');
        const isMobile = window.innerWidth < 1024;
        const mode = saved ?? (isMobile ? 'classic' : 'os');
        document.documentElement.setAttribute('data-portfolio-mode', mode);
      })();
    </script>

    <!-- Portfolio mode toggle — global handler -->
    <script is:inline>
      document.addEventListener('click', function (e) {
        var btn = e.target && e.target.closest && e.target.closest('#mode-toggle-btn');
        if (!btn) return;
        var html = document.documentElement;
        var next = html.getAttribute('data-portfolio-mode') === 'os' ? 'classic' : 'os';
        html.setAttribute('data-portfolio-mode', next);
        localStorage.setItem('portfolio-mode', next);
      });
    </script>
  </head>

  <body class={isLegal ? 'legal-page' : ''}>
    <!-- Skip link RGAA -->
    <a href="#main-content" class="skip-link">
      {lang === 'fr' ? 'Aller au contenu principal' : 'Skip to main content'}
    </a>

    <slot />

    <!-- Back to top -->
    <button
      id="back-to-top"
      class="back-to-top"
      type="button"
      aria-label={lang === 'fr' ? 'Retour en haut de page' : 'Back to top'}
    >
      ↑
    </button>
  </body>
</html>

<style>
.back-to-top {
  position: fixed;
  bottom: 1.5rem;
  right: 1.5rem;
  z-index: 40;
  width: 2.5rem;
  height: 2.5rem;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(13, 13, 26, 0.9);
  border: 1px solid rgba(204, 255, 0, 0.35);
  border-radius: 0.375rem;
  color: #CCFF00;
  font-size: 1rem;
  font-family: monospace;
  cursor: pointer;
  opacity: 0;
  pointer-events: none;
  transform: translateY(8px);
  transition: opacity 0.2s ease, transform 0.2s ease, background 0.15s ease, box-shadow 0.15s ease;
}

.back-to-top.visible {
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0);
}

.back-to-top:hover {
  background: rgba(204, 255, 0, 0.1);
  box-shadow: 0 0 12px rgba(204, 255, 0, 0.2);
}

.back-to-top:focus-visible {
  outline: 2px solid #CCFF00;
  outline-offset: 2px;
}

@media (prefers-reduced-motion: reduce) {
  .back-to-top {
    transition: opacity 0.2s ease;
    transform: none;
  }
}
</style>

<script>
(function () {
  const btn = document.getElementById('back-to-top');
  if (!btn) return;

  window.addEventListener('scroll', () => {
    if (window.scrollY > 300) {
      btn.classList.add('visible');
    } else {
      btn.classList.remove('visible');
    }
  }, { passive: true });

  btn.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
})();
</script>
